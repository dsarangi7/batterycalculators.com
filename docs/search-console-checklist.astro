---
import Layout from '../src/layouts/Layout.astro';
import CalculatorCard from '../src/components/CalculatorCard.astro';
import Breadcrumb from '../src/components/Breadcrumb.astro';
import MStripe from '../src/components/MStripe.astro';

const siteUrl = 'https://batterycalculators.com';

const checklist = [
  {
    title: 'Sitemap',
    status: 'ready',
    detail: `sitemap-index.xml is auto-generated by @astrojs/sitemap at build time. Verify at: ${siteUrl}/sitemap-index.xml`,
  },
  {
    title: 'robots.txt',
    status: 'ready',
    detail: 'Allows all crawlers. Disallows /admin/, /api/, /_astro/. Sitemap directive included.',
  },
  {
    title: 'Canonical URLs',
    status: 'ready',
    detail: 'Every page renders a <link rel="canonical"> via HeadSEO component. Auto-derived from site URL + pathname.',
  },
  {
    title: 'Structured Data (JSON-LD)',
    status: 'ready',
    detail: 'WebSite schema on homepage. WebApplication schema on all calculator pages. FAQPage schema on pages with FAQ sections.',
  },
  {
    title: 'Open Graph Tags',
    status: 'ready',
    detail: 'og:title, og:description, og:image, og:url, og:site_name emitted on every page.',
  },
  {
    title: 'Twitter Card Tags',
    status: 'ready',
    detail: 'summary_large_image card on every page with title, description, and image.',
  },
  {
    title: 'Semantic HTML',
    status: 'ready',
    detail: 'Uses <header>, <main>, <footer>, <nav> landmarks. <h1>–<h3> hierarchy maintained.',
  },
  {
    title: 'Mobile Viewport',
    status: 'ready',
    detail: 'meta viewport set to width=device-width, initial-scale=1.0. All layouts are mobile-first responsive.',
  },
  {
    title: 'Alt Text / A11y',
    status: 'partial',
    detail: 'SVG icons use aria-hidden where decorative. Interactive elements have aria-labels. Room to improve: add more descriptive alt text to illustrative images if added later.',
  },
  {
    title: 'Page Speed',
    status: 'ready',
    detail: 'Static output (SSG). No JavaScript frameworks. Only inline scripts for calculators. Fonts loaded with preconnect + display=swap.',
  },
];

const schemaChecklist = [
  { page: 'Homepage', schema: 'WebSite + SearchAction', status: 'implemented' },
  { page: 'Every calculator', schema: 'WebApplication (EngineeringApplication)', status: 'implemented' },
  { page: 'FAQ sections', schema: 'FAQPage', status: 'implemented' },
  { page: 'Category pages', schema: 'WebSite', status: 'implemented' },
];
---

<Layout
  title="Search Console Readiness Checklist | Battery Calculators"
  description="Internal checklist for verifying SEO, indexing, structured data, and search console readiness before launch."
  schema="website"
  schemaName="Search Console Checklist"
  schemaDescription="Internal pre-launch SEO and search console readiness checklist."
>
  <Breadcrumb items={[{ label: 'Search Console Checklist' }]} />

  <div class="mb-12 border-b border-hairline pb-12">
    <span class="text-label-uppercase text-m-blue-light text-xs block mb-4">INTERNAL</span>
    <h1 class="text-display-md text-primary mb-4">Search Console Checklist</h1>
    <p class="text-body-md text-muted max-w-2xl font-light">
      Pre-launch verification checklist for indexing, structured data, and search engine readiness.
    </p>
  </div>

  <!-- SEO Fundamentals -->
  <section class="mb-16">
    <h2 class="text-title-lg text-primary mb-6 uppercase tracking-wider">SEO Fundamentals</h2>
    <div class="flex flex-col gap-4">
      {checklist.map((item) => (
        <CalculatorCard>
          <div class="flex items-start gap-4">
            <span class={`mt-1 inline-block w-3 h-3 flex-shrink-0 border ${
              item.status === 'ready'
                ? 'border-green-500 bg-green-500'
                : 'border-yellow-500 bg-yellow-500'
            }`}></span>
            <div class="flex-1">
              <h3 class="text-primary font-bold mb-1">{item.title}</h3>
              <p class="text-body-sm text-muted">{item.detail}</p>
            </div>
            <span class={`text-caption px-2 py-0.5 border ${
              item.status === 'ready'
                ? 'text-green-400 border-green-500'
                : 'text-yellow-400 border-yellow-500'
            }`}>
              {item.status.toUpperCase()}
            </span>
          </div>
        </CalculatorCard>
      ))}
    </div>
  </section>

  <MStripe />

  <!-- Structured Data Breakdown -->
  <section class="my-16">
    <h2 class="text-title-lg text-primary mb-6 uppercase tracking-wider">Structured Data by Page Type</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-left">
        <thead>
          <tr class="border-b border-hairline">
            <th class="py-3 px-4 text-label-uppercase text-xs text-primary">Page Type</th>
            <th class="py-3 px-4 text-label-uppercase text-xs text-primary">Schema Type</th>
            <th class="py-3 px-4 text-label-uppercase text-xs text-primary">Status</th>
          </tr>
        </thead>
        <tbody class="text-body-sm text-muted">
          {schemaChecklist.map((row) => (
            <tr class="border-b border-hairline">
              <td class="py-3 px-4 text-primary">{row.page}</td>
              <td class="py-3 px-4 font-mono text-xs">{row.schema}</td>
              <td class="py-3 px-4">
                <span class="text-green-400 border border-green-500 px-2 py-0.5 text-caption">
                  {row.status.toUpperCase()}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <MStripe />

  <!-- Post-Launch Actions -->
  <section class="my-16">
    <h2 class="text-title-lg text-primary mb-6 uppercase tracking-wider">Post-Launch Actions</h2>
    <div class="flex flex-col gap-4 text-body-sm text-muted">
      <CalculatorCard>
        <h3 class="text-primary font-bold mb-2">1. Submit Sitemap to Google Search Console</h3>
        <p>Navigate to Google Search Console → Sitemaps → Add <code class="font-mono text-primary">sitemap-index.xml</code></p>
      </CalculatorCard>
      <CalculatorCard>
        <h3 class="text-primary font-bold mb-2">2. Submit to Bing Webmaster Tools</h3>
        <p>Claim site in Bing Webmaster Tools and submit the sitemap URL.</p>
      </CalculatorCard>
      <CalculatorCard>
        <h3 class="text-primary font-bold mb-2">3. Request Indexing for Key Pages</h3>
        <p>Use Google Search Console URL Inspection to request indexing for homepage, /tools, and /learn.</p>
      </CalculatorCard>
      <CalculatorCard>
        <h3 class="text-primary font-bold mb-2">4. Monitor Coverage Reports</h3>
        <p>Check Search Console Coverage tab weekly for crawl errors, excluded pages, or structured data warnings.</p>
      </CalculatorCard>
      <CalculatorCard>
        <h3 class="text-primary font-bold mb-2">5. Set Up GA4 + Clarity</h3>
        <p>Create GA4 property and Clarity project. Set <code class="font-mono text-primary">PUBLIC_GA4_ID</code> and <code class="font-mono text-primary">PUBLIC_CLARITY_ID</code> env vars.</p>
      </CalculatorCard>
    </div>
  </section>
</Layout>
