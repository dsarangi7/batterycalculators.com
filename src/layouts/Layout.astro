---
import '../styles/global.css';
import Header from '../components/Header.astro';
import HeadSEO from '../components/HeadSEO.astro';
import Analytics from '../components/Analytics.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogType?: string;
  ogImage?: string;
  schema?: 'website' | 'webApplication' | 'faqPage' | 'collectionPage';
  schemaName?: string;
  schemaDescription?: string;
  schemaUrl?: string;
  faqItems?: Array<{ question: string; answer: string }>;
  breadcrumbs?: Array<{ label: string; href?: string }>;
}

const { 
  title = "Battery Calculators | High-Precision Battery Tools", 
  description = "Free online calculators for battery system sizing, runtime, C-rate, DC cable loss, voltage drop, BESS ROI, and state of health estimation.",
  canonical,
  ogType,
  ogImage,
  schema,
  schemaName,
  schemaDescription,
  schemaUrl,
  faqItems,
  breadcrumbs,
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Battery Calculators" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />

    <!-- FOUC prevention: apply saved theme before first paint -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem('beh-theme');
        if (t === 'light' || t === 'dark') {
          document.documentElement.setAttribute('data-theme', t);
        }
      })();
    </script>

    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <HeadSEO
      title={title}
      description={description}
      canonical={canonical}
      ogType={ogType}
      ogImage={ogImage}
      schema={schema}
      schemaName={schemaName}
      schemaDescription={schemaDescription}
      schemaUrl={schemaUrl}
      faqItems={faqItems}
      breadcrumbs={breadcrumbs}
    />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700&display=swap" rel="stylesheet" />

    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3614850858383686" crossorigin="anonymous"></script>

    <!-- Analytics (disabled until env vars set) -->
    <Analytics />
  </head>
  <body class="bg-canvas text-body min-h-screen flex flex-col font-body overflow-x-hidden w-full max-w-full">

    <Header />

    <!-- Main Content Area -->
    <main class="flex-grow w-full max-w-7xl mx-auto px-4 md:px-8 pt-6 pb-8 md:pt-8 md:pb-16">
      <slot />
    </main>

    <!-- Footer -->
<footer class="bg-canvas border-t border-hairline">
  <!-- M-Stripe -->
  <div class="h-[4px] w-full bg-gradient-to-r from-[#0066b1] via-[#1c69d4] to-[#e22718]" />

  <!-- Row 1: Brand + Statistics -->
  <div class="max-w-7xl mx-auto px-4 md:px-8 py-6 grid md:grid-cols-3 gap-6 items-center">
    <div class="col-span-2 flex flex-col gap-1">
      <h2 class="text-lg font-bold text-primary">Battery Calculators</h2>
      <p class="text-body-sm text-muted max-w-prose">
        Engineering-grade battery sizing, runtime, SOC, degradation, and energy storage tools for solar, marine, RV, EV, and BESS applications.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-2 text-center text-body-sm text-muted">
      <div class="flex flex-col">
        <span class="text-label-uppercase text-primary text-xs font-bold">Calculators</span>
        <span class="text-lg font-semibold text-primary">30</span>
      </div>
      <div class="flex flex-col">
        <span class="text-label-uppercase text-primary text-xs font-bold">Guides</span>
        <span class="text-lg font-semibold text-primary">94</span>
      </div>
      <div class="flex flex-col">
        <span class="text-label-uppercase text-primary text-xs font-bold">Categories</span>
        <span class="text-lg font-semibold text-primary">7</span>
      </div>
    </div>
  </div>

  <!-- Row 2: Navigation Columns -->
  <div class="max-w-7xl mx-auto px-4 md:px-8 py-6 grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 border-t border-hairline">
    <div class="flex flex-col gap-2">
      <span class="text-label-uppercase text-primary text-xs font-bold">Calculators</span>
      <ul class="flex flex-col gap-1 text-body-sm text-muted">
        <li><a href="/tools/runtime-calculator" class="hover:text-primary transition-colors">Runtime Calculator</a></li>
        <li><a href="/tools/battery-sizing-calculator" class="hover:text-primary transition-colors">Battery Sizing Calculator</a></li>
        <li><a href="/tools/solar-battery-sizing-calculator" class="hover:text-primary transition-colors">Solar Battery Sizing</a></li>
        <li><a href="/tools/battery-pack-calculator" class="hover:text-primary transition-colors">Battery Pack Calculator</a></li>
        <li><a href="/tools/soc-estimator" class="hover:text-primary transition-colors">SOC Estimator</a></li>
        <li><a href="/tools" class="hover:text-primary transition-colors">View All →</a></li>
      </ul>
    </div>
    <div class="flex flex-col gap-2">
      <span class="text-label-uppercase text-primary text-xs font-bold">Learning Center</span>
      <ul class="flex flex-col gap-1 text-body-sm text-muted">
        <li><a href="/learn" class="hover:text-primary transition-colors">Runtime Guides</a></li>
        <li><a href="/learn" class="hover:text-primary transition-colors">Sizing Guides</a></li>
        <li><a href="/learn" class="hover:text-primary transition-colors">SOC & SOH Guides</a></li>
        <li><a href="/learn" class="hover:text-primary transition-colors">BESS Guides</a></li>
        <li><a href="/learn" class="hover:text-primary transition-colors">Reference Charts</a></li>
        <li><a href="/learn" class="hover:text-primary transition-colors">View All →</a></li>
      </ul>
    </div>
    <div class="flex flex-col gap-2">
      <span class="text-label-uppercase text-primary text-xs font-bold">Categories</span>
      <ul class="flex flex-col gap-1 text-body-sm text-muted">
        <li><a href="/solar" class="hover:text-primary transition-colors">Solar</a></li>
        <li><a href="/home-backup" class="hover:text-primary transition-colors">Home Backup</a></li>
        <li><a href="/rv" class="hover:text-primary transition-colors">RV</a></li>
        <li><a href="/marine" class="hover:text-primary transition-colors">Marine</a></li>
        <li><a href="/ev" class="hover:text-primary transition-colors">EV</a></li>
        <li><a href="/bess" class="hover:text-primary transition-colors">BESS</a></li>
      </ul>
    </div>
    <div class="flex flex-col gap-2">
      <span class="text-label-uppercase text-primary text-xs font-bold">Company</span>
      <ul class="flex flex-col gap-1 text-body-sm text-muted">
        <li><a href="/about" class="hover:text-primary transition-colors">About</a></li>
        <li><a href="/contact" class="hover:text-primary transition-colors">Contact</a></li>
        <li><a href="/methodology" class="hover:text-primary transition-colors">Methodology</a></li>
        <li><a href="/privacy" class="hover:text-primary transition-colors">Privacy Policy</a></li>
        <li><a href="/terms" class="hover:text-primary transition-colors">Terms of Service</a></li>
        <li><a href="/disclaimer" class="hover:text-primary transition-colors">Disclaimer</a></li>
      </ul>
    </div>
  </div>

  <!-- Row 3: Search -->
  <div class="max-w-7xl mx-auto px-4 md:px-8 py-5 flex justify-center border-t border-hairline">
    <form action="/search" method="GET" class="relative w-full max-w-md">
      <input type="text" name="q" placeholder="Search calculators, guides, and reference charts..." class="w-full border border-hairline rounded-md py-2 pl-3 pr-10 text-body-sm bg-canvas text-muted focus:outline-none focus:border-primary" />
      <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 text-primary hover:text-primary/80 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="11" cy="11" r="8" stroke-width="2"/><line x1="21" y1="21" x2="16.65" y2="16.65" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
    </form>
  </div>

  <!-- Row 4: Reference Center -->
  <div class="max-w-7xl mx-auto px-4 md:px-8 py-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 border-t border-hairline">
    <span class="text-label-uppercase text-primary text-xs font-bold whitespace-nowrap">Battery Reference Center</span>
    <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-body-sm text-muted">
      <a href="/learn/lifepo4-voltage-chart" class="hover:text-primary transition-colors">Voltage Charts</a>
      <a href="/learn/lifepo4-soc-chart" class="hover:text-primary transition-colors">SOC Tables</a>
      <a href="/learn/battery-c-rate-reference" class="hover:text-primary transition-colors">C-Rate Reference</a>
      <a href="/learn/battery-sizing-reference" class="hover:text-primary transition-colors">DoD Charts</a>
      <a href="/resources" class="text-primary hover:text-muted transition-colors ml-2">Browse Reference Center →</a>
    </div>
  </div>

  <!-- Row 5: Bottom Bar -->
  <div class="border-t border-hairline py-4">
    <div class="max-w-7xl mx-auto px-4 md:px-8 flex flex-col md:flex-row items-center justify-between gap-2 text-caption text-muted">
      <p class="m-0">© {new Date().getFullYear()} Battery Calculators. Independent open utilities.</p>
      <div class="flex items-center gap-2">
        <a href="/sitemap-index.xml" class="hover:text-primary transition-colors">Sitemap</a>
        <span class="text-hairline">|</span>
        <a href="/privacy" class="hover:text-primary transition-colors">Privacy</a>
        <span class="text-hairline">|</span>
        <a href="/terms" class="hover:text-primary transition-colors">Terms</a>
        <span class="text-hairline">|</span>
        <a href="/contact" class="hover:text-primary transition-colors">Contact</a>
      </div>
    </div>
  </div>
</footer>
  </body>
</html>
