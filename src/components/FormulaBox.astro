<!-- src/components/FormulaBox.astro -->
---
export interface Props {
  title?: string;
}

const { title = 'Mathematical Formulas' } = Astro.props as Props;
---

<div class="min-w-0">
  <h2 class="text-title-lg text-primary uppercase mb-6 tracking-wider">{title}</h2>
  <div class="flex flex-col gap-4 text-body-sm text-muted">
    <slot />
  </div>
</div>
