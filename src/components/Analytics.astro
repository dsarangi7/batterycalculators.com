---
/**
 * Analytics Component
 *
 * Injects GA4 and/or Microsoft Clarity scripts when env vars are set.
 * Safe to include on every page — no-ops when IDs are absent.
 *
 * NOTE: <script is:inline> disables Astro template processing in script
 * content, so `{GA4_ID}` would be output as a literal string. We use
 * set:html on a Fragment to interpolate IDs correctly at build time.
 */

const GA4_ID = (import.meta.env.PUBLIC_GA4_ID as string | undefined) ?? 'G-D40HJV44WS';
const CLARITY_ID = import.meta.env.PUBLIC_CLARITY_ID as string | undefined;

const gaScript = GA4_ID
  ? `<script async src="https://www.googletagmanager.com/gtag/js?id=${GA4_ID}"></script>
<script>
window.dataLayer = window.dataLayer || [];
function gtag(){window.dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', '${GA4_ID}', { send_page_view: true });
</script>`
  : '';

const clarityScript = CLARITY_ID
  ? `<script>
(function(c,l,a,r,i,t,y){
  c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
  t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
  y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
})(window, document, "clarity", "script", "${CLARITY_ID}");
</script>`
  : '';
---

<Fragment set:html={gaScript} />
<Fragment set:html={clarityScript} />
