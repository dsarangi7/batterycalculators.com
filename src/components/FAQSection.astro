<!-- src/components/FAQSection.astro -->
---
export interface FAQItem {
  question: string;
  answer: string;
}

export interface Props {
  title?: string;
  items: FAQItem[];
}

const { title = 'Frequently Asked Questions', items } = Astro.props as Props;
---

<section class="mb-16 border-t border-hairline pt-12">
  <h2 class="text-display-sm text-primary mb-8 text-center md:text-left">{title}</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-body-sm text-muted">
    {items.map((item) => (
      <div>
        <h4 class="text-primary font-bold mb-2">{item.question}</h4>
        <p>{item.answer}</p>
      </div>
    ))}
  </div>
</section>
