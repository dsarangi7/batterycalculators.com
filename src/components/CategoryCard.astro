---
export interface Props {
  href: string;
  title: string;
  description: string;
  calculatorCount: number;
}
const { href, title, description, calculatorCount } = Astro.props as Props;

const schematics: Record<string, string> = {
  Solar: '<svg viewBox="0 0 100 100" class="w-full h-full text-primary" fill="none" stroke="currentColor" stroke-width="0.5"><rect x="20" y="30" width="60" height="30" opacity="0.06"/><line x1="20" y1="30" x2="80" y2="60" opacity="0.06"/></svg>',
  "Home Backup": '<svg viewBox="0 0 100 100" class="w-full h-full text-primary" fill="none" stroke="currentColor" stroke-width="0.5"><rect x="30" y="20" width="40" height="20" opacity="0.06"/><line x1="50" y1="40" x2="50" y2="70" opacity="0.06"/><rect x="40" y="70" width="20" height="10" opacity="0.06"/></svg>',
  RV: '<svg viewBox="0 0 100 100" class="w-full h-full text-primary" fill="none" stroke="currentColor" stroke-width="0.5"><rect x="20" y="30" width="60" height="40" opacity="0.06"/><line x1="30" y1="30" x2="30" y2="70" opacity="0.06"/><line x1="70" y1="30" x2="70" y2="70" opacity="0.06"/></svg>',
  Marine: '<svg viewBox="0 0 100 100" class="w-full h-full text-primary" fill="none" stroke="currentColor" stroke-width="0.5"><path d="M20 70 L50 30 L80 70" opacity="0.06"/><line x1="50" y1="30" x2="50" y2="20" opacity="0.06"/></svg>',
  EV: '<svg viewBox="0 0 100 100" class="w-full h-full text-primary" fill="none" stroke="currentColor" stroke-width="0.5"><rect x="30" y="20" width="40" height="60" opacity="0.06"/><line x1="30" y1="40" x2="70" y2="40" opacity="0.06"/><line x1="30" y1="60" x2="70" y2="60" opacity="0.06"/></svg>',
  BESS: '<svg viewBox="0 0 100 100" class="w-full h-full text-primary" fill="none" stroke="currentColor" stroke-width="0.5"><rect x="25" y="30" width="15" height="40" opacity="0.06"/><rect x="45" y="30" width="15" height="40" opacity="0.06"/><rect x="65" y="30" width="15" height="40" opacity="0.06"/></svg>',
  Engineering: '<svg viewBox="0 0 100 100" class="w-full h-full text-primary" fill="none" stroke="currentColor" stroke-width="0.5"><line x1="20" y1="70" x2="40" y2="30" opacity="0.06"/><line x1="40" y1="30" x2="60" y2="70" opacity="0.06"/><line x1="60" y1="70" x2="80" y2="30" opacity="0.06"/></svg>'
};

const schematicHtml = schematics[title] ?? '';
---
<a href={href} class="block group">
  <div class="bg-surface-card border border-hairline p-5 md:p-7 h-full flex flex-col justify-between hover:border-primary transition-colors relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <Fragment set:html={schematicHtml} />
    </div>

    <div class="relative z-10">
      <h3 class="text-title-lg text-primary mb-2 group-hover:text-m-blue-light transition-colors">
        {title}
      </h3>
      <p class="text-body-sm text-muted mb-4">{description}</p>
    </div>

    <div class="relative z-10 flex items-center justify-between">
      <span class="text-label-uppercase text-muted text-[10px]">
        {calculatorCount} Calculator{calculatorCount !== 1 ? "s" : ""}
      </span>
      <span class="text-label-uppercase text-primary text-[10px] group-hover:text-m-blue-light transition-colors inline-flex items-center gap-1">
        EXPLORE
        <span class="group-hover:translate-x-1 transition-transform inline-block">→</span>
      </span>
    </div>
  </div>
</a>
