---
export interface Props {
  title: string;
  description?: string;
  xLabel: string;
  yLabel: string;
  chartId: string;
  class?: string;
}

const { title, description, xLabel, yLabel, chartId, class: className = '' } = Astro.props as Props;
---

<div class={`mt-4 ${className}`}>
  <span class="text-label-uppercase text-primary text-[10px] block mb-1">{title}</span>
  {description && (
    <p class="text-caption text-muted mb-2">{description}</p>
  )}
  <svg
    id={chartId}
    viewBox="0 0 320 160"
    height="160"
    class="w-full block"
    preserveAspectRatio="xMidYMid meet"
    role="img"
    aria-label={`${title}: ${description || `${yLabel} versus ${xLabel}`}`}
  ></svg>
</div>
