---
import CalculatorCard from './CalculatorCard.astro';

export interface Tool {
  name: string;
  href: string;
  description: string;
  available: boolean;
}

export interface Props {
  tools: Tool[];
}

const { tools } = Astro.props as Props;
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  {tools.map((tool) => (
    tool.available ? (
      <a href={tool.href} class="block group">
        <CalculatorCard class="h-full flex flex-col justify-between">
          <div>
            <h3 class="text-title-lg text-primary mb-2 group-hover:text-m-blue-light transition-colors">{tool.name}</h3>
            <p class="text-body-sm text-muted mb-6">{tool.description}</p>
          </div>
          <span class="btn-primary-outline text-xs text-center py-3 w-full">Open Calculator</span>
        </CalculatorCard>
      </a>
    ) : (
      <div class="bg-surface-card border border-hairline p-6 opacity-60">
        <div class="flex items-center justify-between mb-2">
          <h3 class="text-title-lg text-primary">{tool.name}</h3>
          <span class="text-[10px] text-muted border border-hairline px-2 py-0.5 uppercase tracking-wider">Coming Soon</span>
        </div>
        <p class="text-body-sm text-muted">{tool.description}</p>
      </div>
    )
  ))}
</div>
