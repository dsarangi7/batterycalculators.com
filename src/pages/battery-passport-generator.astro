---
import Layout from '../layouts/Layout.astro';
import CalculatorCard from '../components/CalculatorCard.astro';
import InputField from '../components/InputField.astro';
import FAQSection from '../components/FAQSection.astro';
import RelatedTools from '../components/RelatedTools.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

// Dropdown options
const applicationOptions = [
  { label: "Stationary ESS", value: "Stationary ESS" },
  { label: "Marine ESS", value: "Marine ESS" },
  { label: "EV (Electric Vehicle)", value: "EV" },
  { label: "Industrial Pack", value: "Industrial" },
  { label: "UPS / Backup Power", value: "UPS" },
  { label: "Second-life Storage", value: "Second-life" },
  { label: "Other Application", value: "Other" }
];

const chemistryOptions = [
  { label: "LFP (Lithium Iron Phosphate / LiFePO4)", value: "LFP / LiFePO4" },
  { label: "NMC (Nickel Manganese Cobalt)", value: "NMC" },
  { label: "NCA (Nickel Cobalt Aluminum)", value: "NCA" },
  { label: "LTO (Lithium Titanate)", value: "LTO" },
  { label: "Lead-Acid (Deep Cycle)", value: "Lead-acid" },
  { label: "Sodium-Ion", value: "Sodium-ion" },
  { label: "Other Chemistry", value: "Other" }
];

const carbonUnitOptions = [
  { label: "kg CO2e / kWh", value: "kg CO2e/kWh" },
  { label: "kg CO2e total", value: "kg CO2e total" },
  { label: "Unknown / Undeclared", value: "Unknown" }
];

const secondLifeOptions = [
  { label: "High suitability (SOH >= 80%, low cycle count)", value: "High" },
  { label: "Medium suitability (SOH 70-79%, moderate stress)", value: "Medium" },
  { label: "Low suitability (SOH < 70% or safety events logged)", value: "Low" },
  { label: "Unknown / Untested", value: "Unknown" }
];

// FAQ list for FAQPage schema and display
const faqItems = [
  {
    question: "What is a battery passport?",
    answer: "A battery passport is a structured digital record that stores and shares key information about a battery's lifecycle. It tracks details such as manufacturing origin, material composition, carbon footprint, performance history, State of Health (SOH), and recycling instructions to promote safety, transparency, and circular economy reuse."
  },
  {
    question: "Who needs a battery passport?",
    answer: "Under regulations like the EU Battery Regulation, battery passports are mandatory for industrial batteries (above 2 kWh), electric vehicle (EV) batteries, and large Light Means of Transport (LMT) batteries. Target users include manufacturers, OEMs, battery labs, ESS developers, and recycling teams."
  },
  {
    question: "Is this a certified EU Battery Passport?",
    answer: "No. This tool generates a Battery Passport readiness report for engineering and planning purposes. It is not a legal compliance certification. Official compliance requires independent verification, specific data architectures (like decentralized registries), secure digital identifiers, and audited carbon footprint models."
  },
  {
    question: "Can I use this report as an official Battery Passport?",
    answer: "No. This report is a readiness and data-gap assessment for engineering and planning. An official Battery Passport may require verified data, approved data models, digital identifiers, QR infrastructure, supplier declarations, carbon footprint methodology, authenticated records, and regulatory review."
  },
  {
    question: "What battery data is needed for a battery passport?",
    answer: "Required data is split into five main groups: 1) Battery Identity (serial numbers, chemistry, manufacturer), 2) Performance & Durability (SOH, round-trip efficiency, cycles), 3) Lifecycle & Operational data (temperatures, safety events), 4) Sustainability (carbon footprint, raw materials, recycled content), and 5) Documentation (declarations of conformity, safety manuals)."
  },
  {
    question: "Does a battery passport include SOH data?",
    answer: "Yes. State of Health (SOH) is a critical runtime parameter. It must be updated periodically during the battery's active life to inform operators, second-life evaluators, and recyclers of the remaining capability and capacity fade of the system."
  },
  {
    question: "What is battery passport readiness?",
    answer: "Battery passport readiness measures how complete and accurate a manufacturer's or operator's data is relative to regulatory requirements. A high readiness score indicates that all identity, performance, carbon footprint, and safety documents are compiled and ready for formal registry submission."
  },
  {
    question: "Can this tool create a QR code?",
    answer: "This tool generates a visual QR code placeholder in the preview card and printed report. It does not generate or host a live, persistent database URL. In production systems, the QR code links to a secure digital product passport registry page."
  },
  {
    question: "Can I use this for marine ESS batteries?",
    answer: "Yes. Marine energy storage system (ESS) teams can use this tool to compile baseline data, track operational events, assess SOH, and verify if their documentation meets standard industrial battery regulations."
  },
  {
    question: "What is missing from a complete battery passport?",
    answer: "A production-ready passport requires: secure distributed ledger integration (or authorized API registries), verified life cycle carbon footprint declarations (ISO 14067/14044), official supply chain chain-of-custody audits, and a real-time BMS connection to push telemetry data."
  },
  {
    question: "When does the EU Battery Passport requirement start?",
    answer: "The EU Battery Passport requirement is scheduled to take effect in February 2027. Industrial and EV batteries placed on the EU market must carry a visible QR code linked to their digital passport registry entry by this deadline."
  },
  {
    question: "How much does a Battery Passport cost?",
    answer: "Cost varies by implementation scope. For internal readiness assessments, free tools like this can help structure data. Formal compliance typically involves software platforms, audits, and registry fees. Budget for data management infrastructure, third-party verification, and ongoing maintenance when planning a full Battery Passport program."
  },
  {
    question: "Can I prepare Battery Passport data without a paid provider?",
    answer: "Yes, you can start by organizing existing data using spreadsheets or free tools. However, formal compliance requires secure digital identifiers, verified carbon footprint calculations, and registry integration. Most organizations use specialized platforms for the final implementation, but early data preparation can be done independently."
  },
  {
    question: "What is the difference between a Battery Passport and a battery datasheet?",
    answer: "A battery datasheet provides static technical specifications from the manufacturer. A Battery Passport is a dynamic digital record that tracks the battery's entire lifecycle, including real-time performance data, maintenance history, carbon footprint, and recycling instructions. Passports update over time, while datasheets remain fixed."
  },
  {
    question: "Does a Battery Passport need carbon footprint data?",
    answer: "Yes, carbon footprint data is a core requirement under regulations like the EU Battery Regulation. You need to declare the product carbon footprint (PCF) using recognized methodologies like ISO 14067 or PEF guidelines. This includes lifecycle emissions from raw material extraction through manufacturing, use, and end-of-life processing."
  }
];

const relatedTools = [
  { href: "/tools/battery-degradation-estimator/", title: "Degradation Estimator", description: "Calculate capacity fade and SOH over time." },
  { href: "/tools/runtime-calculator/", title: "Runtime Calculator", description: "Estimate runtime from capacity, load, and efficiency." },
  { href: "/tools/battery-sizing-calculator/", title: "Battery Sizing Calculator", description: "Size storage packs based on electrical load profiles." },
  { href: "/tools/soc-estimator/", title: "SOC Estimator", description: "Estimate State of Charge from voltage or current integration." }
];

const breadcrumbs = [
  { label: 'Tools', href: '/tools' },
  { label: 'Battery Passport Generator' }
];
---

<Layout
  title="Battery Passport Generator | Digital Battery Passport Readiness Tool"
  description="Create a battery passport readiness report with lifecycle data, SOH, performance, durability, traceability, carbon footprint, and compliance checklist fields."
  schema="webApplication"
  schemaName="Battery Passport Generator"
  schemaDescription="A structured battery passport readiness assessment and engineering report generator."
  breadcrumbs={breadcrumbs}
  faqItems={faqItems}
>
  <div class="mb-8 print:hidden">
    <Breadcrumb items={breadcrumbs} />
    <span class="text-label-uppercase text-m-blue-light text-[11px] block mt-4 mb-2">ENGINEERING PLANNING UTILITY</span>
    <h1 class="text-display-md text-primary leading-tight mb-3">Battery Passport Generator</h1>
    <p class="text-body-md text-body font-light max-w-4xl">
      Create a structured battery lifecycle and compliance-readiness report using battery identity, SOH, performance, durability, traceability, carbon footprint, and documentation data.
    </p>
  </div>

  <!-- Hero Highlight / Mockup Area -->
  <section id="hero-section" class="bg-surface-card border border-hairline p-6 md:p-8 mb-12 print:hidden relative overflow-hidden">
    <!-- Glowing background accent -->
    <div class="absolute -right-24 -top-24 w-72 h-72 rounded-full bg-m-blue-dark/15 blur-[80px] pointer-events-none"></div>
    <div class="absolute -left-24 -bottom-24 w-72 h-72 rounded-full bg-m-red/10 blur-[80px] pointer-events-none"></div>

    <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-8 items-center relative z-10">
      <div>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-3">Compliance &amp; Lifecycle Planning</h2>
        <p class="text-body-sm text-body leading-relaxed mb-6">
          Regulations like the upcoming EU Battery Regulation and global mineral traceability initiatives require industrial battery systems to document core technical, safety, and carbon parameters. Use this engineering planning tool to self-assess your dataset, measure your compliance readiness level, and export a formatted lifecycle readiness report.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#generator-tool" class="btn-primary text-xs h-11 inline-flex items-center">
            Start Battery Passport Report
          </a>
          <a href="#data-fields" class="btn-primary-outline text-xs h-11 inline-flex items-center">
            View Required Data Fields
          </a>
        </div>
      </div>

      <!-- Simulated Preview Card -->
      <div class="bg-canvas border border-hairline p-6 relative rounded-none flex flex-col justify-between h-full min-h-[200px]">
        <div class="absolute top-0 left-0 w-full h-[4px] bg-gradient-to-r from-m-blue-light via-m-blue-dark to-m-red"></div>
        <div>
          <div class="flex justify-between items-start mb-4">
            <div>
              <span class="text-[9px] text-muted tracking-wider uppercase block">PASSPORT INITIAL PREVIEW</span>
              <span class="text-sm font-mono text-primary font-bold">BP-2026-X9B2</span>
            </div>
            <span class="text-[9px] font-bold border border-m-blue-light text-m-blue-light px-2 py-0.5 uppercase tracking-wider">Ready for Review</span>
          </div>

          <div class="grid grid-cols-2 gap-y-3 gap-x-2 border-t border-hairline pt-3 mb-4 text-xs font-light text-body">
            <div>
              <span class="text-[10px] text-muted block">Battery Model:</span>
              <span class="text-primary font-medium">LiFePO4 Marine ESS</span>
            </div>
            <div>
              <span class="text-[10px] text-muted block">Chemistry:</span>
              <span class="text-primary font-medium">LFP / LiFePO4</span>
            </div>
            <div>
              <span class="text-[10px] text-muted block">Nominal Voltage:</span>
              <span class="text-primary font-medium">51.2 V</span>
            </div>
            <div>
              <span class="text-[10px] text-muted block">Nominal Capacity:</span>
              <span class="text-primary font-medium">200 Ah</span>
            </div>
          </div>
        </div>

        <div class="flex justify-between items-end border-t border-hairline pt-3">
          <div>
            <span class="text-[10px] text-muted block">Data Completeness:</span>
            <div class="flex items-center gap-2">
              <div class="w-24 h-2 bg-surface-card rounded-none overflow-hidden">
                <div class="bg-m-blue-light h-full" style="width: 82%"></div>
              </div>
              <span class="text-xs font-mono text-primary font-bold">82%</span>
            </div>
          </div>
          <div class="w-10 h-10 border border-hairline flex items-center justify-center p-0.5 bg-white shrink-0">
            <!-- QR code visual placeholder -->
            <div class="w-full h-full bg-canvas grid grid-cols-3 gap-0.5 p-0.5">
              <div class="bg-primary"></div><div class="bg-primary"></div><div class="bg-canvas"></div>
              <div class="bg-primary"></div><div class="bg-canvas"></div><div class="bg-primary"></div>
              <div class="bg-canvas"></div><div class="bg-primary"></div><div class="bg-primary"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Interactive Generator Section -->
  <section id="generator-tool" class="mb-16 scroll-mt-6">
    <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-8">
      
      <!-- Input Form Column -->
      <div id="form-column" class="flex flex-col gap-6 print:hidden">
        
        <!-- SECTION A: Battery Identity -->
        <CalculatorCard>
          <div class="flex items-center gap-3 mb-6">
            <span class="w-6 h-6 border border-m-blue-light text-m-blue-light flex items-center justify-center font-mono text-xs font-bold">A</span>
            <h3 class="text-title-lg text-primary uppercase tracking-wider">Battery Identity</h3>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <InputField id="identity-name" label="Battery Pack/System Name" type="text" value="" placeholder="e.g. Navis Marine LFP-10" />
            <InputField id="identity-manufacturer" label="Manufacturer / Organization" type="text" value="" placeholder="e.g. Apex Power Systems" />
            <InputField id="identity-application" label="Application Profile" type="select" options={applicationOptions} value="Stationary ESS" />
            <InputField id="identity-category" label="Battery Category" type="text" value="" placeholder="e.g. Industrial / ESS Pack" />
            <InputField id="identity-chemistry" label="Cell Chemistry" type="select" options={chemistryOptions} value="LFP / LiFePO4" />
            <InputField id="identity-nominal-voltage" label="Nominal Voltage (V)" type="number" value="" placeholder="e.g. 51.2" min={0.1} step="any" />
            <InputField id="identity-nominal-capacity" label="Nominal Capacity (Ah)" type="number" value="" placeholder="e.g. 200" min={0.1} step="any" />
            <div class="flex flex-col gap-2 w-full">
              <label for="identity-energy-capacity" class="text-label-uppercase text-xs text-primary flex justify-between">
                <span>Energy Capacity (kWh)</span>
                <span id="auto-calc-indicator" class="text-[9px] text-m-blue-light lowercase tracking-normal hidden">Auto-calculated</span>
              </label>
              <div class="relative flex items-center">
                <input id="identity-energy-capacity" type="number" class="text-input w-full" placeholder="e.g. 10.24" min={0.01} step="any" />
                <span class="absolute right-3 text-caption text-muted">kWh</span>
              </div>
              <p class="text-caption text-muted">Leave empty to auto-calculate from Volts × Ah.</p>
            </div>
            <InputField id="identity-manufacturing-date" label="Manufacturing Date" type="text" value="" placeholder="YYYY-MM-DD" />
            <InputField id="identity-country" label="Country of Manufacture" type="text" value="" placeholder="e.g. Germany" />
            <InputField id="identity-serial-number" label="Serial Number / Pack ID" type="text" value="" placeholder="e.g. SN-LFP4-883719" />
          </div>
        </CalculatorCard>

        <!-- SECTION B: Performance and Durability -->
        <CalculatorCard>
          <div class="flex items-center gap-3 mb-6">
            <span class="w-6 h-6 border border-m-blue-dark text-m-blue-dark flex items-center justify-center font-mono text-xs font-bold">B</span>
            <h3 class="text-title-lg text-primary uppercase tracking-wider">Performance &amp; Durability</h3>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <InputField id="perf-rated-cycles" label="Rated Cycle Life (cycles)" type="number" value="" placeholder="e.g. 6000" min={1} />
            <InputField id="perf-current-cycles" label="Current Cycle Count" type="number" value="" placeholder="e.g. 120" min={0} />
            <InputField id="perf-soh" label="State of Health (SOH %)" type="number" value="" placeholder="e.g. 98" min={0} max={120} />
            <InputField id="perf-efficiency" label="Round-Trip Efficiency (%)" type="number" value="" placeholder="e.g. 95" min={0} max={100} />
            <InputField id="perf-temp-min" label="Min Operating Temp (°C)" type="number" value="" placeholder="e.g. -10" step="any" />
            <InputField id="perf-temp-max" label="Max Operating Temp (°C)" type="number" value="" placeholder="e.g. 45" step="any" />
            <InputField id="perf-dod" label="Recommended DoD (%)" type="number" value="" placeholder="e.g. 80" min={0} max={100} />
            <InputField id="perf-warranty" label="Warranty Period (Years)" type="number" value="" placeholder="e.g. 10" min={0} />
            <InputField id="perf-service-life" label="Expected Service Life (Years)" type="number" value="" placeholder="e.g. 15" min={0} />
          </div>
        </CalculatorCard>

        <!-- SECTION C: Lifecycle and Operational Data -->
        <CalculatorCard>
          <div class="flex items-center gap-3 mb-6">
            <span class="w-6 h-6 border border-m-red text-m-red flex items-center justify-center font-mono text-xs font-bold">C</span>
            <h3 class="text-title-lg text-primary uppercase tracking-wider">Lifecycle &amp; Operational Data</h3>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <InputField id="life-commissioning-date" label="Commissioning Date" type="text" value="" placeholder="YYYY-MM-DD" />
            <InputField id="life-profile" label="Operational Profile" type="text" value="" placeholder="e.g. Solar Peak Shaving" />
            <InputField id="life-average-c-rate" label="Average C-Rate" type="number" value="" placeholder="e.g. 0.5" min={0} step="any" />
            <InputField id="life-max-discharge" label="Max Discharge Current (A)" type="number" value="" placeholder="e.g. 200" min={0} step="any" />
            <InputField id="life-max-charge" label="Max Charge Current (A)" type="number" value="" placeholder="e.g. 100" min={0} step="any" />
            <InputField id="life-average-temp" label="Average Operating Temp (°C)" type="number" value="" placeholder="e.g. 23" step="any" />
            <InputField id="life-thermal-events" label="Thermal Events Observed" type="number" value="" placeholder="e.g. 0" min={0} />
            <InputField id="life-safety-incidents" label="Safety Incidents Observed" type="number" value="" placeholder="e.g. 0" min={0} />
            <InputField id="life-maintenance-status" label="Maintenance Status" type="text" value="" placeholder="e.g. Nominal" />
          </div>
        </CalculatorCard>

        <!-- SECTION D: Sustainability and Traceability -->
        <CalculatorCard>
          <div class="flex items-center gap-3 mb-6">
            <span class="w-6 h-6 border border-hairline text-muted flex items-center justify-center font-mono text-xs font-bold">D</span>
            <h3 class="text-title-lg text-primary uppercase tracking-wider">Sustainability &amp; Traceability</h3>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <InputField id="sust-carbon-value" label="Carbon Footprint Value" type="number" value="" placeholder="e.g. 68" min={0} step="any" />
            <InputField id="sust-carbon-unit" label="Carbon Footprint Unit" type="select" options={carbonUnitOptions} value="kg CO2e/kWh" />
            <InputField id="sust-carbon-method" label="LCA Methodology Standard" type="text" value="" placeholder="e.g. ISO 14067" />
            
            <InputField id="sust-recycled" label="Recycled Content Declared?" type="select" options={[{label: "Undeclared", value: ""}, {label: "Yes", value: "yes"}, {label: "No", value: "no"}]} value="" />
            <InputField id="sust-critical-materials" label="Critical Materials Declared?" type="select" options={[{label: "Undeclared", value: ""}, {label: "Yes", value: "yes"}, {label: "No", value: "no"}]} value="" />
            <InputField id="sust-traceability" label="Supplier Traceability Available?" type="select" options={[{label: "Undeclared", value: ""}, {label: "Yes", value: "yes"}, {label: "No", value: "no"}]} value="" />
            <InputField id="sust-recycling-instructions" label="Recycling Instructions Declared?" type="select" options={[{label: "Undeclared", value: ""}, {label: "Yes", value: "yes"}, {label: "No", value: "no"}]} value="" />
            
            <InputField id="sust-second-life" label="Second-Life Suitability Assessment" type="select" options={secondLifeOptions} value="Unknown" />
          </div>
        </CalculatorCard>

        <!-- SECTION E: Documentation Checklist -->
        <CalculatorCard>
          <div class="flex items-center gap-3 mb-6">
            <span class="w-6 h-6 border border-hairline text-muted flex items-center justify-center font-mono text-xs font-bold">E</span>
            <h3 class="text-title-lg text-primary uppercase tracking-wider">Documentation Checklist</h3>
          </div>
          <p class="text-caption text-muted mb-4">Check all documentation files compiled for this battery system:</p>
          <div class="flex flex-col gap-3">
            {[
              { id: "doc-datasheet", label: "Technical datasheet compiled" },
              { id: "doc-conformity", label: "CE / UL Declaration of Conformity signed" },
              { id: "doc-safety-manual", label: "Operator safety manual published" },
              { id: "doc-transport", label: "UN 38.3 transport safety certification filed" },
              { id: "doc-bms", label: "BMS firmware communication protocol / telemetry export mapped" },
              { id: "doc-carbon-decl", label: "Product Carbon Footprint (PCF) declaration certified" },
              { id: "doc-material", label: "Detailed material composition & critical raw materials inventory" },
              { id: "doc-recycling", label: "End-of-life recycling and processing instructions" }
            ].map(doc => (
              <label class="flex items-start gap-3 text-body-sm text-body cursor-pointer select-none">
                <input id={doc.id} type="checkbox" class="w-4 h-4 border border-hairline text-primary focus:ring-0 focus:outline-none accent-m-blue-light mt-0.5 rounded-none" />
                <span>{doc.label}</span>
              </label>
            ))}
          </div>
        </CalculatorCard>

      </div>

      <!-- Right Column: Live Assessment Report & Preview -->
      <div id="preview-column" class="lg:sticky lg:top-8 h-fit flex flex-col gap-6 print:hidden">
        
        <!-- Live Preview Card -->
        <CalculatorCard class="border-m-blue-light relative bg-surface-card overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-[4px] bg-gradient-to-r from-m-blue-light via-m-blue-dark to-m-red"></div>

          <div class="flex justify-between items-start mb-6">
            <div>
              <span class="text-[10px] text-muted tracking-wider uppercase block">BATTERY LIFECYCLE PASSPORT ID</span>
              <span id="out-passport-id" class="text-xl font-mono text-primary font-bold">BP-2026-PEND</span>
            </div>
            <div>
              <span class="text-[10px] text-muted tracking-wider uppercase block text-right">PASSPORT STATUS</span>
              <span id="out-status" class="text-[10px] font-bold border border-m-red text-m-red px-2.5 py-0.5 uppercase tracking-wider inline-block mt-1">Draft</span>
            </div>
          </div>

          <!-- Progress / Score Rings -->
          <div class="grid grid-cols-2 gap-4 mb-8">
            <div class="bg-surface-soft border border-hairline p-4 text-center">
              <span class="text-[10px] text-muted block uppercase tracking-wider mb-1">Completeness</span>
              <span id="out-completeness" class="text-3xl font-mono text-primary font-bold">0%</span>
              <div class="w-full bg-canvas h-1.5 mt-2 overflow-hidden rounded-none">
                <div id="out-completeness-bar" class="bg-m-red h-full transition-all duration-300" style="width: 0%"></div>
              </div>
            </div>

            <div class="bg-surface-soft border border-hairline p-4 text-center">
              <span class="text-[10px] text-muted block uppercase tracking-wider mb-1">Readiness Tier</span>
              <span id="out-readiness" class="text-xl text-m-red font-bold uppercase tracking-wider block mt-1.5">Low</span>
              <span class="text-[9px] text-muted block mt-1">Readiness Alignment</span>
            </div>
          </div>

          <!-- Technical Metrics Summary Card -->
          <div class="bg-surface-soft border border-hairline p-4 mb-6">
            <h4 class="text-label-uppercase text-xs text-primary mb-3">Battery Specifications Summary</h4>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-y-3 gap-x-2 text-xs font-light text-body">
              <div>
                <span class="text-[10px] text-muted block">System Name:</span>
                <span id="sum-name" class="text-primary font-medium truncate block max-w-full">Not set</span>
              </div>
              <div>
                <span class="text-[10px] text-muted block">Chemistry:</span>
                <span id="sum-chemistry" class="text-primary font-medium">Not set</span>
              </div>
              <div>
                <span class="text-[10px] text-muted block">Energy Capacity:</span>
                <span id="sum-energy" class="text-primary font-medium">Not set</span>
              </div>
              <div>
                <span class="text-[10px] text-muted block">Nominal Voltage &amp; Ah:</span>
                <span id="sum-volts-ah" class="text-primary font-medium">Not set</span>
              </div>
              <div>
                <span class="text-[10px] text-muted block">Health Status (SOH):</span>
                <span id="sum-health" class="text-primary font-medium">Not set</span>
              </div>
              <div>
                <span class="text-[10px] text-muted block">Lifecycle Stage:</span>
                <span id="sum-stage" class="text-primary font-medium">Not set</span>
              </div>
            </div>
          </div>

          <!-- Critical Gaps / Warnings -->
          <div id="preview-warnings-container" class="mb-6 hidden">
