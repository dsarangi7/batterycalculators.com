  </div>

  <!-- Engineering Disclaimer at page footer -->
  <section class="bg-surface-soft border border-hairline p-6 text-caption text-muted mb-8 print:hidden">
    <span class="text-primary font-bold text-[10px] tracking-wider uppercase border border-hairline px-1.5 py-0.5 mr-2 inline-block mb-3">
      Engineering Disclaimer
    </span>
    This tool is designed to support structured data collection and self-auditing. The outputs do not replace qualified legal counsel, formal life-cycle carbon calculations, or regulatory audits. Always coordinate with compliance authorities.
  </section>

  <!-- Script for client-side interactivity -->
  <script>
    import { 
      calculateEnergyCapacity,
      calculateDataCompleteness,
      classifyBatteryHealth,
      estimateLifecycleStage,
      generateMissingFieldsList,
      calculateComplianceReadiness,
      generateMissingFieldWarnings,
      generateRecommendations,
      generatePassportId
    } from '../utils/batteryPassport';

    // Form Inputs
    const nameInput = document.getElementById('identity-name') as HTMLInputElement;
    const manufacturerInput = document.getElementById('identity-manufacturer') as HTMLInputElement;
    const applicationInput = document.getElementById('identity-application') as HTMLSelectElement;
    const categoryInput = document.getElementById('identity-category') as HTMLInputElement;
    const chemistryInput = document.getElementById('identity-chemistry') as HTMLSelectElement;
    const nominalVoltageInput = document.getElementById('identity-nominal-voltage') as HTMLInputElement;
    const nominalCapacityInput = document.getElementById('identity-nominal-capacity') as HTMLInputElement;
    const energyCapacityInput = document.getElementById('identity-energy-capacity') as HTMLInputElement;
    const manufacturingDateInput = document.getElementById('identity-manufacturing-date') as HTMLInputElement;
    const countryInput = document.getElementById('identity-country') as HTMLInputElement;
    const serialNumberInput = document.getElementById('identity-serial-number') as HTMLInputElement;

    const ratedCyclesInput = document.getElementById('perf-rated-cycles') as HTMLInputElement;
    const currentCyclesInput = document.getElementById('perf-current-cycles') as HTMLInputElement;
    const sohInput = document.getElementById('perf-soh') as HTMLInputElement;
    const efficiencyInput = document.getElementById('perf-efficiency') as HTMLInputElement;
    const tempMinInput = document.getElementById('perf-temp-min') as HTMLInputElement;
    const tempMaxInput = document.getElementById('perf-temp-max') as HTMLInputElement;
    const dodInput = document.getElementById('perf-dod') as HTMLInputElement;
    const warrantyInput = document.getElementById('perf-warranty') as HTMLInputElement;
    const serviceLifeInput = document.getElementById('perf-service-life') as HTMLInputElement;

    const commissioningDateInput = document.getElementById('life-commissioning-date') as HTMLInputElement;
    const profileInput = document.getElementById('life-profile') as HTMLInputElement;
    const avgCRateInput = document.getElementById('life-average-c-rate') as HTMLInputElement;
    const maxDischargeInput = document.getElementById('life-max-discharge') as HTMLInputElement;
    const maxChargeInput = document.getElementById('life-max-charge') as HTMLInputElement;
    const avgTempInput = document.getElementById('life-average-temp') as HTMLInputElement;
    const thermalEventsInput = document.getElementById('life-thermal-events') as HTMLInputElement;
    const safetyIncidentsInput = document.getElementById('life-safety-incidents') as HTMLInputElement;
    const maintenanceStatusInput = document.getElementById('life-maintenance-status') as HTMLInputElement;

    const carbonValueInput = document.getElementById('sust-carbon-value') as HTMLInputElement;
    const carbonUnitInput = document.getElementById('sust-carbon-unit') as HTMLSelectElement;
    const carbonMethodInput = document.getElementById('sust-carbon-method') as HTMLInputElement;
    const recycledInput = document.getElementById('sust-recycled') as HTMLSelectElement;
    const criticalInput = document.getElementById('sust-critical-materials') as HTMLSelectElement;
    const traceabilityInput = document.getElementById('sust-traceability') as HTMLSelectElement;
    const recyclingInput = document.getElementById('sust-recycling-instructions') as HTMLSelectElement;
    const secondLifeInput = document.getElementById('sust-second-life') as HTMLSelectElement;

    // Documentation checkboxes
    const docs = [
      'doc-datasheet', 'doc-conformity', 'doc-safety-manual', 'doc-transport',
      'doc-bms', 'doc-carbon-decl', 'doc-material', 'doc-recycling'
    ].map(id => document.getElementById(id) as HTMLInputElement);

    // Screen Outputs Elements
    const outPassportId = document.getElementById('out-passport-id') as HTMLElement;
    const outStatus = document.getElementById('out-status') as HTMLElement;
    const outCompleteness = document.getElementById('out-completeness') as HTMLElement;
    const outCompletenessBar = document.getElementById('out-completeness-bar') as HTMLElement;
    const outReadiness = document.getElementById('out-readiness') as HTMLElement;

    // Summary Card Elements
    const sumName = document.getElementById('sum-name') as HTMLElement;
    const sumChemistry = document.getElementById('sum-chemistry') as HTMLElement;
    const sumEnergy = document.getElementById('sum-energy') as HTMLElement;
    const sumVoltsAh = document.getElementById('sum-volts-ah') as HTMLElement;
    const sumHealth = document.getElementById('sum-health') as HTMLElement;
    const sumStage = document.getElementById('sum-stage') as HTMLElement;

    // Gaps & Warnings Lists
    const warningsContainer = document.getElementById('preview-warnings-container') as HTMLElement;
    const missingFieldsList = document.getElementById('preview-missing-fields') as HTMLElement;
    const warningsList = document.getElementById('preview-warnings') as HTMLElement;
    const recommendationsList = document.getElementById('preview-recommendations') as HTMLElement;

    // Print & Utility Buttons
    const buttonPrint = document.getElementById('button-print') as HTMLButtonElement;
    const autoCalcIndicator = document.getElementById('auto-calc-indicator') as HTMLElement;

    // Keep track of manual capacity overrides and random ID on load
    let energyManualOverride = false;
    const pageLoadPassportId = generatePassportId();

    // Init passport ID display
    if (outPassportId) {
      outPassportId.textContent = pageLoadPassportId;
    }

    // Set listener for manual energy capacity adjustments
    energyCapacityInput?.addEventListener('input', () => {
      energyManualOverride = (energyCapacityInput.value.trim() !== '');
      validateInputs();
      updateCalculations();
    });

    function getNumber(el: HTMLInputElement): number | null {
      const val = parseFloat(el.value);
      return isNaN(val) ? null : val;
    }

    function getBoolean(el: HTMLSelectElement): boolean | null {
      const val = el.value;
      if (val === 'yes') return true;
      if (val === 'no') return false;
      return null;
    }

    function getStatusText(val: boolean | null | undefined): string {
      if (val === true) return 'Yes (Declared)';
      if (val === false) return 'No (Undeclared)';
      return 'Undeclared';
    }

    // Interactive input validations
    function validateInputs() {
      // Add red border on negative values where non-negativity is required
      const numericInputs = [
        nominalVoltageInput, nominalCapacityInput, energyCapacityInput,
        ratedCyclesInput, currentCyclesInput, sohInput, efficiencyInput,
        avgCRateInput, maxDischargeInput, maxChargeInput,
        thermalEventsInput, safetyIncidentsInput, carbonValueInput
      ];

      numericInputs.forEach(el => {
        if (!el) return;
        const val = parseFloat(el.value);
        if (!isNaN(val) && val < 0) {
          el.classList.add('border-m-red', 'focus:border-m-red');
          el.classList.remove('border-hairline');
        } else {
          el.classList.remove('border-m-red', 'focus:border-m-red');
          el.classList.add('border-hairline');
        }
      });
    }

    function updateCalculations() {
      const volts = getNumber(nominalVoltageInput);
      const capacityAh = getNumber(nominalCapacityInput);

      // Auto calculate energy capacity if not manually overridden
      if (!energyManualOverride && volts !== null && capacityAh !== null && volts > 0 && capacityAh > 0) {
        const kwh = calculateEnergyCapacity(volts, capacityAh);
        if (kwh !== null) {
          energyCapacityInput.value = String(kwh);
          autoCalcIndicator?.classList.remove('hidden');
        }
      } else if (energyCapacityInput.value === '') {
        autoCalcIndicator?.classList.add('hidden');
      }

      // Build structured input
      const input = {
        identity: {
          name: nameInput.value,
          manufacturer: manufacturerInput.value,
          application: applicationInput.value as any,
          category: categoryInput.value,
          chemistry: chemistryInput.value as any,
          nominalVoltage: volts,
          nominalCapacity: capacityAh,
          energyCapacity: getNumber(energyCapacityInput),
          manufacturingDate: manufacturingDateInput.value,
          countryOfManufacture: countryInput.value,
          serialNumber: serialNumberInput.value
        },
        performance: {
          ratedCycleLife: getNumber(ratedCyclesInput),
          currentCycleCount: getNumber(currentCyclesInput),
          sohPercent: getNumber(sohInput),
          roundTripEfficiency: getNumber(efficiencyInput),
          tempMin: getNumber(tempMinInput),
          tempMax: getNumber(tempMaxInput),
          recommendedDoD: getNumber(dodInput),
          warrantyYears: getNumber(warrantyInput),
          expectedServiceLife: getNumber(serviceLifeInput)
        },
        lifecycle: {
          commissioningDate: commissioningDateInput.value,
          applicationProfile: profileInput.value,
          averageCRate: getNumber(avgCRateInput),
          maxDischargeCurrent: getNumber(maxDischargeInput),
          maxChargeCurrent: getNumber(maxChargeInput),
          averageTemp: getNumber(avgTempInput),
          thermalEvents: getNumber(thermalEventsInput),
          safetyIncidents: getNumber(safetyIncidentsInput),
          maintenanceStatus: maintenanceStatusInput.value
        },
        sustainability: {
          carbonFootprint: getNumber(carbonValueInput),
          carbonFootprintUnit: carbonUnitInput.value as any,
          carbonFootprintMethod: carbonMethodInput.value,
          recycledContentAvailable: getBoolean(recycledInput),
          criticalMaterialsDeclared: getBoolean(criticalInput),
          supplierTraceability: getBoolean(traceabilityInput),
          recyclingInstructionsAvailable: getBoolean(recyclingInput),
          secondLifeSuitability: secondLifeInput.value as any
        },
        documentation: {
          technicalDatasheet: docs[0].checked,
          declarationOfConformity: docs[1].checked,
          safetyManual: docs[2].checked,
          transportCertification: docs[3].checked,
          bmsDataExport: docs[4].checked,
          carbonFootprintDeclaration: docs[5].checked,
          materialCompositionDeclaration: docs[6].checked,
          endOfLifeInstructions: docs[7].checked
        }
      };

      // Calculate outputs
      const completeness = calculateDataCompleteness(input);
      const readiness = calculateComplianceReadiness(input, completeness);
      const health = classifyBatteryHealth(input.performance.sohPercent);
      const stage = estimateLifecycleStage(
        input.performance.currentCycleCount,
        input.performance.ratedCycleLife,
        input.performance.sohPercent
      );
      
      const missingFields = generateMissingFieldsList(input);
      const warningsListArray = generateMissingFieldWarnings(input);
      
      const statusValue = (completeness >= 85 && missingFields.length === 0) ? 'Ready for Review' : (completeness >= 40 ? 'Partial' : 'Draft');

      // Update basic status fields in screen view
      if (outStatus) {
        outStatus.textContent = statusValue;
        outStatus.className = 'text-[10px] font-bold px-2.5 py-0.5 uppercase tracking-wider inline-block mt-1 border ' +
          (statusValue === 'Ready for Review' ? 'border-green-600 text-green-600 bg-green-950/10' : 
           (statusValue === 'Partial' ? 'border-m-blue-light text-m-blue-light bg-m-blue-light/10' : 'border-m-red text-m-red bg-m-red/10'));
      }

      if (outCompleteness) {
        outCompleteness.textContent = `${completeness}%`;
      }
      if (outCompletenessBar) {
        outCompletenessBar.style.width = `${completeness}%`;
        outCompletenessBar.className = 'h-full transition-all duration-300 ' +
          (completeness >= 80 ? 'bg-green-600' : (completeness >= 50 ? 'bg-m-blue-light' : 'bg-m-red'));
      }

      if (outReadiness) {
        outReadiness.textContent = readiness;
        outReadiness.className = 'text-xl font-bold uppercase tracking-wider block mt-1.5 ' +
          (readiness === 'High' ? 'text-green-600' : (readiness === 'Medium' ? 'text-m-blue-light' : 'text-m-red'));
      }

      // Update Summary Card in screen view
      if (sumName) sumName.textContent = input.identity.name || 'Not set';
      if (sumChemistry) sumChemistry.textContent = input.identity.chemistry || 'Not set';
      if (sumEnergy) {
        sumEnergy.textContent = input.identity.energyCapacity ? `${input.identity.energyCapacity} kWh` : 'Not set';
      }
      if (sumVoltsAh) {
        if (volts !== null || capacityAh !== null) {
          sumVoltsAh.textContent = `${volts || '—'}V / ${capacityAh || '—'}Ah`;
        } else {
          sumVoltsAh.textContent = 'Not set';
        }
      }
      if (sumHealth) sumHealth.textContent = health === 'Unknown' ? 'Undeclared' : health;
      if (sumStage) sumStage.textContent = stage === 'Unknown' ? 'Undeclared' : stage;

      // Update Warnings and Gaps in screen view
      if (missingFields.length > 0 || warningsListArray.length > 0) {
        warningsContainer?.classList.remove('hidden');
      } else {
        warningsContainer?.classList.add('hidden');
      }

      if (missingFieldsList) {
        missingFieldsList.innerHTML = '';
        missingFields.forEach(field => {
          const li = document.createElement('li');
          li.textContent = field;
          missingFieldsList.appendChild(li);
        });
      }

      if (warningsList) {
        warningsList.innerHTML = '';
        warningsListArray.forEach(w => {
          const div = document.createElement('div');
          div.className = 'bg-m-red/10 border-l-4 border-m-red p-3 my-2 text-xs font-light text-primary flex gap-2 items-start';
          div.innerHTML = `<span class="font-bold">⚠️</span> <span>${w}</span>`;
          warningsList.appendChild(div);
        });
      }

      // Update Recommendations in screen view
      if (recommendationsList) {
        recommendationsList.innerHTML = '';
        const recs = generateRecommendations(input, {
          passportId: pageLoadPassportId,
          status: statusValue as any,
          completenessScore: completeness,
          complianceReadiness: readiness,
          healthClassification: health,
          lifecycleStage: stage,
          missingCriticalFields: missingFields,
          warnings: warningsListArray
        });
        recs.forEach(rec => {
          const li = document.createElement('li');
          li.textContent = rec;
          recommendationsList.appendChild(li);
        });
      }

      // ─── Update Print Assessment Report Container ───
      const pPassportIdHeader = document.getElementById('print-passport-id-header');
      const pCompleteness = document.getElementById('print-completeness');
      const pReadiness = document.getElementById('print-readiness');
      const pHealth = document.getElementById('print-health');
      const pStage = document.getElementById('print-stage');
      const pDate = document.getElementById('print-date');

      if (pPassportIdHeader) pPassportIdHeader.textContent = pageLoadPassportId;
      if (pCompleteness) pCompleteness.textContent = `${completeness}%`;
      if (pReadiness) {
        pReadiness.textContent = readiness;
        pReadiness.className = 'text-xl font-bold uppercase ' +
          (readiness === 'High' ? 'text-green-700' : (readiness === 'Medium' ? 'text-blue-700' : 'text-red-700'));
      }
      if (pHealth) pHealth.textContent = health === 'Unknown' ? 'Undeclared' : health;
      if (pStage) pStage.textContent = stage === 'Unknown' ? 'Undeclared' : stage;
      if (pDate) pDate.textContent = new Date().toLocaleDateString();

      // Section A print fields
      const pName = document.getElementById('print-name');
      const pManufacturer = document.getElementById('print-manufacturer');
      const pApplication = document.getElementById('print-application');
      const pCategory = document.getElementById('print-category');
      const pChemistry = document.getElementById('print-chemistry');
      const pVolts = document.getElementById('print-volts');
      const pCapacityAh = document.getElementById('print-capacity-ah');
      const pEnergy = document.getElementById('print-energy');
      const pSerialNumber = document.getElementById('print-serial-number');
      const pMfgInfo = document.getElementById('print-mfg-info');

      if (pName) pName.textContent = input.identity.name || 'Undeclared';
      if (pManufacturer) pManufacturer.textContent = input.identity.manufacturer || 'Undeclared';
      if (pApplication) pApplication.textContent = input.identity.application || 'Undeclared';
      if (pCategory) pCategory.textContent = input.identity.category || 'Undeclared';
      if (pChemistry) pChemistry.textContent = input.identity.chemistry || 'Undeclared';
      if (pVolts) pVolts.textContent = volts !== null ? `${volts} V` : 'Undeclared';
      if (pCapacityAh) pCapacityAh.textContent = capacityAh !== null ? `${capacityAh} Ah` : 'Undeclared';
      if (pEnergy) pEnergy.textContent = input.identity.energyCapacity ? `${input.identity.energyCapacity} kWh` : 'Undeclared';
      if (pSerialNumber) pSerialNumber.textContent = input.identity.serialNumber || 'Undeclared';
      if (pMfgInfo) {
        const country = input.identity.countryOfManufacture || '—';
        const date = input.identity.manufacturingDate || '—';
        pMfgInfo.textContent = `${date} (assembled in ${country})`;
      }

      // Section B print fields
      const pRatedCycles = document.getElementById('print-rated-cycles');
      const pCurrentCycles = document.getElementById('print-current-cycles');
      const pSoh = document.getElementById('print-soh');
      const pEfficiency = document.getElementById('print-efficiency');
      const pTempRange = document.getElementById('print-temp-range');
      const pDod = document.getElementById('print-dod');
      const pWarranty = document.getElementById('print-warranty');
      const pServiceLife = document.getElementById('print-service-life');

      if (pRatedCycles) pRatedCycles.textContent = input.performance.ratedCycleLife !== null ? `${input.performance.ratedCycleLife} cycles` : 'Undeclared';
      if (pCurrentCycles) pCurrentCycles.textContent = input.performance.currentCycleCount !== null ? `${input.performance.currentCycleCount} cycles` : 'Undeclared';
      if (pSoh) pSoh.textContent = input.performance.sohPercent !== null ? `${input.performance.sohPercent}%` : 'Undeclared';
      if (pEfficiency) pEfficiency.textContent = input.performance.roundTripEfficiency !== null ? `${input.performance.roundTripEfficiency}%` : 'Undeclared';
      if (pTempRange) {
        const min = input.performance.tempMin !== null ? `${input.performance.tempMin}°C` : '—';
        const max = input.performance.tempMax !== null ? `${input.performance.tempMax}°C` : '—';
        pTempRange.textContent = (min !== '—' || max !== '—') ? `${min} to ${max}` : 'Undeclared';
      }
      if (pDod) pDod.textContent = input.performance.recommendedDoD !== null ? `${input.performance.recommendedDoD}%` : 'Undeclared';
      if (pWarranty) pWarranty.textContent = input.performance.warrantyYears !== null ? `${input.performance.warrantyYears} years` : 'Undeclared';
      if (pServiceLife) pServiceLife.textContent = input.performance.expectedServiceLife !== null ? `${input.performance.expectedServiceLife} years` : 'Undeclared';

      // Section C print fields
      const pCommissionDate = document.getElementById('print-commission-date');
      const pProfile = document.getElementById('print-profile');
      const pCRate = document.getElementById('print-c-rate');
      const pMaxCurrents = document.getElementById('print-max-currents');
      const pAvgTemp = document.getElementById('print-avg-temp');
      const pThermalEvents = document.getElementById('print-thermal-events');
      const pSafetyIncidents = document.getElementById('print-safety-incidents');
      const pMaintenance = document.getElementById('print-maintenance');

      if (pCommissionDate) pCommissionDate.textContent = input.lifecycle.commissioningDate || 'Undeclared';
      if (pProfile) pProfile.textContent = input.lifecycle.applicationProfile || 'Undeclared';
      if (pCRate) pCRate.textContent = input.lifecycle.averageCRate !== null ? `${input.lifecycle.averageCRate}C` : 'Undeclared';
      if (pMaxCurrents) {
        const disc = input.lifecycle.maxDischargeCurrent !== null ? `${input.lifecycle.maxDischargeCurrent}A` : '—';
        const chg = input.lifecycle.maxChargeCurrent !== null ? `${input.lifecycle.maxChargeCurrent}A` : '—';
        pMaxCurrents.textContent = (disc !== '—' || chg !== '—') ? `Dischg: ${disc} / Chg: ${chg}` : 'Undeclared';
      }
      if (pAvgTemp) pAvgTemp.textContent = input.lifecycle.averageTemp !== null ? `${input.lifecycle.averageTemp}°C` : 'Undeclared';
      if (pThermalEvents) pThermalEvents.textContent = input.lifecycle.thermalEvents !== null ? `${input.lifecycle.thermalEvents} logged` : 'Undeclared';
      if (pSafetyIncidents) pSafetyIncidents.textContent = input.lifecycle.safetyIncidents !== null ? `${input.lifecycle.safetyIncidents} logged` : 'Undeclared';
      if (pMaintenance) pMaintenance.textContent = input.lifecycle.maintenanceStatus || 'Undeclared';

      // Section D print fields
      const pCarbon = document.getElementById('print-carbon');
      const pCarbonMethod = document.getElementById('print-carbon-method');
      const pRecycled = document.getElementById('print-recycled');
      const pCritical = document.getElementById('print-critical');
      const pTraceability = document.getElementById('print-traceability');
      const pRecycling = document.getElementById('print-recycling');
      const pSecondLife = document.getElementById('print-second-life');

      if (pCarbon) {
        const val = input.sustainability.carbonFootprint;
        const unit = input.sustainability.carbonFootprintUnit;
        pCarbon.textContent = val !== null ? `${val} ${unit === 'Unknown' ? '' : unit}` : 'Undeclared';
      }
      if (pCarbonMethod) pCarbonMethod.textContent = input.sustainability.carbonFootprintMethod || 'Undeclared';
      if (pRecycled) pRecycled.textContent = getStatusText(input.sustainability.recycledContentAvailable);
      if (pCritical) pCritical.textContent = getStatusText(input.sustainability.criticalMaterialsDeclared);
      if (pTraceability) pTraceability.textContent = getStatusText(input.sustainability.supplierTraceability);
      if (pRecycling) pRecycling.textContent = getStatusText(input.sustainability.recyclingInstructionsAvailable);
      if (pSecondLife) pSecondLife.textContent = input.sustainability.secondLifeSuitability || 'Undeclared';

      // Section E print fields
      const docNames = [
        "Technical datasheet",
        "CE / UL Declaration of Conformity",
        "Operator safety manual",
        "UN 38.3 transport safety certification",
        "BMS telemetry export protocol",
        "Carbon footprint declaration",
        "Material composition declaration",
        "End-of-life recycling instructions"
      ];
      for (let i = 1; i <= 8; i++) {
        const docEl = document.getElementById(`print-doc-${i}`);
        if (docEl) {
          const isChecked = docs[i - 1].checked;
          docEl.textContent = `${docNames[i - 1]}: ${isChecked ? '✓ Available' : '✗ Missing'}`;
          docEl.className = isChecked ? 'text-green-700' : 'text-red-700';
        }
      }

      // Print Gaps & Warnings
      const pMissingWarnings = document.getElementById('print-missing-warnings');
      if (pMissingWarnings) {
        pMissingWarnings.innerHTML = '';
        if (missingFields.length === 0 && warningsListArray.length === 0) {
          pMissingWarnings.innerHTML = '<li>None</li>';
        } else {
          missingFields.forEach(f => {
            const li = document.createElement('li');
            li.textContent = `Missing critical: ${f}`;
            pMissingWarnings.appendChild(li);
          });
          warningsListArray.forEach(w => {
            const li = document.createElement('li');
            li.textContent = `Warning: ${w}`;
            pMissingWarnings.appendChild(li);
          });
        }
      }

      // Print Recommendations
      const pRecommendations = document.getElementById('print-recommendations');
      if (pRecommendations) {
        pRecommendations.innerHTML = '';
        const recs = generateRecommendations(input, {
          passportId: pageLoadPassportId,
          status: statusValue as any,
          completenessScore: completeness,
          complianceReadiness: readiness,
          healthClassification: health,
          lifecycleStage: stage,
          missingCriticalFields: missingFields,
          warnings: warningsListArray
        });
        recs.forEach(rec => {
          const li = document.createElement('li');
          li.textContent = rec;
          pRecommendations.appendChild(li);
        });
      }
    }

    // Set Event Listeners on all controls
    const allFormControls = [
      nameInput, manufacturerInput, applicationInput, categoryInput, chemistryInput,
      nominalVoltageInput, nominalCapacityInput, manufacturingDateInput, countryInput, serialNumberInput,
      ratedCyclesInput, currentCyclesInput, sohInput, efficiencyInput, tempMinInput, tempMaxInput,
      dodInput, warrantyInput, serviceLifeInput, commissioningDateInput, profileInput, avgCRateInput,
      maxDischargeInput, maxChargeInput, avgTempInput, thermalEventsInput, safetyIncidentsInput, maintenanceStatusInput,
      carbonValueInput, carbonUnitInput, carbonMethodInput, recycledInput, criticalInput,
      traceabilityInput, recyclingInput, secondLifeInput, ...docs
    ];

    allFormControls.forEach(ctrl => {
      if (!ctrl) return;
      if (ctrl.type === 'checkbox') {
        ctrl.addEventListener('change', () => {
          updateCalculations();
        });
      } else {
        ctrl.addEventListener('input', () => {
          validateInputs();
          updateCalculations();
        });
      }
    });

    buttonPrint?.addEventListener('click', () => {
      window.print();
    });

    // Run on mount
    validateInputs();
    updateCalculations();
  </script>

  <style>
    /* Custom button resets for Design System */
    .btn-primary {
      cursor: pointer;
    }
  </style>

</Layout>
