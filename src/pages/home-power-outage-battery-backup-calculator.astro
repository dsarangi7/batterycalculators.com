          <tr class="border-b border-hairline"><td class="p-3">Wi-Fi Router</td><td class="p-3 text-right">12 W</td><td class="p-3 text-right">12 W</td><td class="p-3 text-right text-muted">Continuous draw</td></tr>
          <tr class="border-b border-hairline"><td class="p-3">LED Bulb</td><td class="p-3 text-right">10 W</td><td class="p-3 text-right">10 W</td><td class="p-3 text-right text-muted">Per bulb</td></tr>
          <tr class="border-b border-hairline"><td class="p-3">Laptop</td><td class="p-3 text-right">60 W</td><td class="p-3 text-right">90 W</td><td class="p-3 text-right text-muted">Charging + running</td></tr>
          <tr class="border-b border-hairline"><td class="p-3">TV (LED/LCD)</td><td class="p-3 text-right">100 W</td><td class="p-3 text-right">150 W</td><td class="p-3 text-right text-muted">55" class typical</td></tr>
          <tr class="border-b border-hairline"><td class="p-3">CPAP Machine</td><td class="p-3 text-right">40 W</td><td class="p-3 text-right">80 W</td><td class="p-3 text-right text-muted">With humidifier</td></tr>
          <tr class="border-b border-hairline"><td class="p-3">Box Fan</td><td class="p-3 text-right">50 W</td><td class="p-3 text-right">75 W</td><td class="p-3 text-right text-muted">20" box fan</td></tr>
          <tr class="border-b border-hairline"><td class="p-3">Sump Pump</td><td class="p-3 text-right">800 W</td><td class="p-3 text-right">2,000 W</td><td class="p-3 text-right text-muted">½ HP typical</td></tr>
          <tr class="border-b border-hairline"><td class="p-3">Microwave</td><td class="p-3 text-right">1,000 W</td><td class="p-3 text-right">1,500 W</td><td class="p-3 text-right text-muted">1,000W model</td></tr>
          <tr class="border-b border-hairline"><td class="p-3">Phone Charger</td><td class="p-3 text-right">15 W</td><td class="p-3 text-right">15 W</td><td class="p-3 text-right text-muted">USB-C fast charge</td></tr>
          <tr class="p-3"><td class="p-3">Coffee Maker</td><td class="p-3 text-right">900 W</td><td class="p-3 text-right">1,200 W</td><td class="p-3 text-right text-muted">Drip 12-cup</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- LiFePO4 vs Lead-Acid Comparison -->
  <section class="mb-16 border-t border-hairline pt-12">
    <h2 class="text-title-lg text-primary uppercase tracking-wider mb-6">LiFePO4 vs Lead-Acid for Backup Power</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-body-sm text-muted border border-hairline">
        <thead>
          <tr class="border-b border-hairline">
            <th class="text-left p-3 text-label-uppercase text-primary text-[10px]">Feature</th>
            <th class="text-center p-3 text-label-uppercase text-primary text-[10px]">LiFePO4</th>
            <th class="text-center p-3 text-label-uppercase text-primary text-[10px]">AGM / Sealed</th>
            <th class="text-center p-3 text-label-uppercase text-primary text-[10px]">Flooded Lead-Acid</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-hairline"><td class="p-3">Usable Depth of Discharge</td><td class="p-3 text-center font-bold text-primary">80–100%</td><td class="p-3 text-center">50%</td><td class="p-3 text-center">50%</td></tr>
          <tr class="border-b border-hairline"><td class="p-3">Cycle Life</td><td class="p-3 text-center font-bold text-primary">3,000–6,000</td><td class="p-3 text-center">300–500</td><td class="p-3 text-center">200–400</td></tr>
          <tr class="border-b border-hairline"><td class="p-3">Weight</td><td class="p-3 text-center font-bold text-primary">Lightest</td><td class="p-3 text-center">Heavy</td><td class="p-3 text-center">Heaviest</td></tr>
          <tr class="border-b border-hairline"><td class="p-3">Maintenance</td><td class="p-3 text-center font-bold text-primary">None</td><td class="p-3 text-center">None</td><td class="p-3 text-center">Water refill</td></tr>
          <tr class="border-b border-hairline"><td class="p-3">Cold Weather Performance</td><td class="p-3 text-center font-bold text-primary">Good</td><td class="p-3 text-center">Poor</td><td class="p-3 text-center">Poor</td></tr>
          <tr class="border-b border-hairline"><td class="p-3">Indoor Installation</td><td class="p-3 text-center font-bold text-primary">Safe</td><td class="p-3 text-center">Ventilation needed</td><td class="p-3 text-center">Ventilation required</td></tr>
          <tr class="border-b border-hairline"><td class="p-3">Upfront Cost</td><td class="p-3 text-center">Higher</td><td class="p-3 text-center">Lower</td><td class="p-3 text-center">Lowest</td></tr>
          <tr class="p-3"><td class="p-3">Lifetime Cost per Cycle</td><td class="p-3 text-center font-bold text-primary">Lowest</td><td class="p-3 text-center">Higher</td><td class="p-3 text-center">Highest</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- Safety Notes -->
  <section class="mb-16 border-t border-hairline pt-12">
    <h2 class="text-title-lg text-primary uppercase tracking-wider mb-6">Safety Notes</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <CalculatorCard>
        <p class="text-body-sm text-muted flex gap-3">
          <span class="text-m-red shrink-0 mt-0.5">⚠</span>
          <span>Never connect a portable generator or battery system to your home wiring without a proper transfer switch. Backfeed can electrocute utility workers restoring power.</span>
        </p>
      </CalculatorCard>
      <CalculatorCard>
        <p class="text-body-sm text-muted flex gap-3">
          <span class="text-m-red shrink-0 mt-0.5">⚠</span>
          <span>Lithium batteries should be installed away from living spaces per local fire codes. LiFePO4 is the safest lithium chemistry but always follow manufacturer installation guidelines.</span>
        </p>
      </CalculatorCard>
      <CalculatorCard>
        <p class="text-body-sm text-muted flex gap-3">
          <span class="text-m-red shrink-0 mt-0.5">⚠</span>
          <span>Do not exceed the continuous or surge rating of your inverter. Overloaded inverters can overheat, shut down, or cause fire. Add 25% headroom to your continuous load estimate.</span>
        </p>
      </CalculatorCard>
      <CalculatorCard>
        <p class="text-body-sm text-muted flex gap-3">
          <span class="text-m-red shrink-0 mt-0.5">⚠</span>
          <span>Lead-acid batteries emit hydrogen gas during charging. Install in well-ventilated areas away from ignition sources. Never charge a frozen lead-acid battery.</span>
        </p>
      </CalculatorCard>
    </div>
  </section>

  <FAQSection items={faqItems} />

  <!-- Calculation Script -->
  <script>
    import { calculatePowerOutageBackup } from '../utils/calculators';

    interface ApplianceEntry {
      id: string;
      name: string;
      runningW: number;
      surgeW: number;
      quantity: number;
    }

    const appliancePresets: Record<string, { runningW: number; surgeW: number }> = {
      "Refrigerator": { runningW: 150, surgeW: 600 },
      "Freezer": { runningW: 120, surgeW: 500 },
      "Wi-Fi Router": { runningW: 12, surgeW: 12 },
      "LED Light": { runningW: 10, surgeW: 10 },
      "Laptop": { runningW: 60, surgeW: 90 },
      "TV": { runningW: 100, surgeW: 150 },
      "CPAP Machine": { runningW: 40, surgeW: 80 },
      "Fan": { runningW: 50, surgeW: 75 },
      "Sump Pump": { runningW: 800, surgeW: 2000 },
      "Microwave": { runningW: 1000, surgeW: 1500 },
    };

    let appliances: ApplianceEntry[] = [];
    let nextId = 1;

    const applianceSelect = document.getElementById('appliance-select') as HTMLSelectElement;
    const customLoadFields = document.getElementById('custom-load-fields') as HTMLDivElement;
    const addCustomBtn = document.getElementById('add-custom-btn') as HTMLButtonElement;
    const selectedAppliancesDiv = document.getElementById('selected-appliances') as HTMLDivElement;

    const backupHoursInput = document.getElementById('backup-hours') as HTMLInputElement;
    const batteryVoltageSelect = document.getElementById('battery-voltage') as HTMLSelectElement;
    const batteryChemistrySelect = document.getElementById('battery-chemistry') as HTMLSelectElement;
    const dodInput = document.getElementById('dod-percent') as HTMLInputElement;
    const inverterEfficiencyInput = document.getElementById('inverter-efficiency') as HTMLInputElement;
    const safetyMarginInput = document.getElementById('safety-margin') as HTMLInputElement;

    const solarEnabledCheckbox = document.getElementById('solar-enabled') as HTMLInputElement;
    const solarFields = document.getElementById('solar-fields') as HTMLDivElement;
    const solarWattsInput = document.getElementById('solar-watts') as HTMLInputElement;
    const peakSunHoursInput = document.getElementById('peak-sun-hours') as HTMLInputElement;
    const chargeControllerEffInput = document.getElementById('charge-controller-efficiency') as HTMLInputElement;

    const solarResultsDiv = document.getElementById('solar-results') as HTMLDivElement;

    const chemistryDodMap: Record<string, number> = {
      lifepo4: 80,
      agm: 50,
      flooded: 50,
    };

    function addAppliance(name: string, runningW: number, surgeW: number) {
      const id = `appliance-${nextId++}`;
      appliances.push({ id, name, runningW, surgeW, quantity: 1 });
      renderAppliances();
      updateCalculations();
    }

    function removeAppliance(id: string) {
      appliances = appliances.filter(a => a.id !== id);
      renderAppliances();
      updateCalculations();
    }

    function updateQuantity(id: string, qty: number) {
      const appliance = appliances.find(a => a.id === id);
      if (appliance) {
        appliance.quantity = Math.max(1, Math.min(20, qty));
        updateCalculations();
      }
    }

    function renderAppliances() {
      if (!selectedAppliancesDiv) return;
      selectedAppliancesDiv.innerHTML = '';

      if (appliances.length === 0) return;

      const header = document.createElement('div');
      header.className = 'flex items-center justify-between mb-1';
      header.innerHTML = `<span class="text-label-uppercase text-muted text-[10px]">SELECTED APPLIANCES</span><span class="text-caption text-muted">${appliances.length} item${appliances.length !== 1 ? 's' : ''}</span>`;
      selectedAppliancesDiv.appendChild(header);

      for (const appliance of appliances) {
        const row = document.createElement('div');
        row.className = 'flex items-center gap-3 bg-surface-soft border border-hairline p-3';

        row.innerHTML = `
          <div class="flex-1 min-w-0">
            <span class="text-primary font-bold text-sm block truncate">${appliance.name}</span>
            <span class="text-caption text-muted">${appliance.runningW}W running / ${appliance.surgeW}W surge</span>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <label class="text-caption text-muted">Qty:</label>
            <input type="number" class="text-input w-16 h-8 text-center text-sm" value="${appliance.quantity}" min="1" max="20" data-id="${appliance.id}" />
          </div>
          <button type="button" class="text-m-red hover:text-primary text-lg font-bold px-2 h-8 flex items-center justify-center border border-hairline hover:border-primary transition-colors shrink-0" data-remove="${appliance.id}">✕</button>
        `;

        const qtyInput = row.querySelector('input') as HTMLInputElement;
        qtyInput.addEventListener('input', () => {
          updateQuantity(appliance.id, parseInt(qtyInput.value) || 1);
        });

        const removeBtn = row.querySelector('[data-remove]') as HTMLButtonElement;
        removeBtn.addEventListener('click', () => {
          removeAppliance(appliance.id);
        });

        selectedAppliancesDiv.appendChild(row);
      }
    }

    applianceSelect?.addEventListener('change', () => {
      const val = applianceSelect.value;
      if (!val) return;

      if (val === 'custom') {
        customLoadFields?.classList.remove('hidden');
        customLoadFields?.classList.add('flex');
      } else {
        customLoadFields?.classList.add('hidden');
        customLoadFields?.classList.remove('flex');
        const preset = appliancePresets[val];
        if (preset) {
          addAppliance(val, preset.runningW, preset.surgeW);
        }
      }
      applianceSelect.value = '';
    });

    addCustomBtn?.addEventListener('click', () => {
      const nameInput = document.getElementById('custom-name') as HTMLInputElement;
      const runningInput = document.getElementById('custom-running') as HTMLInputElement;
      const surgeInput = document.getElementById('custom-surge') as HTMLInputElement;

      const name = nameInput?.value.trim() || 'Custom Load';
      const runningW = Math.max(1, parseInt(runningInput?.value) || 500);
      const surgeW = Math.max(runningW, parseInt(surgeInput?.value) || Math.ceil(runningW * 1.5));

      addAppliance(name, runningW, surgeW);

      if (nameInput) nameInput.value = '';
    });

    solarEnabledCheckbox?.addEventListener('change', () => {
      if (solarEnabledCheckbox.checked) {
        solarFields?.classList.remove('hidden');
        solarFields?.classList.add('flex');
        solarResultsDiv?.classList.remove('hidden');
      } else {
        solarFields?.classList.add('hidden');
        solarFields?.classList.remove('flex');
        solarResultsDiv?.classList.add('hidden');
      }
      updateCalculations();
    });

    batteryChemistrySelect?.addEventListener('change', () => {
      const chem = batteryChemistrySelect.value;
      const dod = chemistryDodMap[chem];
      if (dod && dodInput) {
        dodInput.value = String(dod);
      }
      updateCalculations();
    });

    function updateCalculations() {
      const backupHours = parseFloat(backupHoursInput?.value) || 8;
      const batteryVoltage = parseFloat(batteryVoltageSelect?.value) || 24;
      const dodPercent = parseFloat(dodInput?.value) || 80;
      const inverterEfficiency = parseFloat(inverterEfficiencyInput?.value) || 90;
      const safetyMargin = parseFloat(safetyMarginInput?.value) || 20;

      const solarEnabled = solarEnabledCheckbox?.checked || false;
      const solarWatts = parseFloat(solarWattsInput?.value) || 400;
      const peakSunHours = parseFloat(peakSunHoursInput?.value) || 5;
      const chargeControllerEff = parseFloat(chargeControllerEffInput?.value) || 95;

      const applianceLoads = appliances.map(a => ({
        name: a.name,
        runningW: a.runningW,
        surgeW: a.surgeW,
        quantity: a.quantity,
      }));

      const results = calculatePowerOutageBackup(
        applianceLoads,
        backupHours,
        batteryVoltage,
        dodPercent,
        inverterEfficiency,
        safetyMargin,
        solarEnabled,
        solarWatts,
        peakSunHours,
        chargeControllerEff
      );

      // Update result displays
      const batteryWhBox = document.getElementById('result-battery-wh');
      const batteryWhValue = batteryWhBox?.querySelector('.text-display-md') as HTMLElement;
      const batteryWhSuffix = batteryWhBox?.querySelector('.text-caption') as HTMLElement;
      if (batteryWhValue) batteryWhValue.textContent = `${Math.round(results.energyRequiredWh).toLocaleString()} Wh`;
      if (batteryWhSuffix) batteryWhSuffix.textContent = `${results.energyRequiredKwh.toFixed(1)} kWh total battery bank`;

      const batteryAhBox = document.getElementById('result-battery-ah');
      const batteryAhValue = batteryAhBox?.querySelector('.text-title-lg') as HTMLElement;
      const batteryAhSuffix = batteryAhBox?.querySelector('.text-caption') as HTMLElement;
      if (batteryAhValue) batteryAhValue.textContent = `${Math.round(results.batteryCapacityAh).toLocaleString()} Ah`;
      if (batteryAhSuffix) batteryAhSuffix.textContent = `At ${batteryVoltage}V nominal`;

      const runningBox = document.getElementById('result-running-w');
      const runningValue = runningBox?.querySelector('.text-title-lg') as HTMLElement;
      if (runningValue) runningValue.textContent = `${Math.round(results.totalRunningW).toLocaleString()} W`;

      const surgeBox = document.getElementById('result-surge-w');
      const surgeValue = surgeBox?.querySelector('.text-title-lg') as HTMLElement;
      if (surgeValue) surgeValue.textContent = `${Math.round(results.surgeW).toLocaleString()} W`;

      const inverterContBox = document.getElementById('result-inverter-cont');
      const inverterContValue = inverterContBox?.querySelector('.text-title-lg') as HTMLElement;
      if (inverterContValue) inverterContValue.textContent = `${results.inverterContinuousW.toLocaleString()} W`;

      const inverterSurgeBox = document.getElementById('result-inverter-surge');
      const inverterSurgeValue = inverterSurgeBox?.querySelector('.text-title-lg') as HTMLElement;
      if (inverterSurgeValue) inverterSurgeValue.textContent = `${results.inverterSurgeW.toLocaleString()} W`;

      // Battery configurations
      const bat12v100 = document.getElementById('result-bat-12v100');
      const bat12v200 = document.getElementById('result-bat-12v200');
      const bat24v100 = document.getElementById('result-bat-24v100');
      const bat48v100 = document.getElementById('result-bat-48v100');
      if (bat12v100) bat12v100.textContent = String(results.batteries12v100ah);
      if (bat12v200) bat12v200.textContent = String(results.batteries12v200ah);
      if (bat24v100) bat24v100.textContent = String(results.batteries24v100ah);
      if (bat48v100) bat48v100.textContent = String(results.batteries48v100ah);

      // Solar results
      if (solarEnabled) {
        const solarDaily = document.getElementById('result-solar-daily');
        const solarRecharge = document.getElementById('result-solar-recharge');
        const solarSufficient = document.getElementById('result-solar-sufficient');
        if (solarDaily) solarDaily.textContent = `${Math.round(results.solarDailyWh).toLocaleString()} Wh`;
        if (solarRecharge) solarRecharge.textContent = `${results.solarRechargeHours.toFixed(1)} hours`;
        if (solarSufficient) solarSufficient.textContent = results.solarSufficient ? 'Yes' : 'No — need more panels';
      }

      // Planning notes
      const planningNotes = document.getElementById('planning-notes');
      if (planningNotes) {
        if (appliances.length === 0) {
          planningNotes.textContent = 'Add appliances above to calculate your backup power requirements. Results update instantly as you adjust inputs.';
        } else {
          const chemistryName = batteryChemistrySelect?.value === 'lifepo4' ? 'LiFePO4' : batteryChemistrySelect?.value === 'agm' ? 'AGM Lead-Acid' : 'Flooded Lead-Acid';
          planningNotes.textContent = `For ${Math.round(results.totalRunningW)}W of loads over ${backupHours} hours at ${batteryVoltage}V ${chemistryName}, you need approximately ${results.energyRequiredKwh.toFixed(1)} kWh of battery capacity (${Math.round(results.batteryCapacityAh)} Ah). Recommended inverter: ${results.inverterContinuousW}W continuous with ${results.inverterSurgeW}W surge rating.`;
        }
      }
    }

    // Attach event listeners
    [backupHoursInput, dodInput, inverterEfficiencyInput, safetyMarginInput, solarWattsInput, peakSunHoursInput, chargeControllerEffInput].forEach(el => {
      el?.addEventListener('input', updateCalculations);
    });

    [batteryVoltageSelect, batteryChemistrySelect].forEach(el => {
      el?.addEventListener('change', updateCalculations);
    });

    // Initial render
    updateCalculations();
  </script>

</CalculatorLayout>
