---
import Layout from '../layouts/Layout.astro';

const popularCalculators = [
  { title: "Runtime Calculator", url: "/tools/runtime-calculator", description: "Estimate battery runtime from capacity, load, and efficiency." },
  { title: "Solar Battery Sizing Calculator", url: "/tools/solar-battery-sizing-calculator", description: "Size your solar bank from daily consumption and autonomy days." },
  { title: "Battery Pack Calculator", url: "/tools/battery-pack-calculator", description: "Design packs from individual cells with series-parallel configs." },
];
---

<Layout
  title="Server Error | Battery Calculators"
  description="An unexpected error occurred. Please try again or browse our battery calculators and learning resources."
>
  <div class="max-w-3xl mx-auto text-center py-12 md:py-20">
    <!-- Error Code -->
    <span class="text-label-uppercase text-m-red text-xs block mb-4">ERROR</span>
    <h1 class="text-display-lg text-primary mb-6">500</h1>
    <p class="text-body-md text-body font-light mb-10 max-w-lg mx-auto">
      Something went wrong. An unexpected error occurred. Please try again or use the links below to continue browsing.
    </p>

    <!-- Action Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
      <a href="/" class="btn-primary text-xs">Return Home</a>
      <a href="/tools" class="btn-primary-outline text-xs">Browse Calculators</a>
      <a href="/learn" class="btn-primary-outline text-xs">Learning Center</a>
    </div>

    <!-- Popular Calculators -->
    <div class="border-t border-hairline pt-12">
      <span class="text-label-uppercase text-primary text-xs block mb-6">Popular Calculators</span>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {popularCalculators.map((calc) => (
          <a
            href={calc.url}
            class="bg-surface-card border border-hairline p-6 flex flex-col gap-3 hover:border-primary transition-colors text-left group"
          >
            <span class="text-title-md text-primary group-hover:text-m-blue-light transition-colors">
              {calc.title}
            </span>
            <span class="text-body-sm text-muted">
              {calc.description}
            </span>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>
