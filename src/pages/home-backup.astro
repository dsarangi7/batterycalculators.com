---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CategoryToolGrid from '../components/CategoryToolGrid.astro';
import FAQSection from '../components/FAQSection.astro';

const tools = [
  {
    name: "Home Backup Battery Calculator",
    href: "/tools/home-backup-battery-calculator",
    description: "Calculate the battery size you need for home backup power during outages. Size critical load coverage for 8–48 hours.",
    available: true,
  },
  {
    name: "Inverter Battery Calculator",
    href: "/tools/inverter-battery-calculator",
    description: "Calculate the battery capacity you need for AC inverter loads with DoD and efficiency adjustments.",
    available: true,
  },
  {
    name: "Battery Runtime Calculator",
    href: "/tools/runtime-calculator",
    description: "Estimate how long your home battery will power critical loads during a power outage.",
    available: true,
  },
  {
    name: "Home Power Outage Battery Backup Calculator",
    href: "/home-power-outage-battery-backup-calculator",
    description: "Calculate battery size, inverter size, and backup system for storms, hurricanes, and grid failures.",
    available: true,
  },
  {
    name: "Charging Time Calculator",
    href: "/tools/charging-time-calculator",
    description: "Calculate how long it takes to charge your home battery from a given SOC to target SOC.",
    available: true,
  },
  {
    name: "Fridge Battery Backup Calculator",
    href: "/fridge-battery-backup-calculator",
    description: "Size a battery to keep your refrigerator running during a power outage. Prevent food spoilage.",
    available: true,
  },
  {
    name: "CPAP Battery Backup Calculator",
    href: "/cpap-battery-backup-calculator",
    description: "Size a battery to power your CPAP machine overnight during a power outage.",
    available: true,
  },
  {
    name: "Sump Pump Battery Backup Calculator",
    href: "/sump-pump-battery-backup-calculator",
    description: "Size a battery to keep your sump pump running during storm-related power outages.",
    available: true,
  },
  {
    name: "Portable Power Station Runtime Calculator",
    href: "/portable-power-station-runtime-calculator",
    description: "See how long a portable power station will run your critical appliances during an outage.",
    available: true,
  },
  {
    name: "Solar Generator Sizing Calculator",
    href: "/solar-generator-sizing-calculator",
    description: "Size a complete solar backup system with battery, panels, and inverter.",
    available: true,
  },
];

const learnArticles = [
  { title: "Home Battery Backup Planning Guide", href: "/learn/home-battery-backup-planning" },
  { title: "How Many kWh Do I Need for My House?", href: "/learn/how-many-kwh-do-i-need-for-my-house" },
  { title: "Power Outage Battery Guide", href: "/learn/power-outage-battery-guide" },
  { title: "Whole House Battery Backup", href: "/learn/whole-house-battery-backup" },
  { title: "Generator vs Battery Backup", href: "/learn/generator-vs-battery-backup" },
  { title: "Home Backup Runtime Guide", href: "/learn/home-backup-runtime-guide" },
  { title: "Home Battery Sizing Guide", href: "/learn/home-battery-sizing-guide" },
  { title: "How to Size a Battery Bank", href: "/learn/how-to-size-a-battery-bank" },
  { title: "Battery Sizing Reference", href: "/learn/battery-sizing-reference" },
  { title: "Battery Depth of Discharge Chart", href: "/learn/battery-depth-of-discharge-chart" },
  { title: "LiFePO4 vs Lead-Acid", href: "/learn/lifepo4-vs-lead-acid" },
  { title: "Common Battery Sizes Reference", href: "/learn/common-battery-sizes-reference" },
];

const faqItems = [
  {
    question: "How big of a battery do I need for home backup?",
    answer: "The battery size depends on which loads you want to back up and for how long. A typical home backing up essential loads (refrigerator, lights, internet, medical devices) for 24 hours needs approximately 10–15 kWh of usable battery capacity. Backing up the entire house for 24 hours may require 30–50 kWh or more.",
  },
  {
    question: "How long will a home battery last during a power outage?",
    answer: "Runtime depends on your battery capacity and the loads you are running. A 10 kWh usable battery powering essential loads at 1.5 kW will last approximately 6.7 hours. Running only a refrigerator and a few lights at 500W could extend runtime to 20 hours. Use our Runtime Calculator for precise estimates based on your specific load profile.",
  },
  {
    question: "What loads should I prioritize for backup?",
    answer: "Critical loads typically include refrigerator/freezer, medical equipment, internet router, phone charging, a few lights, and well pumps. High-draw loads like air conditioning, electric water heaters, and electric ranges should generally be excluded from backup unless you have a very large battery bank.",
  },
  {
    question: "Do I need a special inverter for home battery backup?",
    answer: "Yes. Home battery backup requires a hybrid inverter or a battery-based inverter-charger that can operate independently of the grid. Standard grid-tied solar inverters shut down during grid outages for safety (anti-islanding). A hybrid inverter with backup capability can isolate your critical loads and power them from the battery during outages.",
  },
  {
    question: "Can I add batteries to my existing solar system?",
    answer: "Yes, but the approach depends on your current inverter. If you have a standard grid-tied inverter, you will need to either replace it with a hybrid inverter or add an AC-coupled battery system with its own inverter. Some manufacturers offer battery retrofit kits for their existing inverter platforms.",
  },
];

const relatedCategories = [
  { href: "/solar", title: "Solar", description: "Solar battery sizing and off-grid planning" },
  { href: "/engineering", title: "Engineering", description: "C-rate, SOC, voltage drop, and cable loss tools" },
  { href: "/bess", title: "BESS & Commercial", description: "Commercial battery storage ROI analysis" },
];

const breadcrumbItems = [
  { label: "Home Backup" },
];
---

<Layout
  title="Home Backup Battery Calculators | Battery Calculators"
  description="Free home backup battery calculators for power outage planning, essential load sizing, and battery runtime estimation."
  schema="website"
  schemaName="Home Backup Battery Calculators"
  schemaDescription="Engineering-grade battery calculators for home backup power systems and power outage planning."
  breadcrumbs={[{ label: 'Home Backup' }]}
>
  <Breadcrumb items={breadcrumbItems} />

  <section class="mb-12 md:mb-16 border-b border-hairline pb-12">
    <div class="max-w-4xl">
      <span class="text-label-uppercase text-m-blue-light text-xs block mb-4">HOME BACKUP</span>
      <h1 class="text-display-md text-primary mb-6">Home Backup Battery Calculators</h1>
      <p class="text-body-md text-body max-w-2xl font-light">
        Plan your home battery backup system with engineering-grade calculators. Size your battery for essential loads, estimate runtime during outages, and calculate charging times.
      </p>
    </div>
  </section>

  <section class="mb-16">
    <div class="max-w-4xl text-body-md text-body font-light flex flex-col gap-6">
      <p>
        Home battery backup systems provide electrical independence during grid outages. Unlike grid-tied solar alone, which shuts down when the grid fails, a battery-backed system can seamlessly transition to island mode, keeping your critical loads running without interruption.
      </p>
      <p>
        The foundation of any home backup system is proper load analysis. You need to identify which appliances and circuits are essential during an outage, determine their power consumption, and size the battery to cover these loads for your desired backup duration. A household backing up only a refrigerator, internet router, and a few lights draws roughly 500–800 watts. Adding a well pump, medical equipment, or a mini-split can push the load to 2–4 kW.
      </p>
      <p>
        Battery chemistry selection affects both the usable capacity and the system cost. Lithium Iron Phosphate (LiFePO4) batteries can be discharged to 80–90% DoD daily, meaning a 10 kWh battery delivers 8–9 kWh of usable energy. Lead-acid batteries are limited to 50% DoD, so the same 10 kWh rated bank only provides 5 kWh of usable energy. This makes lithium batteries more cost-effective per usable kilowatt-hour despite their higher upfront price.
      </p>
      <p>
        System voltage is another critical design decision. 12V systems work for small backup setups under 2 kW. 24V systems handle moderate loads up to 5 kW efficiently. 48V systems are standard for whole-house backup, reducing current draw and allowing thinner, less expensive wiring. Our calculators help you evaluate each configuration option.
      </p>
    </div>
  </section>

  <section class="mb-16">
    <h2 class="text-title-lg text-primary mb-6">Available Calculators</h2>
    <CategoryToolGrid tools={tools} />
  </section>

  {learnArticles.length > 0 && (
    <section class="mb-16 border-t border-hairline pt-12">
      <h2 class="text-title-lg text-primary mb-6">Home Backup Guides</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {learnArticles.map((article) => (
          <a href={article.href} class="bg-surface-card border border-hairline p-4 hover:border-primary transition-colors">
            <span class="text-label-uppercase text-muted text-[10px] block mb-2">LEARNING CENTER</span>
            <h3 class="text-title-sm text-primary">{article.title}</h3>
          </a>
        ))}
      </div>
    </section>
  )}

  <FAQSection items={faqItems} />

  {relatedCategories.length > 0 && (
    <section class="mb-16 border-t border-hairline pt-12">
      <h2 class="text-title-lg text-primary mb-6">Related Categories</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {relatedCategories.map((cat) => (
          <a href={cat.href} class="bg-surface-card border border-hairline p-6 hover:border-primary transition-colors block">
            <h3 class="text-title-md text-primary mb-2">{cat.title}</h3>
            <p class="text-body-sm text-muted">{cat.description}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="bg-surface-soft border border-hairline p-6 text-caption text-muted mb-8">
    <span class="text-primary font-bold text-[10px] tracking-wider uppercase border border-hairline px-1.5 py-0.5 mr-2 inline-block mb-3">
      Engineering Disclaimer
    </span>
    All calculators provide sizing estimates only. Actual backup duration depends on battery chemistry, temperature, load profile, and system losses. Consult a certified electrician for critical backup systems.
  </section>
</Layout>
