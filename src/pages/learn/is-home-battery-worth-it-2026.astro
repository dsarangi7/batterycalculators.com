        <FormulaBox title="Key Formulas">
          <div class="bg-surface-soft border border-hairline p-5">
            <p class="text-primary font-bold mb-2">Simple Payback Period</p>
            <p class="text-muted">Net System Cost After Incentives ($) ÷ Annual Savings ($) = Payback (Years)</p>
          </div>
          <div class="bg-surface-soft border border-hairline p-5">
            <p class="text-primary font-bold mb-2">Annual TOU Arbitrage Savings</p>
            <p class="text-muted">Daily kWh Shifted × (Peak Rate – Off-Peak Rate) × 365 = Annual Savings ($)</p>
          </div>
          <div class="bg-surface-soft border border-hairline p-5">
            <p class="text-primary font-bold mb-2">Solar Self-Consumption Improvement</p>
            <p class="text-muted">Daily kWh Consumed On-Site × (Retail Rate – Feed-in Rate) × 365 = Annual Savings ($)</p>
          </div>
          <div class="bg-surface-soft border border-hairline p-5">
            <p class="text-primary font-bold mb-2">Total Battery Capacity Required</p>
            <p class="text-muted">Daily Consumption (kWh) ÷ (DoD × Inverter Efficiency) = Required Battery Capacity (kWh)</p>
          </div>
        </FormulaBox>
