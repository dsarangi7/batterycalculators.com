---
import Layout from '../../layouts/Layout.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import FormulaBox from '../../components/FormulaBox.astro';
import FAQSection from '../../components/FAQSection.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const faqItems = [
  {
    question: "How long will a 300Ah battery run a house?",
    answer: "A 300Ah 48V LFP battery stores 15,360 Wh total, with 12,288 Wh usable at 80% DoD. For a home consuming 10 kWh/day, this provides approximately 1.1 days of autonomy. For essential loads only (2–3 kWh/day), it lasts 4–5 days.",
  },
  {
    question: "How long will a 300Ah 12V battery last camping?",
    answer: "At 12.8V, a 300Ah LFP battery provides 3,072 Wh usable at 80% DoD. For typical camping loads (fridge 50W, lights 24W, phone 15W = 89W), runtime is approximately 31 hours — enough for a 3-day camping trip without recharging.",
  },
  {
    question: "How many solar panels to charge a 300Ah battery?",
    answer: "A 300Ah 48V LFP battery stores 15,360 Wh. With 5 peak sun hours, you need approximately 3,072W of solar panels (before losses). A 3.5–4 kW array accounts for system losses and cloudy-day margin.",
  },
  {
    question: "Is a 300Ah battery good for home backup?",
    answer: "A 300Ah 48V LFP battery (15.36 kWh) provides excellent overnight backup for essential loads. It can power a fridge, router, lights, and medical devices for 12+ hours. For multi-day backup, consider parallel batteries or a larger bank.",
  },
];
---

<Layout
  title="How Long Will a 300Ah Battery Last? | Battery Calculators"
  description="Runtime examples for 300Ah batteries in home backup, RV, marine, and off-grid solar applications. Includes worked calculations and sizing guidance."
  canonical="https://batterycalculators.com/learn/how-long-will-a-300ah-battery-last"
  schema="faqPage"
  schemaName="How Long Will a 300Ah Battery Last"
  schemaDescription="Runtime examples for 300Ah batteries across common load scenarios."
  schemaUrl="https://batterycalculators.com/learn/how-long-will-a-300ah-battery-last"
  faqItems={faqItems}
>
  <div class="max-w-3xl mx-auto">
    <div class="mb-12 border-b border-hairline pb-8">
      <a href="/learn" class="text-label-uppercase text-xs text-muted hover:text-primary transition-colors mb-4 inline-block">← Back to Guides</a>
      <Breadcrumb items={[
        { label: "Learning Center", href: "/learn" },
        { label: "How Long Will a 300Ah Battery Last" }
      ]} />
      <span class="text-label-uppercase text-m-blue-light text-xs block mb-4">PRACTICAL EXAMPLES</span>
      <h1 class="text-display-md text-primary mb-6">How Long Will a 300Ah Battery Last?</h1>
      <p class="text-body-md text-body font-light">
        A 300Ah battery is a mid-range capacity commonly used in larger RV systems, small home backup, and off-grid cabins. At 48V, it provides over 15 kWh of total energy — enough for meaningful overnight home backup or multi-day camping.
      </p>
    </div>

    <div class="flex flex-col gap-12">
      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-4">Energy by Voltage</h2>
        <div class="bg-surface-soft border border-hairline overflow-hidden">
          <table class="w-full text-left text-body-sm">
            <thead>
              <tr class="border-b border-hairline bg-surface-card">
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Voltage</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Total Energy</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Usable (80% DoD)</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline">
              <tr>
                <td class="p-4 font-mono text-primary">12.8V</td>
                <td class="p-4 text-muted">3,840 Wh</td>
                <td class="p-4 font-mono text-primary">3,072 Wh</td>
              </tr>
              <tr>
                <td class="p-4 font-mono text-primary">25.6V</td>
                <td class="p-4 text-muted">7,680 Wh</td>
                <td class="p-4 font-mono text-primary">6,144 Wh</td>
              </tr>
              <tr>
                <td class="p-4 font-mono text-primary">51.2V</td>
                <td class="p-4 text-muted">15,360 Wh</td>
                <td class="p-4 font-mono text-primary">12,288 Wh</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <FormulaBox title="Runtime Formula">
        <div class="bg-surface-soft p-4 font-mono text-primary border border-hairline my-2">
          Runtime (h) = Capacity (Ah) × Voltage (V) × DoD / (Load (W) / Efficiency)
        </div>
      </FormulaBox>

      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-4">Runtime Table: 300Ah 48V LFP</h2>
        <p class="text-body-md text-body font-light mb-4">
          At 80% DoD and 92% efficiency, a 300Ah 48V LFP battery provides 12,288 Wh of usable energy:
        </p>
        <div class="bg-surface-soft border border-hairline overflow-hidden">
          <table class="w-full text-left text-body-sm">
            <thead>
              <tr class="border-b border-hairline bg-surface-card">
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Load</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Power (W)</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Runtime</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline">
              <tr>
                <td class="p-4 text-muted">Router + lights + phone</td>
                <td class="p-4 font-mono text-primary">50 W</td>
                <td class="p-4 font-mono text-primary">~226 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">Fridge + essentials</td>
                <td class="p-4 font-mono text-primary">150 W</td>
                <td class="p-4 font-mono text-primary">~75 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">TV + laptop + lights</td>
                <td class="p-4 font-mono text-primary">250 W</td>
                <td class="p-4 font-mono text-primary">~45 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">Small AC unit</td>
                <td class="p-4 font-mono text-primary">800 W</td>
                <td class="p-4 font-mono text-primary">~14 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">Electric kettle</td>
                <td class="p-4 font-mono text-primary">1,500 W</td>
                <td class="p-4 font-mono text-primary">~7.4 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">Microwave + fridge</td>
                <td class="p-4 font-mono text-primary">2,000 W</td>
                <td class="p-4 font-mono text-primary">~5.5 hours</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-4">Scenario: Home Backup</h2>
        <p class="text-body-md text-body font-light mb-4">
          For overnight home backup with essential loads:
        </p>
        <CalculatorCard>
          <div class="flex flex-col gap-4 text-body-sm text-muted">
            <p><strong>Given:</strong> 300 Ah at 48V LFP, 80% DoD, 92% efficiency</p>
            <p><strong>Loads:</strong> Fridge (60W) + router (10W) + 4 LED lights (24W) + phone (15W) + CPAP (30W) = 139W</p>
            <p><strong>Usable energy:</strong></p>
            <div class="font-mono text-primary pl-4 border-l-2 border-m-blue-light">
              300 × 48 × 0.80 = 11,520 Wh
            </div>
            <p><strong>Effective load:</strong></p>
            <div class="font-mono text-primary pl-4 border-l-2 border-m-blue-light">
              139 / 0.92 = 151 W
            </div>
            <p><strong>Runtime:</strong></p>
            <div class="font-mono text-primary pl-4 border-l-2 border-m-blue-light">
              11,520 / 151 = 76.3 hours ≈ 3.2 days
            </div>
          </div>
        </CalculatorCard>
      </section>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <CalculatorCard class="border-m-blue-light">
          <h4 class="text-label-uppercase text-primary text-xs mb-3">Try It</h4>
          <p class="text-body-sm text-muted mb-4">
            Use the Runtime Calculator for your specific configuration.
          </p>
          <a href="/tools/runtime-calculator" class="btn-primary text-xs py-3 px-6 inline-block">Open Runtime Calculator</a>
        </CalculatorCard>
        <CalculatorCard class="border-m-blue-light">
          <h4 class="text-label-uppercase text-primary text-xs mb-3">Related</h4>
          <p class="text-body-sm text-muted mb-4">
            Size a solar array to keep your 300Ah bank fully charged.
          </p>
          <a href="/tools/solar-battery-sizing-calculator" class="btn-primary-outline text-xs py-3 px-6 inline-block">Solar Sizing Calculator</a>
        </CalculatorCard>
      </div>

      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-4">Related Articles</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <CalculatorCard>
            <h4 class="text-primary font-bold mb-2">How Long Will a 200Ah Battery Last?</h4>
            <p class="text-body-sm text-muted mb-3">Runtime examples for 200Ah batteries across common loads.</p>
            <a href="/learn/how-long-will-a-200ah-battery-last" class="text-label-uppercase text-m-blue-light text-xs hover:text-primary transition-colors">Read Guide →</a>
          </CalculatorCard>
          <CalculatorCard>
            <h4 class="text-primary font-bold mb-2">How Long Will a Battery Last?</h4>
            <p class="text-body-sm text-muted mb-3">The general method for calculating runtime from capacity and load.</p>
            <a href="/learn/how-long-will-a-battery-last" class="text-label-uppercase text-m-blue-light text-xs hover:text-primary transition-colors">Read Guide →</a>
          </CalculatorCard>
        </div>
      </section>

      <FAQSection items={faqItems} />
    </div>
  </div>
</Layout>
