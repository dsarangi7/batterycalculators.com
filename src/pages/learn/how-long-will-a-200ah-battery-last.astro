---
import Layout from '../../layouts/Layout.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import FormulaBox from '../../components/FormulaBox.astro';
import FAQSection from '../../components/FAQSection.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const faqItems = [
  {
    question: "How long will a 200Ah battery run a fridge?",
    answer: "A typical 12V fridge draws 40–60W continuously (compressor cycling). A 200Ah 12.8V LFP battery at 80% DoD provides 2,048 Wh of usable energy. Divided by 50W at 90% efficiency, runtime is approximately 36 hours. Actual time varies with ambient temperature and how often the door is opened.",
  },
  {
    question: "How long will a 200Ah battery run a 1000W inverter?",
    answer: "At 1000W AC load with 90% inverter efficiency, the battery sees 1,111W. A 200Ah 12.8V LFP battery at 80% DoD provides 2,048 Wh. Runtime is approximately 1.84 hours, or about 1 hour 50 minutes.",
  },
  {
    question: "Is a 200Ah battery enough for camping?",
    answer: "For a weekend camping trip (2–3 days) with moderate loads (fridge, lights, phone charging), a 200Ah 12V LFP battery is usually sufficient. For extended off-grid stays or heavy loads (air conditioning, heating), you may need 400Ah or more.",
  },
  {
    question: "Does voltage matter when comparing 200Ah batteries?",
    answer: "Yes. A 200Ah battery at 12.8V stores 2,560 Wh. The same 200Ah at 25.6V stores 5,120 Wh — double the energy. Always compare total energy (Wh), not just Ah, when evaluating batteries.",
  },
];
---

<Layout
  title="How Long Will a 200Ah Battery Last? | Battery Calculators"
  description="Practical runtime examples for 200Ah batteries powering common loads. Includes worked calculations for RV, marine, solar, and home backup applications."
  canonical="https://batterycalculators.com/learn/how-long-will-a-200ah-battery-last"
  schema="faqPage"
  schemaName="How Long Will a 200Ah Battery Last"
  schemaDescription="Practical runtime examples for 200Ah batteries across common load scenarios."
  schemaUrl="https://batterycalculators.com/learn/how-long-will-a-200ah-battery-last"
  faqItems={faqItems}
>
  <div class="max-w-3xl mx-auto">
    <div class="mb-12 border-b border-hairline pb-8">
      <a href="/learn" class="text-label-uppercase text-xs text-muted hover:text-primary transition-colors mb-4 inline-block">← Back to Guides</a>
      <Breadcrumb items={[
        { label: "Learning Center", href: "/learn" },
        { label: "How Long Will a 200Ah Battery Last" }
      ]} />
      <span class="text-label-uppercase text-m-blue-light text-xs block mb-4">PRACTICAL EXAMPLES</span>
      <h1 class="text-display-md text-primary mb-6">How Long Will a 200Ah Battery Last?</h1>
      <p class="text-body-md text-body font-light">
        A 200Ah battery is one of the most popular sizes for RV, marine, solar, and home backup applications. Understanding its real-world runtime under different loads helps you plan power systems that actually meet your needs.
      </p>
    </div>

    <div class="flex flex-col gap-12">
      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-4">Total Energy vs. Capacity</h2>
        <p class="text-body-md text-body font-light mb-4">
          "200Ah" describes charge capacity, but runtime depends on total energy, which also requires knowing the voltage. A 200Ah battery at different voltages stores vastly different amounts of energy:
        </p>
        <div class="bg-surface-soft border border-hairline overflow-hidden">
          <table class="w-full text-left text-body-sm">
            <thead>
              <tr class="border-b border-hairline bg-surface-card">
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Voltage</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Total Energy</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Usable (80% DoD)</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline">
              <tr>
                <td class="p-4 font-mono text-primary">12.8V (4S LFP)</td>
                <td class="p-4 text-muted">2,560 Wh</td>
                <td class="p-4 font-mono text-primary">2,048 Wh</td>
              </tr>
              <tr>
                <td class="p-4 font-mono text-primary">25.6V (8S LFP)</td>
                <td class="p-4 text-muted">5,120 Wh</td>
                <td class="p-4 font-mono text-primary">4,096 Wh</td>
              </tr>
              <tr>
                <td class="p-4 font-mono text-primary">51.2V (16S LFP)</td>
                <td class="p-4 text-muted">10,240 Wh</td>
                <td class="p-4 font-mono text-primary">8,192 Wh</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-body-md text-body font-light mt-4">
          This is why comparing batteries by Ah alone is misleading. A 200Ah 48V battery stores four times the energy of a 200Ah 12V battery, even though the Ah rating is identical.
        </p>
      </section>

      <FormulaBox title="Runtime Formula">
        <div class="bg-surface-soft p-4 font-mono text-primary border border-hairline my-2">
          Runtime (h) = Capacity (Ah) × Voltage (V) × DoD / (Load (W) / Efficiency)
        </div>
        <p>
          For all examples below, we assume LFP chemistry at 80% DoD and 90% system efficiency unless stated otherwise.
        </p>
      </FormulaBox>

      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-6">Worked Example: Common Loads</h2>
        <CalculatorCard>
          <div class="flex flex-col gap-4 text-body-sm text-muted">
            <p><strong>Given:</strong> 200 Ah at 12.8V LFP battery, 80% DoD, 90% efficiency</p>
            <p><strong>Usable energy:</strong></p>
            <div class="font-mono text-primary pl-4 border-l-2 border-m-blue-light">
              200 Ah × 12.8V × 0.80 = 2,048 Wh
            </div>
            <p class="mt-2"><strong>Effective load with efficiency correction:</strong></p>
            <div class="font-mono text-primary pl-4 border-l-2 border-m-blue-light">
              Effective Load = Load (W) / 0.90
            </div>
          </div>
        </CalculatorCard>
      </section>

      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-4">Runtime Table: 200Ah 12.8V LFP</h2>
        <p class="text-body-md text-body font-light mb-4">
          This table shows runtime for typical loads you might encounter in RV, marine, or home backup scenarios.
        </p>
        <div class="bg-surface-soft border border-hairline overflow-hidden">
          <table class="w-full text-left text-body-sm">
            <thead>
              <tr class="border-b border-hairline bg-surface-card">
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Load</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Power (W)</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Runtime</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline">
              <tr>
                <td class="p-4 text-muted">Phone charging (×3)</td>
                <td class="p-4 font-mono text-primary">15 W</td>
                <td class="p-4 font-mono text-primary">~121 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">LED lights (×4)</td>
                <td class="p-4 font-mono text-primary">24 W</td>
                <td class="p-4 font-mono text-primary">~76 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">Laptop</td>
                <td class="p-4 font-mono text-primary">60 W</td>
                <td class="p-4 font-mono text-primary">~30 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">12V camping fridge</td>
                <td class="p-4 font-mono text-primary">50 W</td>
                <td class="p-4 font-mono text-primary">~36 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">TV + streaming stick</td>
                <td class="p-4 font-mono text-primary">100 W</td>
                <td class="p-4 font-mono text-primary">~18 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">Coffee maker</td>
                <td class="p-4 font-mono text-primary">800 W</td>
                <td class="p-4 font-mono text-primary">~2.3 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">Microwave</td>
                <td class="p-4 font-mono text-primary">1,000 W</td>
                <td class="p-4 font-mono text-primary">~1.8 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">Space heater</td>
                <td class="p-4 font-mono text-primary">1,500 W</td>
                <td class="p-4 font-mono text-primary">~1.2 hours</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-4">Scenario: Weekend RV Camping</h2>
        <p class="text-body-md text-body font-light mb-4">
          A typical weekend camping trip (2 nights, 3 days) with the following loads:
        </p>
        <div class="bg-surface-soft border border-hairline overflow-hidden mb-4">
          <table class="w-full text-left text-body-sm">
            <thead>
              <tr class="border-b border-hairline bg-surface-card">
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Appliance</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Daily Use</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Energy (Wh)</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline">
              <tr>
                <td class="p-4 text-muted">12V fridge (24h)</td>
                <td class="p-4 text-muted">Continuous</td>
                <td class="p-4 font-mono text-primary">600 Wh</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">LED lights (5h)</td>
                <td class="p-4 text-muted">5 hours</td>
                <td class="p-4 font-mono text-primary">30 Wh</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">Phone + tablet</td>
                <td class="p-4 text-muted">2 hours</td>
                <td class="p-4 font-mono text-primary">30 Wh</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">Water pump (10 min)</td>
                <td class="p-4 text-muted">3× daily</td>
                <td class="p-4 font-mono text-primary">50 Wh</td>
              </tr>
              <tr class="bg-surface-card">
                <td class="p-4 font-bold text-primary">Daily Total</td>
                <td></td>
                <td class="p-4 font-mono font-bold text-primary">710 Wh</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-body-md text-body font-light">
          With 2,048 Wh of usable energy from a 200Ah 12.8V LFP battery, this camping setup runs for approximately <strong class="text-primary">2.9 days</strong> — covering a full weekend trip without recharging. If you have solar panels, even a small 100W panel in good sun can replenish 400–500 Wh per day, extending the trip indefinitely.
        </p>
      </section>

      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-4">Scenario: Home Backup</h2>
        <p class="text-body-md text-body font-light mb-4">
          For home backup during a power outage, prioritizing critical loads only:
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <CalculatorCard>
            <h4 class="text-primary font-bold mb-2">Essential Loads Only</h4>
            <p class="text-body-sm text-muted mb-3">
              Router (10W) + fridge (50W) + 4 LED lights (24W) + phone charging (15W) = ~99W
            </p>
            <p class="text-body-sm text-muted">
              Runtime: <strong class="text-primary">~18.6 hours</strong> — enough for overnight coverage.
            </p>
          </CalculatorCard>
          <CalculatorCard>
            <h4 class="text-primary font-bold mb-2">Essentials + Medical Device</h4>
            <p class="text-body-sm text-muted mb-3">
              Add CPAP machine (30W) to essential loads = ~129W
            </p>
            <p class="text-body-sm text-muted">
              Runtime: <strong class="text-primary">~14.2 hours</strong> — still covers a full night plus morning.
            </p>
          </CalculatorCard>
        </div>
      </section>

      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-4">Chemistry Comparison</h2>
        <p class="text-body-md text-body font-light mb-4">
          The runtime of a 200Ah battery varies significantly with chemistry. Lead-acid batteries have lower usable DoD and suffer the Peukert effect at higher loads:
        </p>
        <div class="bg-surface-soft border border-hairline overflow-hidden">
          <table class="w-full text-left text-body-sm">
            <thead>
              <tr class="border-b border-hairline bg-surface-card">
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Chemistry</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Usable DoD</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Usable Energy</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Runtime at 100W</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline">
              <tr>
                <td class="p-4 font-mono text-primary">LFP (LiFePO4)</td>
                <td class="p-4 text-muted">80%</td>
                <td class="p-4 font-mono text-primary">2,048 Wh</td>
                <td class="p-4 text-muted">~18.4 hrs</td>
              </tr>
              <tr>
                <td class="p-4 font-mono text-primary">NMC (Lithium)</td>
                <td class="p-4 text-muted">80%</td>
                <td class="p-4 font-mono text-primary">2,048 Wh</td>
                <td class="p-4 text-muted">~18.4 hrs</td>
              </tr>
              <tr>
                <td class="p-4 font-mono text-primary">AGM Lead-Acid</td>
                <td class="p-4 text-muted">50%</td>
                <td class="p-4 font-mono text-primary">1,280 Wh</td>
                <td class="p-4 text-muted">~11.5 hrs</td>
              </tr>
              <tr>
                <td class="p-4 font-mono text-primary">Flooded Lead-Acid</td>
                <td class="p-4 text-muted">50%</td>
                <td class="p-4 font-mono text-primary">1,280 Wh</td>
                <td class="p-4 text-muted">~10.2 hrs*</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-caption text-muted mt-2">
          * Flooded lead-acid runtime is lower due to the Peukert effect reducing usable capacity at moderate discharge rates.
        </p>
      </section>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <CalculatorCard class="border-m-blue-light">
          <h4 class="text-label-uppercase text-primary text-xs mb-3">Try It</h4>
          <p class="text-body-sm text-muted mb-4">
            Use the Runtime Calculator to estimate discharge duration for your specific loads and battery configuration.
          </p>
          <a href="/tools/runtime-calculator" class="btn-primary text-xs py-3 px-6 inline-block">Open Runtime Calculator</a>
        </CalculatorCard>
        <CalculatorCard class="border-m-blue-light">
          <h4 class="text-label-uppercase text-primary text-xs mb-3">Related</h4>
          <p class="text-body-sm text-muted mb-4">
            Size your solar battery bank to ensure your 200Ah bank recharges properly.
          </p>
          <a href="/tools/solar-battery-sizing-calculator" class="btn-primary-outline text-xs py-3 px-6 inline-block">Open Solar Sizing Calculator</a>
        </CalculatorCard>
      </div>

      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-4">Related Articles</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <CalculatorCard>
            <h4 class="text-primary font-bold mb-2">How Long Will a Battery Last?</h4>
            <p class="text-body-sm text-muted mb-3">
              The general method for calculating battery runtime from any capacity and load.
            </p>
            <a href="/learn/how-long-will-a-battery-last" class="text-label-uppercase text-m-blue-light text-xs hover:text-primary transition-colors">Read Guide →</a>
          </CalculatorCard>
          <CalculatorCard>
            <h4 class="text-primary font-bold mb-2">How to Size a Solar Battery Bank</h4>
            <p class="text-body-sm text-muted mb-3">
              Match your solar storage capacity to daily consumption and autonomy needs.
            </p>
            <a href="/learn/how-to-size-solar-battery-bank" class="text-label-uppercase text-m-blue-light text-xs hover:text-primary transition-colors">Read Guide →</a>
          </CalculatorCard>
        </div>
      </section>

      <FAQSection items={faqItems} />
    </div>
  </div>
</Layout>
