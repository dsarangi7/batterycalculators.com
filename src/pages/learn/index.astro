<Layout
  title="Engineering Guides | Battery Calculators"
  description="Practical engineering guides covering battery fundamentals, system sizing, solar storage, RV and marine batteries, and BESS financial analysis."
>
  <div class="mb-12 border-b border-hairline pb-8">
    <span class="text-label-uppercase text-m-blue-light text-xs block mb-4">LEARNING CENTER</span>
    <h1 class="text-display-md text-primary mb-6">Engineering Guides</h1>
    <p class="text-body-md text-body max-w-2xl font-light">
      Practical explanations of core electrical engineering concepts. Each guide links to the relevant calculator so you can apply the formulas directly.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">
    {articles.map((article) => (
      <a href={`/learn/${article.slug}`} class="block group">
        <CalculatorCard class="h-full flex flex-col justify-between">
          <div>
            <span class="text-label-uppercase text-m-blue-light text-[10px] block mb-2">{article.category}</span>
            <h2 class="text-title-lg text-primary mb-3 group-hover:text-m-blue-light transition-colors">{article.title}</h2>
            <p class="text-body-sm text-muted mb-4">{article.description}</p>
          </div>
          <div class="flex flex-wrap gap-2">
            {article.tools.map((tool) => (
              <span class="text-[10px] text-primary border border-hairline px-2 py-0.5 uppercase tracking-wider">{tool}</span>
            ))}
          </div>
        </CalculatorCard>
      </a>
    ))}
  </div>
</Layout>
