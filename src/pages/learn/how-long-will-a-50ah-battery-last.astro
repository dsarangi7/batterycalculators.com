---
import Layout from '../../layouts/Layout.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import FormulaBox from '../../components/FormulaBox.astro';
import FAQSection from '../../components/FAQSection.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const faqItems = [
  {
    question: "How long will a 50Ah battery run a fridge?",
    answer: "A typical 12V fridge draws 40–60W continuously (compressor cycling). A 50Ah 12.8V LFP battery at 80% DoD provides 512 Wh of usable energy. Divided by 50W at 90% efficiency, runtime is approximately 9.2 hours. A 50Ah battery is generally too small to run a fridge overnight without recharging.",
  },
  {
    question: "How long will a 50Ah battery run a 1000W inverter?",
    answer: "At 1000W AC load with 90% inverter efficiency, the battery sees 1,111W. A 50Ah 12.8V LFP battery at 80% DoD provides 512 Wh. Runtime is approximately 0.46 hours, or about 28 minutes. A 50Ah battery is not recommended for high-draw appliances.",
  },
  {
    question: "Is a 50Ah battery enough for camping?",
    answer: "For a weekend camping trip with minimal loads — LED lights, phone charging, and small USB devices — a 50Ah 12V LFP battery is usually sufficient. If you need to run a fridge or larger appliances, consider upgrading to 100Ah or more.",
  },
  {
    question: "Can I use a 50Ah battery for emergency home backup?",
    answer: "A 50Ah 12.8V LFP battery can power essential small devices — router, a few LED lights, and phone charging — for roughly 19 hours. It is not large enough for medical devices, refrigeration, or extended outages. For meaningful home backup, consider 200Ah or larger.",
  },
];
---

<Layout
  title="How Long Will a 50Ah Battery Last? | Battery Calculators"
  description="Practical runtime examples for 50Ah batteries powering common loads. Includes worked calculations for camping, emergency, and small electronics applications."
  canonical="https://batterycalculators.com/learn/how-long-will-a-50ah-battery-last"
  schema="faqPage"
  schemaName="How Long Will a 50Ah Battery Last"
  schemaDescription="Practical runtime examples for 50Ah batteries across common load scenarios."
  schemaUrl="https://batterycalculators.com/learn/how-long-will-a-50ah-battery-last"
  faqItems={faqItems}
>
  <div class="max-w-3xl mx-auto">
    <div class="mb-12 border-b border-hairline pb-8">
      <a href="/learn" class="text-label-uppercase text-xs text-muted hover:text-primary transition-colors mb-4 inline-block">← Back to Guides</a>
      <Breadcrumb items={[
        { label: "Learning Center", href: "/learn" },
        { label: "How Long Will a 50Ah Battery Last" }
      ]} />
      <span class="text-label-uppercase text-m-blue-light text-xs block mb-4">PRACTICAL EXAMPLES</span>
      <h1 class="text-display-md text-primary mb-6">How Long Will a 50Ah Battery Last?</h1>
      <p class="text-body-md text-body font-light">
        A 50Ah battery is a compact, lightweight option ideal for small electronics, emergency kits, and fish finders. Understanding its real-world runtime helps you avoid undersizing your power system — or overspending on capacity you don't need.
      </p>
    </div>

    <div class="flex flex-col gap-12">
      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-4">Total Energy vs. Capacity</h2>
        <p class="text-body-md text-body font-light mb-4">
          "50Ah" describes charge capacity, but runtime depends on total energy, which also requires knowing the voltage. A 50Ah battery at different voltages stores vastly different amounts of energy:
        </p>
        <div class="bg-surface-soft border border-hairline overflow-hidden">
          <table class="w-full text-left text-body-sm">
            <thead>
              <tr class="border-b border-hairline bg-surface-card">
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Voltage</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Total Energy</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Usable (80% DoD)</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline">
              <tr>
                <td class="p-4 font-mono text-primary">12.8V (4S LFP)</td>
                <td class="p-4 text-muted">640 Wh</td>
                <td class="p-4 font-mono text-primary">512 Wh</td>
              </tr>
              <tr>
                <td class="p-4 font-mono text-primary">25.6V (8S LFP)</td>
                <td class="p-4 text-muted">1,280 Wh</td>
                <td class="p-4 font-mono text-primary">1,024 Wh</td>
              </tr>
              <tr>
                <td class="p-4 font-mono text-primary">51.2V (16S LFP)</td>
                <td class="p-4 text-muted">2,560 Wh</td>
                <td class="p-4 font-mono text-primary">2,048 Wh</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-body-md text-body font-light mt-4">
          This is why comparing batteries by Ah alone is misleading. A 50Ah 48V battery stores four times the energy of a 50Ah 12V battery, even though the Ah rating is identical.
        </p>
      </section>

      <FormulaBox title="Runtime Formula">
        <div class="bg-surface-soft p-4 font-mono text-primary border border-hairline my-2">
          Runtime (h) = Capacity (Ah) × Voltage (V) × DoD / (Load (W) / Efficiency)
        </div>
        <p>
          For all examples below, we assume LFP chemistry at 80% DoD and 90% system efficiency unless stated otherwise.
        </p>
      </FormulaBox>

      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-6">Worked Example: Common Loads</h2>
        <CalculatorCard>
          <div class="flex flex-col gap-4 text-body-sm text-muted">
            <p><strong>Given:</strong> 50 Ah at 12.8V LFP battery, 80% DoD, 90% efficiency</p>
            <p><strong>Usable energy:</strong></p>
            <div class="font-mono text-primary pl-4 border-l-2 border-m-blue-light">
              50 Ah × 12.8V × 0.80 = 512 Wh
            </div>
            <p class="mt-2"><strong>Effective load with efficiency correction:</strong></p>
            <div class="font-mono text-primary pl-4 border-l-2 border-m-blue-light">
              Effective Load = Load (W) / 0.90
            </div>
          </div>
        </CalculatorCard>
      </section>

      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-4">Runtime Table: 50Ah 12.8V LFP</h2>
        <p class="text-body-md text-body font-light mb-4">
          This table shows runtime for typical loads you might encounter in camping, marine, or small electronics scenarios.
        </p>
        <div class="bg-surface-soft border border-hairline overflow-hidden">
          <table class="w-full text-left text-body-sm">
            <thead>
              <tr class="border-b border-hairline bg-surface-card">
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Load</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Power (W)</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Runtime</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline">
              <tr>
                <td class="p-4 text-muted">Phone charging (×3)</td>
                <td class="p-4 font-mono text-primary">15 W</td>
                <td class="p-4 font-mono text-primary">~31 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">LED lights (×4)</td>
                <td class="p-4 font-mono text-primary">24 W</td>
                <td class="p-4 font-mono text-primary">~19 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">Fish finder</td>
                <td class="p-4 font-mono text-primary">20 W</td>
                <td class="p-4 font-mono text-primary">~23 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">Laptop</td>
                <td class="p-4 font-mono text-primary">60 W</td>
                <td class="p-4 font-mono text-primary">~7.7 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">12V camping fridge</td>
                <td class="p-4 font-mono text-primary">50 W</td>
                <td class="p-4 font-mono text-primary">~9.2 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">TV + streaming stick</td>
                <td class="p-4 font-mono text-primary">100 W</td>
                <td class="p-4 font-mono text-primary">~4.6 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">Coffee maker</td>
                <td class="p-4 font-mono text-primary">800 W</td>
                <td class="p-4 font-mono text-primary">~0.6 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">Space heater</td>
                <td class="p-4 font-mono text-primary">1,500 W</td>
                <td class="p-4 font-mono text-primary">~0.3 hours</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-4">Scenario: Weekend Camping with Minimal Loads</h2>
        <p class="text-body-md text-body font-light mb-4">
          A short camping trip (1–2 nights) with light power needs — no fridge, just essentials:
        </p>
        <div class="bg-surface-soft border border-hairline overflow-hidden mb-4">
          <table class="w-full text-left text-body-sm">
            <thead>
              <tr class="border-b border-hairline bg-surface-card">
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Appliance</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Daily Use</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Energy (Wh)</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline">
              <tr>
                <td class="p-4 text-muted">LED lights (5h)</td>
                <td class="p-4 text-muted">5 hours</td>
                <td class="p-4 font-mono text-primary">30 Wh</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">Phone + tablet</td>
                <td class="p-4 text-muted">2 hours</td>
                <td class="p-4 font-mono text-primary">30 Wh</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">Small USB fan (4h)</td>
                <td class="p-4 text-muted">4 hours</td>
                <td class="p-4 font-mono text-primary">20 Wh</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">Emergency radio (2h)</td>
                <td class="p-4 text-muted">2 hours</td>
                <td class="p-4 font-mono text-primary">4 Wh</td>
              </tr>
              <tr class="bg-surface-card">
                <td class="p-4 font-bold text-primary">Daily Total</td>
                <td></td>
                <td class="p-4 font-mono font-bold text-primary">84 Wh</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-body-md text-body font-light">
          With 512 Wh of usable energy from a 50Ah 12.8V LFP battery, this minimal camping setup runs for approximately <strong class="text-primary">6.1 days</strong> — easily covering a weekend trip. However, adding a fridge (600 Wh/day) would drain the battery in less than a day, so a 50Ah pack is best suited for light-duty use.
        </p>
      </section>

      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-4">Scenario: Emergency Kit Power</h2>
        <p class="text-body-md text-body font-light mb-4">
          For a home emergency kit during a short power outage, keeping critical small devices running:
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <CalculatorCard>
            <h4 class="text-primary font-bold mb-2">Communication Only</h4>
            <p class="text-body-sm text-muted mb-3">
              Router (10W) + phone charging (15W) + emergency radio (2W) = ~27W
            </p>
            <p class="text-body-sm text-muted">
              Runtime: <strong class="text-primary">~17 hours</strong> — enough for overnight internet and morning updates.
            </p>
          </CalculatorCard>
          <CalculatorCard>
            <h4 class="text-primary font-bold mb-2">Communication + Lighting</h4>
            <p class="text-body-sm text-muted mb-3">
              Add 4 LED lights (24W) to communication loads = ~51W
            </p>
            <p class="text-body-sm text-muted">
              Runtime: <strong class="text-primary">~9 hours</strong> — covers one full night of light and connectivity.
            </p>
          </CalculatorCard>
        </div>
      </section>

      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-4">Chemistry Comparison</h2>
        <p class="text-body-md text-body font-light mb-4">
          The runtime of a 50Ah battery varies significantly with chemistry. Lead-acid batteries have lower usable DoD and suffer the Peukert effect at higher loads:
        </p>
        <div class="bg-surface-soft border border-hairline overflow-hidden">
          <table class="w-full text-left text-body-sm">
            <thead>
              <tr class="border-b border-hairline bg-surface-card">
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Chemistry</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Usable DoD</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Usable Energy</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Runtime at 100W</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline">
              <tr>
                <td class="p-4 font-mono text-primary">LFP (LiFePO4)</td>
                <td class="p-4 text-muted">80%</td>
                <td class="p-4 font-mono text-primary">512 Wh</td>
                <td class="p-4 text-muted">~4.6 hrs</td>
              </tr>
              <tr>
                <td class="p-4 font-mono text-primary">NMC (Lithium)</td>
                <td class="p-4 text-muted">80%</td>
                <td class="p-4 font-mono text-primary">512 Wh</td>
                <td class="p-4 text-muted">~4.6 hrs</td>
              </tr>
              <tr>
                <td class="p-4 font-mono text-primary">AGM Lead-Acid</td>
                <td class="p-4 text-muted">50%</td>
                <td class="p-4 font-mono text-primary">320 Wh</td>
                <td class="p-4 text-muted">~2.9 hrs</td>
              </tr>
              <tr>
                <td class="p-4 font-mono text-primary">Flooded Lead-Acid</td>
                <td class="p-4 text-muted">50%</td>
                <td class="p-4 font-mono text-primary">320 Wh</td>
                <td class="p-4 text-muted">~2.5 hrs*</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-caption text-muted mt-2">
          * Flooded lead-acid runtime is lower due to the Peukert effect reducing usable capacity at moderate discharge rates.
        </p>
      </section>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <CalculatorCard class="border-m-blue-light">
          <h4 class="text-label-uppercase text-primary text-xs mb-3">Try It</h4>
          <p class="text-body-sm text-muted mb-4">
            Use the Runtime Calculator to estimate discharge duration for your specific loads and battery configuration.
          </p>
          <a href="/tools/runtime-calculator" class="btn-primary text-xs py-3 px-6 inline-block">Open Runtime Calculator</a>
        </CalculatorCard>
        <CalculatorCard class="border-m-blue-light">
          <h4 class="text-label-uppercase text-primary text-xs mb-3">Related</h4>
          <p class="text-body-sm text-muted mb-4">
            Compare 50Ah with larger capacities to find the right fit for your application.
          </p>
          <a href="/learn/how-long-will-a-100ah-battery-last" class="btn-primary-outline text-xs py-3 px-6 inline-block">100Ah Runtime Guide</a>
        </CalculatorCard>
      </div>

      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-4">Related Articles</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <CalculatorCard>
            <h4 class="text-primary font-bold mb-2">How Long Will a Battery Last?</h4>
            <p class="text-body-sm text-muted mb-3">
              The general method for calculating battery runtime from any capacity and load.
            </p>
            <a href="/learn/how-long-will-a-battery-last" class="text-label-uppercase text-m-blue-light text-xs hover:text-primary transition-colors">Read Guide →</a>
          </CalculatorCard>
          <CalculatorCard>
            <h4 class="text-primary font-bold mb-2">How Long Will a 100Ah Battery Last?</h4>
            <p class="text-body-sm text-muted mb-3">
              Double the capacity — see how 100Ah performs for weekend camping and small RV setups.
            </p>
            <a href="/learn/how-long-will-a-100ah-battery-last" class="text-label-uppercase text-m-blue-light text-xs hover:text-primary transition-colors">Read Guide →</a>
          </CalculatorCard>
        </div>
      </section>

      <FAQSection items={faqItems} />
    </div>
  </div>
</Layout>
