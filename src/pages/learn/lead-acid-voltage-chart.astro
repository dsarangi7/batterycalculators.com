            { x: 30, y: 11.88, label: "30%" },
            { x: 40, y: 12.0, label: "40%" },
            { x: 50, y: 12.12, label: "50%" },
            { x: 60, y: 12.24, label: "60%" },
            { x: 70, y: 12.34, label: "70%" },
            { x: 80, y: 12.46, label: "80%" },
