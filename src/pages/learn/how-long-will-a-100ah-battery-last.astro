---
import Layout from '../../layouts/Layout.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import FormulaBox from '../../components/FormulaBox.astro';
import FAQSection from '../../components/FAQSection.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const faqItems = [
  {
    question: "How long will a 100Ah battery run a 1000W inverter?",
    answer: "A 100Ah 12.8V LFP battery at 80% DoD provides 1,024 Wh of usable energy. Through a 90% efficient inverter, the effective load is 1,111W. Runtime is approximately 0.92 hours, or about 55 minutes.",
  },
  {
    question: "How long will a 100Ah lead-acid battery last?",
    answer: "Lead-acid batteries have lower usable capacity (50% DoD) and suffer the Peukert effect at higher loads. A 100Ah AGM battery at 50% DoD provides only 640 Wh usable. At 100W, runtime is about 5.8 hours — roughly half that of a comparable LFP battery.",
  },
  {
    question: "How many solar panels to recharge a 100Ah battery?",
    answer: "A 100Ah 12.8V LFP battery stores 1,280 Wh. A 200W solar panel in 5 peak sun hours generates about 900 Wh (accounting for losses). You need approximately two 200W panels or one 300W panel to fully recharge in one day.",
  },
  {
    question: "Can a 100Ah battery run a refrigerator?",
    answer: "A typical 12V camping fridge draws 40–60W average (compressor cycles). A 100Ah LFP battery at 80% DoD provides 1,024 Wh. At 50W average, runtime is about 16.4 hours. For a full-size residential fridge (150W average), runtime drops to about 5.5 hours.",
  },
];
---

<Layout
  title="How Long Will a 100Ah Battery Last? | Battery Calculators"
  description="Detailed runtime examples for 100Ah batteries at 12V, 24V, and 48V. Covers LFP, NMC, and lead-acid chemistries with worked calculations for RV, marine, and home backup."
  canonical="https://batterycalculators.com/learn/how-long-will-a-100ah-battery-last"
  schema="faqPage"
  schemaName="How Long Will a 100Ah Battery Last"
  schemaDescription="Runtime examples for 100Ah batteries across common load scenarios."
  schemaUrl="https://batterycalculators.com/learn/how-long-will-a-100ah-battery-last"
  faqItems={faqItems}
>
  <div class="max-w-3xl mx-auto">
    <div class="mb-12 border-b border-hairline pb-8">
      <a href="/learn" class="text-label-uppercase text-xs text-muted hover:text-primary transition-colors mb-4 inline-block">← Back to Guides</a>
      <Breadcrumb items={[
        { label: "Learning Center", href: "/learn" },
        { label: "How Long Will a 100Ah Battery Last" }
      ]} />
      <span class="text-label-uppercase text-m-blue-light text-xs block mb-4">PRACTICAL EXAMPLES</span>
      <h1 class="text-display-md text-primary mb-6">How Long Will a 100Ah Battery Last?</h1>
      <p class="text-body-md text-body font-light">
        A 100Ah battery is one of the most common sizes for portable power, RV house systems, marine applications, and small solar setups. Understanding its real-world runtime helps you plan systems that actually meet your needs.
      </p>
    </div>

    <div class="flex flex-col gap-12">
      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-4">Energy by Voltage</h2>
        <p class="text-body-md text-body font-light mb-4">
          A 100Ah rating tells you charge capacity, but energy depends on voltage. The same 100Ah rating at different voltages stores vastly different amounts of energy:
        </p>
        <div class="bg-surface-soft border border-hairline overflow-hidden">
          <table class="w-full text-left text-body-sm">
            <thead>
              <tr class="border-b border-hairline bg-surface-card">
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Voltage</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Total Energy</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Usable (80% DoD)</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline">
              <tr>
                <td class="p-4 font-mono text-primary">12.8V (4S LFP)</td>
                <td class="p-4 text-muted">1,280 Wh</td>
                <td class="p-4 font-mono text-primary">1,024 Wh</td>
              </tr>
              <tr>
                <td class="p-4 font-mono text-primary">25.6V (8S LFP)</td>
                <td class="p-4 text-muted">2,560 Wh</td>
                <td class="p-4 font-mono text-primary">2,048 Wh</td>
              </tr>
              <tr>
                <td class="p-4 font-mono text-primary">51.2V (16S LFP)</td>
                <td class="p-4 text-muted">5,120 Wh</td>
                <td class="p-4 font-mono text-primary">4,096 Wh</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <FormulaBox title="Runtime Formula">
        <div class="bg-surface-soft p-4 font-mono text-primary border border-hairline my-2">
          Runtime (h) = Capacity (Ah) × Voltage (V) × DoD / (Load (W) / Efficiency)
        </div>
      </FormulaBox>

      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-4">Runtime Table: 100Ah 12.8V LFP</h2>
        <p class="text-body-md text-body font-light mb-4">
          At 80% DoD and 90% system efficiency, a 100Ah 12.8V LFP battery provides 1,024 Wh of usable energy:
        </p>
        <div class="bg-surface-soft border border-hairline overflow-hidden">
          <table class="w-full text-left text-body-sm">
            <thead>
              <tr class="border-b border-hairline bg-surface-card">
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Load</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Power (W)</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Runtime</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline">
              <tr>
                <td class="p-4 text-muted">Phone charging</td>
                <td class="p-4 font-mono text-primary">15 W</td>
                <td class="p-4 font-mono text-primary">~60 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">LED lights (×4)</td>
                <td class="p-4 font-mono text-primary">24 W</td>
                <td class="p-4 font-mono text-primary">~38 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">Laptop</td>
                <td class="p-4 font-mono text-primary">60 W</td>
                <td class="p-4 font-mono text-primary">~15 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">12V camping fridge</td>
                <td class="p-4 font-mono text-primary">50 W</td>
                <td class="p-4 font-mono text-primary">~18 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">TV + streaming</td>
                <td class="p-4 font-mono text-primary">100 W</td>
                <td class="p-4 font-mono text-primary">~9.1 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">Coffee maker</td>
                <td class="p-4 font-mono text-primary">800 W</td>
                <td class="p-4 font-mono text-primary">~1.1 hours</td>
              </tr>
              <tr>
                <td class="p-4 text-muted">Space heater</td>
                <td class="p-4 font-mono text-primary">1,500 W</td>
                <td class="p-4 font-mono text-primary">~36 minutes</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-4">Chemistry Comparison</h2>
        <div class="bg-surface-soft border border-hairline overflow-hidden">
          <table class="w-full text-left text-body-sm">
            <thead>
              <tr class="border-b border-hairline bg-surface-card">
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Chemistry</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Usable DoD</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Usable Energy</th>
                <th class="p-4 text-label-uppercase text-primary text-xs tracking-wider">Runtime at 100W</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline">
              <tr>
                <td class="p-4 font-mono text-primary">LFP (LiFePO4)</td>
                <td class="p-4 text-muted">80%</td>
                <td class="p-4 font-mono text-primary">1,024 Wh</td>
                <td class="p-4 text-muted">~9.2 hrs</td>
              </tr>
              <tr>
                <td class="p-4 font-mono text-primary">NMC (Lithium)</td>
                <td class="p-4 text-muted">80%</td>
                <td class="p-4 font-mono text-primary">1,024 Wh</td>
                <td class="p-4 text-muted">~9.2 hrs</td>
              </tr>
              <tr>
                <td class="p-4 font-mono text-primary">AGM Lead-Acid</td>
                <td class="p-4 text-muted">50%</td>
                <td class="p-4 font-mono text-primary">640 Wh</td>
                <td class="p-4 text-muted">~5.8 hrs</td>
              </tr>
              <tr>
                <td class="p-4 font-mono text-primary">Flooded Lead-Acid</td>
                <td class="p-4 text-muted">50%</td>
                <td class="p-4 font-mono text-primary">640 Wh</td>
                <td class="p-4 text-muted">~5.0 hrs*</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-caption text-muted mt-2">* Flooded lead-acid runtime is lower due to Peukert effect at moderate discharge rates.</p>
      </section>

      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-6">Worked Example</h2>
        <CalculatorCard>
          <div class="flex flex-col gap-4 text-body-sm text-muted">
            <p><strong>Given:</strong> 100 Ah at 12.8V LFP, 80% DoD, 90% efficiency, 150W AC load</p>
            <p><strong>Step 1:</strong> Usable energy:</p>
            <div class="font-mono text-primary pl-4 border-l-2 border-m-blue-light">
              100 × 12.8 × 0.80 = 1,024 Wh
            </div>
            <p><strong>Step 2:</strong> Effective load:</p>
            <div class="font-mono text-primary pl-4 border-l-2 border-m-blue-light">
              150 / 0.90 = 166.7 W
            </div>
            <p><strong>Step 3:</strong> Runtime:</p>
            <div class="font-mono text-primary pl-4 border-l-2 border-m-blue-light">
              1,024 / 166.7 = 6.14 hours
            </div>
          </div>
        </CalculatorCard>
      </section>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <CalculatorCard class="border-m-blue-light">
          <h4 class="text-label-uppercase text-primary text-xs mb-3">Try It</h4>
          <p class="text-body-sm text-muted mb-4">
            Use the Runtime Calculator for your specific load and battery configuration.
          </p>
          <a href="/tools/runtime-calculator" class="btn-primary text-xs py-3 px-6 inline-block">Open Runtime Calculator</a>
        </CalculatorCard>
        <CalculatorCard class="border-m-blue-light">
          <h4 class="text-label-uppercase text-primary text-xs mb-3">Related</h4>
          <p class="text-body-sm text-muted mb-4">
            Compare with 200Ah and 300Ah runtime examples for larger systems.
          </p>
          <a href="/learn/how-long-will-a-200ah-battery-last" class="btn-primary-outline text-xs py-3 px-6 inline-block">200Ah Guide</a>
        </CalculatorCard>
      </div>

      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-4">Related Articles</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <CalculatorCard>
            <h4 class="text-primary font-bold mb-2">How Long Will a 200Ah Battery Last?</h4>
            <p class="text-body-sm text-muted mb-3">Runtime examples for 200Ah batteries across RV, marine, and home backup loads.</p>
            <a href="/learn/how-long-will-a-200ah-battery-last" class="text-label-uppercase text-m-blue-light text-xs hover:text-primary transition-colors">Read Guide →</a>
          </CalculatorCard>
          <CalculatorCard>
            <h4 class="text-primary font-bold mb-2">How Long Will a Battery Last?</h4>
            <p class="text-body-sm text-muted mb-3">The general method for calculating runtime from any capacity and load.</p>
            <a href="/learn/how-long-will-a-battery-last" class="text-label-uppercase text-m-blue-light text-xs hover:text-primary transition-colors">Read Guide →</a>
          </CalculatorCard>
        </div>
      </section>

      <FAQSection items={faqItems} />
    </div>
  </div>
</Layout>
