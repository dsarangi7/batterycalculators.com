---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CategoryToolGrid from '../components/CategoryToolGrid.astro';
import CalculatorCard from '../components/CalculatorCard.astro';
import FAQSection from '../components/FAQSection.astro';
import RelatedTools from '../components/RelatedTools.astro';

const WEB3FORMS_KEY = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY || '';

const tools = [
  {
    name: "Marine Battery Sizing Calculator",
    href: "/tools/marine-battery-sizing-calculator",
    description: "Size your vessel battery bank based on hotel loads, usage hours, battery voltage, and depth of discharge for reliable marine electrical systems.",
    available: true,
  },
  {
    name: "Vessel Energy Storage Calculator",
    href: "/tools/vessel-energy-storage-calculator",
    description: "Determine optimal energy storage capacity for vessel propulsion, hotel loads, and hybrid power management systems.",
    available: true,
  },
  {
    name: "Marine CO₂ Reduction Calculator",
    href: "/tools/marine-co2-reduction-calculator",
    description: "Estimate fuel savings and CO₂ emission reductions from hybrid or battery-electric vessel configurations.",
    available: true,
  },
  {
    name: "Hybrid Vessel ROI Calculator",
    href: "/tools/hybrid-vessel-roi-calculator",
    description: "Calculate payback period, fuel savings, and return on investment for hybrid and electric propulsion retrofits.",
    available: true,
  },
  {
    name: "Shore Power Savings Calculator",
    href: "/tools/shore-power-savings-calculator",
    description: "Compare shore power costs versus onboard diesel generator operation for vessels at berth or anchor.",
    available: true,
  },
  {
    name: "Ferry Battery Sizing Calculator",
    href: "/tools/ferry-battery-sizing-calculator",
    description: "Size battery packs for short-route ferry electrification based on crossing distance, schedule, and load profile.",
    available: true,
  },
  {
    name: "CII Calculator",
    href: "/tools/cii-calculator",
    description: "Estimate your vessel's Carbon Intensity Indicator rating and identify operational improvements to meet IMO targets.",
    available: true,
  },
  {
    name: "EEXI Calculator",
    href: "/tools/eexi-calculator",
    description: "Evaluate Energy Efficiency Existing Ship Index compliance and model technical upgrades to meet EEXI requirements.",
    available: false,
  },
];

const toolCategories = [
  {
    title: "Vessel Energy Storage",
    description: "Battery sizing, energy storage planning, and power system design for all vessel types — from harbor craft to offshore support vessels and passenger ferries.",
    icon: "M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z",
  },
  {
    title: "Emissions & CO₂ Reduction",
    description: "Quantify fuel savings, CO₂ reductions, and NOx/SOx emission improvements from electrification, shore power, and hybrid propulsion strategies.",
    icon: "M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z",
  },
  {
    title: "Hybrid Vessel Economics",
    description: "Financial analysis tools for evaluating hybrid and electric propulsion retrofits, including payback periods, fuel cost projections, and lifecycle ROI.",
    icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  },
  {
    title: "IMO & Regulatory Tools",
    description: "Navigate IMO CII ratings, EEXI requirements, and decarbonization regulations with calculators that model compliance pathways and improvement scenarios.",
    icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
  },
];

const resourceArticles = [
  { title: "Why Shipowners Should Invest in Cleaner Operations", href: "/learn/why-shipowners-should-invest-in-cleaner-operations", planned: true },
  { title: "Reducing Vessel Fuel Consumption: Practical Strategies", href: "/learn/reducing-vessel-fuel-consumption", planned: true },
  { title: "How Hybrid Propulsion Lowers Operating Costs", href: "/learn/how-hybrid-propulsion-lowers-operating-costs", planned: true },
  { title: "Battery Energy Storage for Ferries and Workboats", href: "/learn/battery-energy-storage-for-ferries-and-workboats", planned: true },
  { title: "Understanding Shore Power Benefits", href: "/learn/understanding-shore-power-benefits", planned: true },
  { title: "How Vessel Operators Can Improve CII Ratings", href: "/learn/how-vessel-operators-can-improve-cii-ratings", planned: true },
  { title: "Maritime Decarbonization Roadmap", href: "/learn/maritime-decarbonization-roadmap", planned: true },
  { title: "Future of Electric and Hybrid Vessels", href: "/learn/future-of-electric-and-hybrid-vessels", planned: true },
];

const learnArticles = [
  { title: "What Is Marine Electrification?", href: "/learn/what-is-marine-electrification" },
  { title: "Hybrid Propulsion Systems Explained", href: "/learn/hybrid-propulsion-systems-explained" },
  { title: "Battery-Electric Ferries Explained", href: "/learn/battery-electric-ferries-explained" },
  { title: "Shore Power vs Diesel Generators", href: "/learn/shore-power-vs-diesel-generators" },
  { title: "Understanding CII Ratings", href: "/learn/understanding-cii-ratings" },
  { title: "Vessel Energy Storage Systems Explained", href: "/learn/vessel-energy-storage-systems-explained" },
  { title: "How Hybrid Vessels Reduce Emissions", href: "/learn/how-hybrid-vessels-reduce-emissions" },
  { title: "Maritime Decarbonization Roadmap", href: "/learn/maritime-decarbonization-roadmap" },
];

const relatedTools = [
  { href: "/tools/marine-co2-reduction-calculator", title: "Marine CO₂ Reduction Calculator", description: "Quantify emissions reductions from hybridization and shore power." },
  { href: "/tools/hybrid-vessel-roi-calculator", title: "Hybrid Vessel ROI Calculator", description: "Evaluate the financial return on hybrid propulsion investment." },
  { href: "/tools/shore-power-savings-calculator", title: "Shore Power Savings Calculator", description: "Estimate fuel savings from shore power connection." },
  { href: "/tools/vessel-energy-storage-calculator", title: "Vessel Energy Storage Calculator", description: "Determine battery capacity for hybrid or electric vessel systems." },
  { href: "/tools/ferry-battery-sizing-calculator", title: "Ferry Battery Sizing Calculator", description: "Size battery packs for short-route ferry electrification." },
  { href: "/tools/cii-calculator", title: "CII Calculator", description: "Estimate your vessel's Carbon Intensity Indicator rating." },
];

const faqItems = [
  {
    question: "What is marine electrification?",
    answer: "Marine electrification is the integration of battery energy storage, electric propulsion motors, and power management systems into vessels to reduce or replace fossil fuel dependency. It ranges from full battery-electric operation on short routes to hybrid diesel-electric systems that supplement main engines with electric drive for improved efficiency and lower emissions.",
  },
  {
    question: "How do batteries reduce vessel emissions?",
    answer: "Batteries reduce emissions by enabling zero-discharge operation in ports and emission control areas, supporting hybrid modes where electric motors handle low-load conditions where diesel engines operate inefficiently, and capturing regenerative energy from thrusters and propulsion systems. A well-designed hybrid system can reduce fuel consumption by 15–30% and significantly cut CO₂, NOx, and SOx emissions.",
  },
  {
    question: "What vessels benefit most from hybrid propulsion?",
    answer: "Vessels with variable load profiles benefit most: ferries with frequent port calls, offshore support vessels with dynamic positioning duty cycles, harbor tugs with intermittent high-power demands, cruise ships with large hotel loads, and fishing vessels with extended idle periods. These vessel types see the greatest fuel savings because batteries can handle peak loads while engines run at optimal efficiency.",
  },
  {
    question: "What is shore power?",
    answer: "Shore power (also called cold ironing or Alternative Maritime Power) allows vessels to connect to the local electrical grid while at berth, shutting down onboard diesel generators. This eliminates exhaust emissions in port, reduces noise, and can lower operating costs when grid electricity is cheaper than marine fuel. Shore power requires compatible vessel infrastructure and port-side power supply systems.",
  },
  {
    question: "What is CII?",
    answer: "The Carbon Intensity Indicator (CII) is an IMO metric that rates ships from A to E based on their operational carbon intensity — measured as CO₂ emissions per transport work. Ships rated D for three consecutive years or E in any year must submit a corrective action plan. CII applies to vessels of 5,000 GT and above and is part of the IMO's strategy to reduce greenhouse gas emissions from international shipping.",
  },
  {
    question: "What is EEXI?",
    answer: "The Energy Efficiency Existing Ship Index (EEXI) is a mandatory IMO technical measure that requires existing ships to meet a minimum energy efficiency standard. It is a one-time certification based on the ship's design and installed power. EEXI became effective January 1, 2023 and applies to most cargo, tanker, and passenger ships. Compliance typically requires engine power limitations, propeller modifications, or energy-saving device installations.",
  },
  {
    question: "Can batteries fully replace diesel engines on vessels?",
    answer: "Battery-electric operation is viable for short-route ferries, harbor craft, and inland vessels with predictable schedules and charging infrastructure. For long-voyage ocean-going vessels, batteries alone cannot yet match the energy density of marine fuels. Hybrid systems that combine diesel engines with battery storage offer the most practical near-term pathway, delivering substantial emission reductions while maintaining operational range and reliability.",
  },
  {
    question: "Is this calculator section suitable for official compliance reporting?",
    answer: "No. All calculators on this site are educational engineering estimators designed for preliminary planning, feasibility analysis, and learning purposes. They do not replace official class society calculations, flag-state submissions, or IMO compliance documentation. Always consult classification societies, marine surveyors, and certified marine engineers for official regulatory compliance and vessel certification.",
  },
  {
    question: "How can shipowners reduce vessel emissions?",
    answer: "Shipowners can reduce emissions through multiple pathways: hybrid propulsion systems (15–30% fuel savings), shore power at berth (eliminates port emissions), speed optimization (10–20% fuel reduction), hull and propeller maintenance (5–10% improvement), weather routing, and switching to cleaner fuels. A combination of technical and operational measures delivers the greatest impact. Our marine CO₂ reduction calculator helps quantify the potential of each strategy.",
  },
  {
    question: "What is the benefit of shore power for vessels?",
    answer: "Shore power eliminates generator fuel consumption at berth, saving 5,000–50,000+ liters of fuel annually per vessel depending on port call frequency and berth duration. It eliminates NOx, SOx, and particulate emissions in port, reduces noise pollution, and qualifies for green port fee discounts of 10–30%. The net cost benefit depends on local electricity rates versus marine fuel prices — our shore power savings calculator quantifies this for your specific operations.",
  },
  {
    question: "How much fuel can hybrid vessels save?",
    answer: "Hybrid vessels typically save 15–30% of annual fuel consumption, depending on the duty cycle. Ferries with frequent port calls and variable loads achieve the highest savings (20–40%), while steady-cruise vessels see more modest reductions (5–15%). The savings come from battery-electric operation during low-load periods, load leveling that keeps engines at optimal efficiency, and capture of regenerative energy. Our hybrid vessel ROI calculator models the financial return of these savings.",
  },
  {
    question: "How can battery systems improve vessel efficiency?",
    answer: "Battery systems improve vessel efficiency by handling low-load conditions where diesel engines operate poorly (below 25% rated power), enabling engines to run at their optimal efficiency band. They also enable peak shaving (reducing installed engine power), load leveling, and zero-emission operation in ports and emission control areas. Battery energy storage for ferries and workboats can reduce total energy consumption by 20–40% compared to conventional diesel-only propulsion.",
  },
  {
    question: "What is a marine CO₂ calculator?",
    answer: "A marine CO₂ calculator is an engineering tool that estimates the carbon dioxide emissions from vessel operations based on fuel consumption, fuel type, and operating hours. It helps shipowners, operators, and naval architects quantify baseline emissions and model reduction scenarios from hybridization, shore power, and efficiency improvements. Our marine CO₂ reduction calculator provides CO₂, NOx, and SOx estimates using Fourth IMO GHG Study emission factors.",
  },
  {
    question: "How does vessel electrification support decarbonization?",
    answer: "Vessel electrification directly reduces CO₂ emissions by replacing fossil fuel combustion with electric propulsion powered by batteries or shore power. Hybrid systems reduce fuel consumption by 15–30%, while full battery-electric operation eliminates direct emissions entirely on suitable routes. Electrification also supports the IMO's Carbon Intensity Indicator (CII) targets by improving operational carbon intensity, helping vessels maintain compliant ratings as benchmarks tighten through 2030.",
  },
  {
    question: "What factors influence a vessel's carbon footprint?",
    answer: "A vessel's carbon footprint is influenced by: fuel type and consumption rate (largest factor), engine efficiency and load factor, distance traveled and cargo carried, speed profile, port time and generator usage, weather and sea conditions, hull fouling and propeller condition, and hotel loads (HVAC, lighting, galley). Our calculators help quantify the impact of each factor and model improvement scenarios for vessel decarbonization.",
  },
  {
    question: "Can battery systems help improve CII performance?",
    answer: "Yes. Battery systems improve CII by reducing annual fuel consumption (and therefore CO₂ emissions) through hybrid operation. A 15% fuel reduction translates directly to approximately 15% CII improvement. Combined with shore power (additional 5%) and operational efficiency measures (10%), total CII improvement can reach 28–30%. This can shift a vessel from a D or E rating to a compliant C or B rating. Our CII calculator models these improvement scenarios.",
  },
];

const breadcrumbItems = [
  { label: "Marine Electrification & Decarbonization" },
];

const advisoryBenefits = [
  "Vessel emissions reduction assessment",
  "Hybrid propulsion feasibility review",
  "Battery energy storage sizing guidance",
  "Shore power opportunity evaluation",
  "Fuel consumption reduction strategies",
  "CII improvement opportunities",
  "Energy efficiency planning",
];

const decisionBlocks = [
  {
    title: "Regulatory Compliance",
    icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
    content: "The IMO's Initial GHG Strategy targets net-zero emissions by or around 2050, with intermediate targets of 40% carbon intensity reduction by 2030 and 70% by 2040. The Carbon Intensity Indicator (CII) mandates annual ratings for vessels over 5,000 GT — persistent D or E ratings require corrective action plans. EU ETS now covers maritime emissions, adding direct carbon costs. Proactive decarbonization avoids regulatory penalties and positions vessels favorably for tightening standards.",
  },
  {
    title: "Cost Efficiency",
    icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
    content: "Fuel represents 50–60% of vessel operating costs. Hybrid propulsion delivers 15–30% fuel savings, translating to $50,000–$500,000+ annual savings per vessel depending on size and duty cycle. Shore power eliminates generator fuel at berth. Reduced engine run hours cut maintenance costs by 20–40%. Battery-electric operation on short routes can reduce energy costs by 50–80% compared to diesel. These savings compound over the vessel's 15–25 year operational life.",
  },
  {
    title: "Market Reputation",
    icon: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z",
    content: "Charterers, cargo owners, and passengers increasingly demand verifiable sustainability credentials. Major charterers (Cargill, Maersk, BHP) require emissions data and favor low-carbon vessels. Cruise passengers选择 environmentally responsible operators. Green shipping certifications (Green Marine, Clean Shipping) provide competitive advantage. Documented decarbonization strategies strengthen commercial positioning in an emissions-conscious market.",
  },
  {
    title: "Stakeholder Expectations",
    icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z",
    content: "Investors screen portfolios for climate risk and favor companies with credible decarbonization roadmaps (TCFD, ESG reporting). Ports offer green fee discounts and preferential berthing for low-emission vessels. Flag states and classification societies increasingly reward proactive environmental measures. Insurers offer preferential rates for vessels with documented energy management systems. Stakeholder alignment on decarbonization creates compound commercial benefits.",
  },
  {
    title: "Future Readiness",
    icon: "M13 10V3L4 14h7v7l9-11h-7z",
    content: "Battery technology costs continue declining (projected 50% reduction by 2030), making electrification increasingly viable for larger vessels and longer routes. Hybrid systems provide a flexible platform for integrating future fuel cells, advanced batteries, and wind-assisted propulsion. Digital energy management systems optimize real-time fuel consumption. Vessels invested in electrification infrastructure today avoid stranded asset risk as regulations tighten and fuel costs rise.",
  },
];
---

<Layout
  title="Marine Electrification & Decarbonization Tools | Battery Calculators"
  description="Engineering calculators and guides for vessel batteries, hybrid propulsion, shore power, emissions reduction, and IMO CII/EEXI decarbonization planning."
  schema="collectionPage"
  schemaName="Marine Electrification & Decarbonization Tools"
  schemaDescription="Engineering-grade calculators for vessel battery sizing, hybrid propulsion economics, marine emissions reduction, shore power savings, and IMO CII/EEXI compliance planning."
  canonical="https://batterycalculators.com/marine"
  breadcrumbs={[{ label: 'Marine Electrification & Decarbonization' }]}
  faqItems={faqItems}
>
  <Breadcrumb items={breadcrumbItems} />

  <!-- Hero Section -->
  <section class="mb-12 md:mb-16 border-b border-hairline pb-12">
    <div class="max-w-4xl">
      <span class="text-label-uppercase text-m-blue-light text-xs block mb-4">MARINE ELECTRIFICATION & DECARBONIZATION</span>
      <h1 class="text-display-md text-primary mb-6">Marine Electrification &amp; Decarbonization Tools</h1>
      <p class="text-body-md text-body max-w-2xl font-light mb-8">
        Engineering calculators, guides, and expert advisory for vessel batteries, hybrid propulsion, shore power, emissions reduction, and IMO decarbonization planning.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="#marine-calculators" class="btn-primary-outline px-6 py-3 text-sm">Explore Marine Calculators</a>
        <a href="#why-marine-electrification" class="btn-primary px-6 py-3 text-sm">Learn Marine Decarbonization</a>
      </div>
    </div>
  </section>

  <!-- Tool Category Section -->
  <section class="mb-16">
    <h2 class="text-title-lg text-primary mb-6">Tool Categories</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {toolCategories.map((cat) => (
        <div class="bg-surface-card border border-hairline p-6">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 flex-shrink-0 flex items-center justify-center border border-hairline">
              <svg class="w-5 h-5 text-m-blue-light" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d={cat.icon} />
              </svg>
            </div>
            <div>
              <h3 class="text-title-md text-primary mb-2">{cat.title}</h3>
              <p class="text-body-sm text-muted">{cat.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Featured Marine Tools Section -->
  <section id="marine-calculators" class="mb-16 border-t border-hairline pt-12">
    <h2 class="text-title-lg text-primary mb-6">Marine Electrification Calculators</h2>
    <CategoryToolGrid tools={tools} />
  </section>

  <!-- Why Marine Electrification Matters -->
  <section id="why-marine-electrification" class="mb-16 border-t border-hairline pt-12">
    <h2 class="text-display-sm text-primary mb-8">Why Marine Electrification Matters</h2>
    <div class="max-w-4xl text-body-md text-body font-light flex flex-col gap-6">
      <p>
        The maritime industry accounts for approximately 2.9% of global greenhouse gas emissions, and regulatory pressure from the IMO is accelerating the transition toward cleaner propulsion technologies. Marine electrification — through battery energy storage, hybrid diesel-electric systems, and shore power connectivity — represents the most practical pathway to meaningful emission reductions across the existing fleet.
      </p>
      <p>
        Fuel cost reduction is one of the strongest economic drivers for electrification. Hybrid propulsion systems capture energy during low-load operations, reduce engine run hours, and enable optimal engine loading — delivering 15–30% fuel savings on vessel types with variable duty cycles. For ferries and harbor craft operating frequent short voyages, full battery-electric operation can eliminate fuel costs entirely during electric mode.
      </p>
      <p>
        Beyond fuel savings, electrification directly reduces CO₂, NOx, and SOx emissions. Batteries enable zero-discharge operation in ports and emission control areas, helping vessels meet increasingly strict regional and international air quality standards. Shore power connections allow vessels to shut down diesel generators at berth, eliminating localized exhaust emissions and reducing port-side noise pollution.
      </p>
      <p>
        The operational benefits extend to efficiency during low-load conditions. Diesel engines operate poorly at low loads — often below 25% of rated power — where fuel consumption per kilowatt-hour increases dramatically and combustion incomplete. Hybrid systems use batteries to handle these inefficient low-load periods, allowing engines to run at their optimal efficiency band or shut down entirely.
      </p>
      <p>
        Vessel types that benefit most from hybrid and electric propulsion include short-route ferries, offshore support vessels with dynamic positioning duty cycles, harbor tugs with intermittent high-power demands, workboats, service vessels, and cruise ships with large hotel loads. Each vessel type presents unique challenges in battery sizing, energy storage planning, and operational profile analysis — which is precisely what these calculators address.
      </p>
      <p>
        Proper battery sizing and energy storage planning are critical to successful marine electrification. Oversized battery packs increase capital cost and weight without proportional benefit. Undersized packs limit electric range and force premature engine starts. Our calculators provide the engineering foundation for finding the optimal balance between battery capacity, vessel requirements, and economic return.
      </p>
    </div>
  </section>

  <!-- Why Shipowners Are Investing in Cleaner Operations -->
  <section class="mb-16 border-t border-hairline pt-12">
    <h2 class="text-display-sm text-primary mb-4">Why Shipowners Are Investing in Cleaner Operations</h2>
    <p class="text-body-md text-muted max-w-3xl mb-8 font-light">
      Maritime decarbonization is no longer just an environmental imperative — it is a commercial necessity. Shipowners investing in cleaner operations gain regulatory compliance, cost savings, market advantage, and long-term asset resilience.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {decisionBlocks.map((block) => (
        <div class="bg-surface-card border border-hairline p-6 flex flex-col">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 flex-shrink-0 flex items-center justify-center border border-hairline">
              <svg class="w-5 h-5 text-m-blue-light" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d={block.icon} />
              </svg>
            </div>
            <h3 class="text-title-sm text-primary">{block.title}</h3>
          </div>
          <p class="text-body-sm text-muted flex-1">{block.content}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Marine Decarbonization Resource Center -->
  <section class="mb-16 border-t border-hairline pt-12">
    <h2 class="text-title-lg text-primary mb-4">Marine Decarbonization Resource Center</h2>
    <p class="text-body-sm text-muted max-w-3xl mb-8">
      Educational guides for shipowners, operators, naval architects, consultants, and marine engineers exploring electrification and emissions reduction.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {resourceArticles.map((article) => (
        <a href={article.href} class="bg-surface-card border border-hairline p-4 hover:border-primary transition-colors">
          <div class="flex items-center justify-between mb-2">
            <span class="text-label-uppercase text-muted text-[10px]">RESOURCE CENTER</span>
            {article.planned && (
              <span class="text-[10px] text-muted border border-hairline px-2 py-0.5 uppercase tracking-wider">Coming Soon</span>
            )}
          </div>
          <h3 class="text-title-sm text-primary">{article.title}</h3>
        </a>
      ))}
    </div>
  </section>

  <!-- Marine Learning Center -->
  {learnArticles.length > 0 && (
    <section class="mb-16 border-t border-hairline pt-12">
      <h2 class="text-title-lg text-primary mb-6">Marine Electrification Learning Center</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {learnArticles.map((article) => (
          <a href={article.href} class="bg-surface-card border border-hairline p-4 hover:border-primary transition-colors">
            <div class="flex items-center justify-between mb-2">
              <span class="text-label-uppercase text-muted text-[10px]">LEARNING CENTER</span>
            </div>
            <h3 class="text-title-sm text-primary">{article.title}</h3>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Related Tools (Internal Linking) -->
  <section class="mb-16 border-t border-hairline pt-12">
    <h2 class="text-title-lg text-primary mb-6">Marine Engineering Calculators</h2>
    <p class="text-body-sm text-muted max-w-3xl mb-8">
      Explore our complete suite of marine CO₂ calculators, vessel emissions calculators, and maritime decarbonization tools — designed for shipowners, operators, and marine engineers.
    </p>
    <RelatedTools tools={relatedTools} />
  </section>

  <!-- Advisory Section + Get Support Form -->
  <section id="marine-advisory" class="mb-16 border-t border-hairline pt-12">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">

      <!-- Advisory Content -->
      <div>
        <span class="text-label-uppercase text-m-blue-light text-xs block mb-4">EXPERT ADVISORY</span>
        <h2 class="text-title-lg text-primary mb-4">Need Advice on Reducing Your Ship's Emissions and Energy Consumption?</h2>
        <p class="text-body-md text-muted font-light mb-6">
          Speak with a battery and marine electrification specialist regarding vessel decarbonization, hybrid propulsion, energy storage sizing, shore power integration, and operational efficiency improvements.
        </p>
        <h3 class="text-label-uppercase text-primary text-xs mb-3">How We Can Help</h3>
        <ul class="flex flex-col gap-2 mb-6">
          {advisoryBenefits.map((benefit) => (
            <li class="flex items-start gap-2 text-body-sm text-muted">
              <span class="text-m-blue-light shrink-0 mt-0.5">→</span>
              <span>{benefit}</span>
            </li>
          ))}
        </ul>
        <div class="bg-surface-soft border border-hairline p-4 text-caption text-muted">
          <span class="text-primary font-bold">Educational Advisory.</span> Our team provides engineering guidance and preliminary feasibility analysis. For official vessel design, classification, and regulatory compliance, consult certified marine engineers and classification societies.
        </div>
      </div>

      <!-- Get Support Form -->
      <div>
        <CalculatorCard>
          <h3 class="text-title-md text-primary mb-6 uppercase tracking-wider">Get Support</h3>
          <form id="marine-support-form" class="flex flex-col gap-4">
            <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
            <input type="hidden" name="subject" value="Marine Electrification Support Request" />
            <input type="hidden" name="from_name" value="Battery Calculators - Marine Advisory" />
            <input type="checkbox" name="honeypot" class="hidden" tabindex="-1" autocomplete="off" style="display:none" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="flex flex-col gap-1.5">
                <label for="first-name" class="text-label-uppercase text-[10px] text-primary">First Name *</label>
                <input type="text" id="first-name" name="first_name" required class="text-input" placeholder="FIRST NAME" />
              </div>
              <div class="flex flex-col gap-1.5">
                <label for="last-name" class="text-label-uppercase text-[10px] text-primary">Last Name *</label>
                <input type="text" id="last-name" name="last_name" required class="text-input" placeholder="LAST NAME" />
              </div>
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="business-email" class="text-label-uppercase text-[10px] text-primary">Business Email *</label>
              <input type="email" id="business-email" name="email" required class="text-input" placeholder="NAME@COMPANY.COM" />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="flex flex-col gap-1.5">
                <label for="company" class="text-label-uppercase text-[10px] text-primary">Company *</label>
                <input type="text" id="company" name="company" required class="text-input" placeholder="COMPANY NAME" />
              </div>
              <div class="flex flex-col gap-1.5">
                <label for="country" class="text-label-uppercase text-[10px] text-primary">Country / Territory *</label>
                <input type="text" id="country" name="country" required class="text-input" placeholder="COUNTRY" />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="flex flex-col gap-1.5">
                <label for="job-title" class="text-label-uppercase text-[10px] text-primary">Job Title *</label>
                <input type="text" id="job-title" name="job_title" required class="text-input" placeholder="JOB TITLE" />
              </div>
              <div class="flex flex-col gap-1.5">
                <label for="phone" class="text-label-uppercase text-[10px] text-primary">Phone Number</label>
                <input type="tel" id="phone" name="phone" class="text-input" placeholder="+1 (555) 000-0000" />
              </div>
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="comments" class="text-label-uppercase text-[10px] text-primary">Comments / Project Details *</label>
              <textarea id="comments" name="comments" required class="text-input h-28 resize-none" placeholder="DESCRIBE YOUR VESSEL, ROUTE, AND DECARBONIZATION OBJECTIVES..."></textarea>
            </div>

            <div class="flex items-start gap-2">
              <input type="checkbox" id="consent" name="consent" required class="mt-1 shrink-0" />
              <label for="consent" class="text-caption text-muted leading-relaxed">
                I agree to be contacted regarding my enquiry and understand my information will be processed according to the website <a href="/privacy" class="underline underline-offset-2 hover:text-primary transition-colors">privacy policy</a>.
              </label>
            </div>

            <button type="submit" class="btn-primary w-full text-xs h-12 mt-2">Contact Battery Calculators Expert</button>
          </form>

          <div id="form-success" class="hidden mt-4 p-4 border border-green-600 bg-surface-soft text-body-sm text-green-500">
            Thank you for your enquiry. A marine electrification specialist will contact you within 1–2 business days.
          </div>
          <div id="form-error" class="hidden mt-4 p-4 border border-m-red bg-surface-soft text-body-sm text-m-red">
            Something went wrong. Please try again or email us directly.
          </div>
        </CalculatorCard>
      </div>

    </div>
  </section>

  <!-- FAQ Section -->
  <section class="mb-16 border-t border-hairline pt-12">
    <FAQSection items={faqItems} />
  </section>

  <!-- Engineering Disclaimer -->
  <section class="bg-surface-soft border border-hairline p-6 text-caption text-muted mb-8">
    <span class="text-primary font-bold text-[10px] tracking-wider uppercase border border-hairline px-1.5 py-0.5 mr-2 inline-block mb-3">
      Engineering Disclaimer
    </span>
    All calculators provide educational engineering estimates only. They are intended for preliminary planning, feasibility analysis, and learning purposes. These tools do not replace official class society calculations, flag-state submissions, IMO compliance documentation, or regulatory filings. Marine electrical and propulsion systems must comply with applicable classification society rules, flag-state regulations, and IMO conventions. Consult certified marine engineers and naval architects for final system design and official compliance.
  </section>

  <!-- Form Submission Script -->
  <script>
    const form = document.getElementById('marine-support-form') as HTMLFormElement;
    const successDiv = document.getElementById('form-success');
    const errorDiv = document.getElementById('form-error');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const honeypot = form.querySelector('input[name="honeypot"]') as HTMLInputElement;
      if (honeypot?.value) return;

      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'SENDING...';
      }

      try {
        const formData = new FormData(form);
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData,
        });

        const result = await response.json();

        if (result.success) {
          form.reset();
          if (successDiv) successDiv.classList.remove('hidden');
          if (errorDiv) errorDiv.classList.add('hidden');
          setTimeout(() => { if (successDiv) successDiv.classList.add('hidden'); }, 10000);
        } else {
          throw new Error('Submission failed');
        }
      } catch {
        if (errorDiv) errorDiv.classList.remove('hidden');
        if (successDiv) successDiv.classList.add('hidden');
        setTimeout(() => { if (errorDiv) errorDiv.classList.add('hidden'); }, 8000);
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Contact Battery Calculators Expert';
        }
      }
    });
  </script>

</Layout>