---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import FormulaBox from '../components/FormulaBox.astro';
import FAQSection from '../components/FAQSection.astro';
import PowerOutageForm from '../components/PowerOutageForm.astro';

const whatIs = `A solar generator sizing calculator determines the battery capacity, solar panel wattage, charge controller size, and inverter requirements for a complete solar-powered backup system. Unlike gas generators, solar generators recharge from sunlight — providing unlimited runtime as long as the sun shines. This calculator sizes the full system: battery bank for overnight storage, solar panels for daytime recharge, and inverter for AC appliance loads.`;

const whyItMatters = [
  "Solar generators require matching three components: battery capacity, solar panel wattage, and inverter size. Mismatched components waste money or fail to power your loads.",
  "Battery capacity determines overnight runtime — how many hours you can run loads when the sun isn't shining.",
  "Solar panel wattage determines recharge speed — how quickly the battery replenishes during daylight hours.",
  "Peak sun hours vary dramatically by location and season: 4–6 hours in summer, 2–3 hours in winter. System sizing must account for worst-case conditions.",
  "A properly sized solar generator can provide indefinite backup power during extended outages — unlike fuel-limited gas generators."
];

const practicalApplications = [
  { title: "Off-Grid Cabin Power", description: "Size a complete solar generator system for remote cabins, tiny homes, or off-grid living where grid connection isn't available." },
  { title: "Emergency Whole-Home Backup", description: "Design a solar backup system that recharges daily from sunlight, providing indefinite power during multi-day grid outages." },
  { title: "Camping & Overlanding", description: "Size portable solar panels and battery storage for extended camping trips, van life, or overlanding adventures." },
  { title: "Construction & Remote Sites", description: "Power tools, lighting, and equipment at job sites without grid access using solar-charged battery systems." },
];

const expertNotes: { title: string; variant: 'engineering' | 'tip' | 'warning'; content: string }[] = [
  { title: "Solar Recharge Must Exceed Daily Consumption", variant: "engineering", content: "For indefinite off-grid operation, daily solar generation must exceed daily consumption. If you use 2,000Wh/day, you need 2,000Wh+ of daily solar production. At 4 peak sun hours, that's 500W+ of panels (before losses)." },
  { title: "Battery Sizing for Overnight", variant: "tip", content: "Size the battery to handle your full nighttime load plus a 20% safety margin. The solar panels recharge during the day. Don't skimp on battery capacity — it's your buffer for cloudy days." },
  { title: "MPPT vs PWM Charge Controllers", variant: "warning", content: "MPPT controllers are 15–30% more efficient than PWM, especially with higher-voltage panels. For any system over 200W, MPPT is strongly recommended. The efficiency difference directly affects recharge speed." }
];

const trustSection = {
  text: "This calculator uses standard solar engineering formulas. All calculations assume MPPT charge controllers and standard panel efficiency. Actual performance varies by location, weather, and equipment quality.",
  link: { label: "View our methodology", href: "/methodology" }
};

const references = [
  { title: "NREL — Solar Resource Data", url: "https://developer.nrel.gov/docs/solar/pvwatts/v8/", source: "National Renewable Energy Laboratory" },
  { title: "DOE — Solar Energy Technologies Office", url: "https://www.energy.gov/eere/solar/solar-energy-technologies-office", source: "U.S. Department of Energy" },
  { title: "Sandia National Labs — PV Performance Modeling", url: "https://pvlib.readthedocs.io/", source: "Sandia National Laboratories" },
];

const faqItems = [
  { question: "How many solar panels do I need for a solar generator?", answer: "For a system running 1,500Wh/day, you need approximately 400–500W of solar panels at 4 peak sun hours. In winter (2–3 peak sun hours), you'd need 700–800W to maintain the same daily recharge." },
  { question: "What battery size for a solar generator?", answer: "Size the battery for 1–2 days of autonomy. If daily consumption is 2,000Wh, a 4,000Wh (4 kWh) battery bank provides 2 days of backup without any solar recharge. Use LiFePO4 for 80–100% usable capacity." },
  { question: "Can a solar generator power a house?", answer: "A properly sized solar generator (5–15 kWh battery, 1–3 kW solar) can power essential household loads indefinitely. Running everything (AC, oven, dryer) requires a 20+ kWh system with 5–10 kW of solar panels." },
  { question: "How long does a solar generator take to charge?", answer: "Charge time depends on panel wattage and sun exposure. A 400W panel system in 5 peak sun hours generates ~2,000Wh. A 2,000Wh battery charges from empty to full in about 5 hours of peak sun. Most systems take 4–8 hours." },
];

const relatedCalculators = [
  { href: "/home-power-outage-battery-backup-calculator", title: "Home Power Outage Battery Backup Calculator", description: "Full backup power calculator for all household appliances." },
  { href: "/fridge-battery-backup-calculator", title: "Fridge Battery Backup Calculator", description: "Battery sizing specifically for refrigerator backup during outages." },
  { href: "/cpap-battery-backup-calculator", title: "CPAP Battery Backup Calculator", description: "Size batteries for overnight CPAP machine power." },
  { href: "/sump-pump-battery-backup-calculator", title: "Sump Pump Battery Backup Calculator", description: "Keep your sump pump running during storm outages." },
  { href: "/portable-power-station-runtime-calculator", title: "Portable Power Station Runtime Calculator", description: "See how long a portable power station runs your loads." },
  { href: "/tools/runtime-calculator", title: "Battery Runtime Calculator", description: "Estimate discharge time from capacity and load." },
  { href: "/tools/battery-sizing-calculator", title: "Battery Sizing Calculator", description: "Full battery bank sizing with temperature derating." },
  { href: "/tools/solar-battery-sizing-calculator", title: "Solar Battery Sizing Calculator", description: "Size batteries paired with solar panel arrays." },
  { href: "/tools/energy-conversion-calculator", title: "Energy Conversion Calculator", description: "Convert between Ah, Wh, and kWh at any voltage." },
  { href: "/tools/charging-time-calculator", title: "Charging Time Calculator", description: "Estimate charge time from solar or grid." },
  { href: "/tools/voltage-drop-calculator", title: "Voltage Drop Calculator", description: "Size wire runs to minimize voltage drop." },
  { href: "/tools/dc-cable-loss-calculator", title: "DC Cable Loss Calculator", description: "Calculate wiring losses in DC connections." },
];

const presetAppliances = [
  { name: "Refrigerator", runningW: 150, surgeW: 600 }, { name: "Freezer", runningW: 120, surgeW: 500 },
  { name: "Wi-Fi Router", runningW: 12, surgeW: 12 }, { name: "LED Light", runningW: 10, surgeW: 10 },
  { name: "Laptop", runningW: 60, surgeW: 90 }, { name: "TV", runningW: 100, surgeW: 150 },
  { name: "CPAP Machine", runningW: 40, surgeW: 80 }, { name: "Fan", runningW: 50, surgeW: 75 },
  { name: "Sump Pump", runningW: 800, surgeW: 2000 }, { name: "Microwave", runningW: 1000, surgeW: 1500 },
];
---

<CalculatorLayout
  title="Solar Generator Sizing Calculator | Battery Calculators"
  description="Calculate the battery capacity, solar panel wattage, and system components needed for a complete solar generator. Size your solar backup system for off-grid living, emergency preparedness, or camping."
  faqItems={faqItems}
  whatIs={whatIs}
  whyItMatters={whyItMatters}
  practicalApplications={practicalApplications}
  trustSection={trustSection}
  references={references}
  expertNotes={expertNotes}
  relatedCalculators={relatedCalculators}
>
  <PowerOutageForm
    presetAppliances={presetAppliances}
    defaultBackupHours={12}
    defaultVoltage="24"
    defaultLoadsDescription="Common solar generator loads pre-loaded. Add your devices and enable solar recharge to size a complete system."
    defaultLoads={[{ name: "Refrigerator", quantity: 1 }, { name: "Freezer", quantity: 1 }, { name: "Wi-Fi Router", quantity: 1 }]}
  />

  <section class="mb-16 border-t border-hairline pt-12">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <FormulaBox title="Mathematical Formulas">
        <div class="bg-surface-soft p-4 font-mono text-primary border border-hairline my-2">Total Running W = Σ (Appliance Running W × Quantity)</div>
        <div class="bg-surface-soft p-4 font-mono text-primary border border-hairline my-2">Energy Required (Wh) = (Running W × Hours) / Inverter Efficiency × (1 + Safety Margin)</div>
        <div class="bg-surface-soft p-4 font-mono text-primary border border-hairline my-2">Battery Ah = Required Wh / (Battery Voltage × Depth of Discharge)</div>
        <div class="bg-surface-soft p-4 font-mono text-primary border border-hairline my-2">Daily Solar Production = Solar Panels (W) × Peak Sun Hours × Controller Efficiency</div>
        <div class="bg-surface-soft p-4 font-mono text-primary border border-hairline my-2">Panel Size (W) = Daily Consumption (Wh) / (Peak Sun Hours × Controller Efficiency)</div>
        <p class="text-xs text-muted mt-4">For indefinite off-grid operation, daily solar production must exceed daily consumption. Size panels for worst-case season.</p>
      </FormulaBox>
      <div>
        <h2 class="text-title-lg text-primary uppercase mb-6 tracking-wider">Worked Example</h2>
        <div class="text-body-sm text-muted flex flex-col gap-4">
          <p><strong>Scenario:</strong> Size a solar generator for a fridge + freezer + Wi-Fi with 12h overnight backup, recharged by 400W of solar panels.</p>
          <div class="border-l-2 border-m-blue-light pl-4">
            <p class="font-bold text-primary mb-2">Step 1: Running load</p>
            <div class="font-mono text-primary">Fridge: 150W + Freezer: 120W + Wi-Fi: 12W</div>
            <div class="font-mono text-primary">Total running: 282W</div>
          </div>
          <div class="border-l-2 border-m-blue-light pl-4">
            <p class="font-bold text-primary mb-2">Step 2: Battery for 12h overnight</p>
            <div class="font-mono text-primary">Raw: 282W × 12h = 3,384 Wh</div>
            <div class="font-mono text-primary">After efficiency: 3,384 / 0.90 = 3,760 Wh</div>
            <div class="font-mono text-primary">With 20% margin: 3,760 × 1.20 = 4,512 Wh</div>
            <div class="font-mono text-primary">24V LFP (80% DoD): 4,512 / 19.2 = 235 Ah</div>
            <div class="font-mono text-primary font-bold mt-1">→ Battery: 24V 250Ah LFP (6 kWh)</div>
          </div>
          <div class="border-l-2 border-m-blue-light pl-4">
            <p class="font-bold text-primary mb-2">Step 3: Solar panel sizing</p>
            <div class="font-mono text-primary">Daily consumption: 282W × 24h = 6,768 Wh</div>
            <div class="font-mono text-primary">At 5 peak sun hours, 95% controller eff:</div>
            <div class="font-mono text-primary">Panels needed: 6,768 / (5 × 0.95) = 1,425W</div>
            <div class="font-mono text-primary font-bold mt-1">→ Solar: 1,500W of panels (4× 400W)</div>
          </div>
          <div class="border-l-2 border-m-blue-light pl-4">
            <p class="font-bold text-primary mb-2">Result: Complete system</p>
            <div class="font-mono text-primary font-bold">24V 250Ah LFP + 1,500W solar + 3,000W inverter</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FAQSection items={faqItems} />
</CalculatorLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const solarCheckbox = document.getElementById('solar-enabled') as HTMLInputElement | null;
    if (solarCheckbox && !solarCheckbox.checked) {
      solarCheckbox.click();
    }
  });
</script>
