---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CategoryToolGrid from '../components/CategoryToolGrid.astro';
import FAQSection from '../components/FAQSection.astro';

const tools = [
  {
    name: "Solar Battery Sizing Calculator",
    href: "/tools/solar-battery-sizing-calculator",
    description: "Size your solar battery bank based on daily energy consumption, autonomy days, battery chemistry, and depth of discharge.",
    available: true,
  },
  {
    name: "Off-Grid Battery Runtime",
    href: "/tools/runtime-calculator",
    description: "Estimate how long your battery bank will power your off-grid load based on capacity, voltage, and discharge limits.",
    available: true,
  },
  {
    name: "Energy Conversion (Ah ↔ Wh)",
    href: "/tools/energy-conversion-calculator",
    description: "Convert between Amp-hours and Watt-hours for any nominal voltage. Essential for matching solar panel output to battery capacity.",
    available: true,
  },
];

const learnArticles = [
  { title: "How to Size a Solar Battery Bank", href: "/learn/how-to-size-solar-battery-bank" },
  { title: "How Many Batteries for Solar?", href: "/learn/how-many-batteries-for-solar" },
  { title: "How Much Battery Storage Do I Need?", href: "/learn/how-much-battery-storage-do-i-need" },
  { title: "Solar Battery Backup Guide", href: "/learn/solar-battery-backup-guide" },
  { title: "Off-Grid Battery Planning", href: "/learn/off-grid-battery-planning" },
  { title: "Solar Storage Sizing Guide", href: "/learn/solar-storage-sizing-guide" },
  { title: "How Long Will My Solar Battery Last?", href: "/learn/how-long-will-my-solar-battery-last" },
  { title: "How to Size a Battery Bank", href: "/learn/how-to-size-a-battery-bank" },
  { title: "How to Calculate Battery Runtime", href: "/learn/how-to-calculate-battery-runtime" },
  { title: "Battery Sizing Reference", href: "/learn/battery-sizing-reference" },
  { title: "Battery Depth of Discharge Chart", href: "/learn/battery-depth-of-discharge-chart" },
  { title: "Best Battery Chemistry for Solar", href: "/learn/best-battery-chemistry-for-solar" },
  { title: "24V vs 48V Solar Systems", href: "/learn/24v-vs-48v-solar-systems" },
];

const faqItems = [
  {
    question: "How do I size a solar battery bank?",
    answer: "Calculate your daily energy consumption in Watt-hours, determine how many autonomy days you need (typically 1–3 days for grid-tied, 2–5 days for off-grid), account for depth of discharge limits based on battery chemistry, and apply temperature derating. Our Solar Battery Sizing Calculator handles all these factors automatically.",
  },
  {
    question: "How many batteries do I need for solar?",
    answer: "The number of batteries depends on your total daily energy consumption, desired autonomy, system voltage, and battery capacity. A typical home consuming 30 kWh per day with 2 days of autonomy would need approximately 60 kWh of usable battery storage. At 48V with 200Ah batteries (10.24 kWh each), you would need approximately 6 batteries.",
  },
  {
    question: "What is the best battery chemistry for solar storage?",
    answer: "Lithium Iron Phosphate (LiFePO4) is the recommended chemistry for solar storage due to its 80–90% depth of discharge, 3000–5000 cycle lifespan, thermal stability, and low maintenance requirements. Lead-acid batteries are cheaper upfront but have lower usable capacity (50% DoD), shorter lifespan, and require regular maintenance.",
  },
  {
    question: "How long will my solar battery last at night?",
    answer: "Runtime at night depends on your battery capacity, the load you are running, and system efficiency. A 100Ah 12.8V LFP battery (1,280 Wh) powering a 200W load with 90% inverter efficiency will last approximately 5.7 hours. Our Runtime Calculator provides precise estimates for your specific configuration.",
  },
  {
    question: "Can I use solar batteries for home backup?",
    answer: "Yes. Solar batteries paired with a hybrid inverter can provide backup power during grid outages. The battery charges from solar panels during the day and can power critical loads when the grid fails. Size the battery to cover your essential loads for the desired backup duration using our Home Backup Battery Calculator.",
  },
  {
    question: "What is the difference between off-grid and hybrid solar battery systems?",
    answer: "Off-grid systems are completely independent of the utility grid and require larger battery banks to handle multi-day periods without solar production. Hybrid systems remain connected to the grid but use batteries for self-consumption optimization, time-of-use arbitrage, and backup during outages. Hybrid systems can use smaller battery banks since the grid serves as a backup.",
  },
];

const relatedCategories = [
  { href: "/home-backup", title: "Home Backup", description: "Battery backup for power outages and essential loads" },
  { href: "/engineering", title: "Engineering", description: "C-rate, SOC, voltage drop, and cable loss tools" },
  { href: "/bess", title: "BESS & Commercial", description: "Commercial battery storage ROI analysis" },
];

const breadcrumbItems = [
  { label: "Solar & Home Energy" },
];
---

<Layout
  title="Solar & Home Battery Calculators | Battery Calculators"
  description="Free solar battery sizing calculators, off-grid battery tools, and energy conversion calculators for homeowners and solar installers."
  schema="website"
  schemaName="Solar & Home Battery Calculators"
  schemaDescription="Engineering-grade battery calculators for solar energy storage, off-grid systems, and home backup power."
  breadcrumbs={[{ label: 'Solar & Home Energy' }]}
>
  <Breadcrumb items={breadcrumbItems} />

  <section class="mb-12 md:mb-16 border-b border-hairline pb-12">
    <div class="max-w-4xl">
      <span class="text-label-uppercase text-m-blue-light text-xs block mb-4">SOLAR & HOME ENERGY</span>
      <h1 class="text-display-md text-primary mb-6">Solar & Home Battery Calculators</h1>
      <p class="text-body-md text-body max-w-2xl font-light">
        Engineering-grade battery calculators for solar energy storage, off-grid systems, and home backup power. Size your battery bank, estimate runtime, and convert energy units with transparent formulas.
      </p>
    </div>
  </section>

  <!-- Authority Introduction -->
  <section class="mb-16">
    <div class="max-w-4xl text-body-md text-body font-light flex flex-col gap-6">
      <p>
        Solar battery storage is the backbone of modern residential energy systems. Whether you are designing an off-grid cabin, adding battery backup to a grid-tied solar installation, or optimizing self-consumption to reduce electricity bills, proper battery sizing determines whether your system meets your energy needs or falls short.
      </p>
      <p>
        The core challenge in solar battery design is balancing three competing factors: sufficient storage capacity to cover your consumption during periods without sunlight, depth of discharge limits that preserve battery cycle life, and system voltage compatibility with your inverter and charge controller. Getting any one of these wrong leads to either overspending on unnecessary capacity or experiencing unexpected power shortages.
      </p>
      <p>
        Our solar battery calculators apply standard electrical engineering formulas to help you navigate these trade-offs. The Solar Battery Sizing Calculator takes your daily energy consumption, desired autonomy days, battery chemistry, and temperature conditions to determine the exact battery bank capacity you need. The Runtime Calculator estimates how long your battery bank will power a specific load, accounting for inverter efficiency, depth of discharge, and voltage sag.
      </p>
      <p>
        For off-grid solar installations, battery sizing is especially critical. Without a grid connection to fall back on, your battery bank must store enough energy to power your loads through consecutive cloudy days. The standard approach is to size for 2–5 days of autonomy depending on your location's solar resource and weather variability. Our calculators help you determine the exact capacity needed for your specific conditions.
      </p>
      <p>
        Grid-tied solar systems with battery backup follow a different design philosophy. Here, the battery primarily stores excess solar energy for use during evening peak hours or provides backup during grid outages. The battery bank can be smaller since the grid serves as a secondary power source. Our tools help you optimize the battery size for your self-consumption goals and backup requirements.
      </p>
    </div>
  </section>

  <section class="mb-16">
    <h2 class="text-title-lg text-primary mb-6">Available Calculators</h2>
    <CategoryToolGrid tools={tools} />
  </section>

  {learnArticles.length > 0 && (
    <section class="mb-16 border-t border-hairline pt-12">
      <h2 class="text-title-lg text-primary mb-6">Solar Battery Guides</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {learnArticles.map((article) => (
          <a href={article.href} class="bg-surface-card border border-hairline p-4 hover:border-primary transition-colors">
            <span class="text-label-uppercase text-muted text-[10px] block mb-2">LEARNING CENTER</span>
            <h3 class="text-title-sm text-primary">{article.title}</h3>
          </a>
        ))}
      </div>
    </section>
  )}

  <FAQSection items={faqItems} />

  {relatedCategories.length > 0 && (
    <section class="mb-16 border-t border-hairline pt-12">
      <h2 class="text-title-lg text-primary mb-6">Related Categories</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {relatedCategories.map((cat) => (
          <a href={cat.href} class="bg-surface-card border border-hairline p-6 hover:border-primary transition-colors block">
            <h3 class="text-title-md text-primary mb-2">{cat.title}</h3>
            <p class="text-body-sm text-muted">{cat.description}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="bg-surface-soft border border-hairline p-6 text-caption text-muted mb-8">
    <span class="text-primary font-bold text-[10px] tracking-wider uppercase border border-hairline px-1.5 py-0.5 mr-2 inline-block mb-3">
      Engineering Disclaimer
    </span>
    All calculators provide sizing estimates only. Actual performance depends on temperature, battery chemistry, wiring, and load characteristics. Consult a certified installer for final system design.
  </section>
</Layout>
