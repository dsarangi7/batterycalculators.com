---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import FormulaBox from '../components/FormulaBox.astro';
import FAQSection from '../components/FAQSection.astro';
import PowerOutageForm from '../components/PowerOutageForm.astro';

const whatIs = `A portable power station runtime calculator estimates how long a portable power station (battery generator) will run your specific appliances during a power outage. Unlike gas generators, portable power stations are silent, emission-free, and indoor-safe — but they have limited capacity. This calculator tells you exactly how many hours your station will last based on your actual load, helping you choose the right size and plan energy usage during extended outages.`;

const whyItMatters = [
  "Portable power stations are rated in Wh (watt-hours), but real runtime depends on your specific appliances — a station rated for '2,000Wh' doesn't mean 2,000W for 1 hour.",
  "Inverter efficiency losses (10–15%) reduce usable capacity. A 1,000Wh station provides roughly 850–900Wh of actual output.",
  "Lithium NMC batteries should not be discharged below 80–90% depth of discharge. LiFePO4 units allow 80–100% DoD.",
  "Higher discharge rates reduce usable capacity — running a 1,500W load from a 1,000Wh station depletes it faster than running 500W.",
  "Matching your load to a power station's output rating is critical — exceeding continuous output shuts down the unit, even if capacity remains."
];

const practicalApplications = [
  { title: "Power Outage Preparedness", description: "Before buying a portable power station, calculate exactly how long it will power your critical appliances during an outage." },
  { title: "Camping & RV Trips", description: "Plan your portable power station capacity based on what you'll actually plug in — fridge, lights, phone charging, CPAP." },
  { title: "Worksite & Remote Power", description: "Power tools, lighting, and equipment at remote locations without grid access." },
  { title: "Emergency Kit Planning", description: "Determine what size portable power station fits your household's critical emergency load requirements." },
];

const expertNotes: { title: string; variant: 'engineering' | 'tip' | 'warning'; content: string }[] = [
  { title: "Continuous vs Surge Output", variant: "warning", content: "A power station rated '1,500W continuous, 3,000W surge' can run loads up to 1,500W continuously. The surge rating only handles brief motor startups (1–3 seconds). Running 1,800W will shut it down even though it's below surge capacity." },
  { title: "Inverter Efficiency Matters", variant: "engineering", content: "Portable power stations lose 10–15% converting DC battery power to AC output. A 1,000Wh station provides roughly 850Wh of usable AC energy. Some manufacturers quote 'DC capacity' which excludes this loss." },
  { title: "Temperature Affects Runtime", variant: "tip", content: "Cold weather (below 32°F / 0°C) reduces lithium battery capacity by 10–25%. If you're using a portable power station in winter, plan for 20% less runtime than rated capacity suggests." }
];

const trustSection = {
  text: "This calculator uses standard electrical engineering formulas. Runtime estimates assume 85% inverter efficiency and standard depth-of-discharge limits.",
  link: { label: "View our methodology", href: "/methodology" }
};

const references = [
  { title: "DOE — Battery Energy Storage Safety", url: "https://www.energy.gov/eere/solar/battery-safety-and-performance", source: "U.S. Department of Energy" },
  { title: "UL 2743 — Portable Power Stations", url: "https://www.ul.com/resources/ul-2743-standard-safety-portable-lithium-ion-battery", source: "Underwriters Laboratories" },
];

const faqItems = [
  { question: "How long will a portable power station run a refrigerator?", answer: "A 1,000Wh lithium portable power station runs a standard refrigerator (150W running) for approximately 5–6 hours. A 2,000Wh station extends this to 10–12 hours. Remember the compressor cycles on and off, so actual runtime may be longer." },
  { question: "What size portable power station do I need?", answer: "For essential loads (fridge + Wi-Fi + lights + phone charging, ~250W average), a 1,000Wh station provides 3–4 hours. For overnight backup (8 hours), plan for 2,000–3,000Wh. For multi-day outages, consider 3,000Wh+ with solar recharging." },
  { question: "Can a portable power station run a microwave or space heater?", answer: "Most portable power stations (1,000–2,000W output) cannot run microwaves (1,000–1,500W) or space heaters (1,500W+) simultaneously with other loads. They may handle a microwave alone briefly, but not continuously." },
  { question: "Do portable power stations lose charge when not in use?", answer: "Yes, all lithium batteries self-discharge at 1–5% per month. Store portable power stations at 50–80% charge in a cool location. Check charge every 3 months if in long-term storage." },
];

const relatedCalculators = [
  { href: "/home-power-outage-battery-backup-calculator", title: "Home Power Outage Battery Backup Calculator", description: "Full backup power calculator for all household appliances." },
  { href: "/tools/runtime-calculator", title: "Battery Runtime Calculator", description: "Estimate discharge time from capacity and load." },
  { href: "/tools/battery-sizing-calculator", title: "Battery Sizing Calculator", description: "Full battery bank sizing with temperature derating." },
  { href: "/tools/solar-battery-sizing-calculator", title: "Solar Battery Sizing Calculator", description: "Size batteries paired with solar panel arrays." },
  { href: "/tools/energy-conversion-calculator", title: "Energy Conversion Calculator", description: "Convert between Ah, Wh, and kWh at any voltage." },
  { href: "/tools/charging-time-calculator", title: "Charging Time Calculator", description: "Estimate charge time from solar or grid." },
  { href: "/tools/voltage-drop-calculator", title: "Voltage Drop Calculator", description: "Size wire runs to minimize voltage drop." },
  { href: "/tools/dc-cable-loss-calculator", title: "DC Cable Loss Calculator", description: "Calculate wiring losses in DC connections." },
];

const presetAppliances = [
  { name: "Refrigerator", runningW: 150, surgeW: 600 }, { name: "Freezer", runningW: 120, surgeW: 500 },
  { name: "Wi-Fi Router", runningW: 12, surgeW: 12 }, { name: "LED Light", runningW: 10, surgeW: 10 },
  { name: "Laptop", runningW: 60, surgeW: 90 }, { name: "TV", runningW: 100, surgeW: 150 },
  { name: "CPAP Machine", runningW: 40, surgeW: 80 }, { name: "Fan", runningW: 50, surgeW: 75 },
  { name: "Phone Charger", runningW: 15, surgeW: 15 }, { name: "Microwave", runningW: 1000, surgeW: 1500 },
];
---

<CalculatorLayout
  title="Portable Power Station Runtime Calculator | Battery Calculators"
  description="Calculate how long a portable power station will run your appliances during a power outage. Estimate runtime, compare station sizes, and plan backup power for camping, emergencies, and off-grid use."
  faqItems={faqItems}
  whatIs={whatIs}
  whyItMatters={whyItMatters}
  practicalApplications={practicalApplications}
  trustSection={trustSection}
  references={references}
  expertNotes={expertNotes}
  relatedCalculators={relatedCalculators}
>
  <PowerOutageForm
    presetAppliances={presetAppliances}
    defaultBackupHours={8}
    defaultVoltage="24"
    defaultLoadsDescription="Common portable power station loads pre-loaded. Add your actual devices to see accurate runtime."
    defaultLoads={[{ name: "Refrigerator", quantity: 1 }, { name: "Wi-Fi Router", quantity: 1 }, { name: "LED Light", quantity: 2 }]}
  />

  <section class="mb-16 border-t border-hairline pt-12">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <FormulaBox title="Mathematical Formulas">
        <div class="bg-surface-soft p-4 font-mono text-primary border border-hairline my-2">Total Running W = Σ (Appliance Running W × Quantity)</div>
        <div class="bg-surface-soft p-4 font-mono text-primary border border-hairline my-2">Surge W = Highest Single Appliance Surge + Other Running W</div>
        <div class="bg-surface-soft p-4 font-mono text-primary border border-hairline my-2">Energy Required (Wh) = (Running W × Hours) / Inverter Efficiency × (1 + Safety Margin)</div>
        <div class="bg-surface-soft p-4 font-mono text-primary border border-hairline my-2">Battery Ah = Required Wh / (Battery Voltage × Depth of Discharge)</div>
        <p class="text-xs text-muted mt-4">For portable power stations, Battery Voltage and DoD are internal — compare the Energy Required to the station's usable Wh rating.</p>
      </FormulaBox>
      <div>
        <h2 class="text-title-lg text-primary uppercase mb-6 tracking-wider">Worked Example</h2>
        <div class="text-body-sm text-muted flex flex-col gap-4">
          <p><strong>Scenario:</strong> How long will a portable power station run a fridge, Wi-Fi, and two lights?</p>
          <div class="border-l-2 border-m-blue-light pl-4">
            <p class="font-bold text-primary mb-2">Step 1: Running load</p>
            <div class="font-mono text-primary">Fridge: 150W, Wi-Fi: 12W, LED×2: 20W</div>
            <div class="font-mono text-primary">Total running: 182W</div>
          </div>
          <div class="border-l-2 border-m-blue-light pl-4">
            <p class="font-bold text-primary mb-2">Step 2: Energy for 8 hours</p>
            <div class="font-mono text-primary">Raw: 182W × 8h = 1,456 Wh</div>
            <div class="font-mono text-primary">After efficiency (85%): 1,456 / 0.85 = 1,713 Wh</div>
            <div class="font-mono text-primary">With 20% margin: 1,713 × 1.20 = 2,056 Wh</div>
          </div>
          <div class="border-l-2 border-m-blue-light pl-4">
            <p class="font-bold text-primary mb-2">Step 3: Station recommendation</p>
            <div class="font-mono text-primary">Need ≈2,056 Wh usable → 2,500Wh rated station</div>
            <div class="font-mono text-primary font-bold mt-1">Result: Look for a 2,500Wh+ LiFePO4 portable power station</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FAQSection items={faqItems} />
</CalculatorLayout>
