---
import Layout from "../layouts/Layout.astro";
import CalculatorCard from "../components/CalculatorCard.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import FAQSection from "../components/FAQSection.astro";

const resources = [
  {
    title: "LiFePO4 Voltage Chart",
    description:
      "Resting voltage reference for LiFePO4 batteries at 12V, 24V, and 48V by state of charge.",
    category: "Reference Chart",
    href: "/learn/lifepo4-voltage-chart",
    tags: ["lifepo4", "voltage", "soc"],
  },
  {
    title: "SOC Reference Chart",
    description:
      "State-of-charge reference and explanation for LiFePO4 batteries, including why voltage behavior can be misleading mid-SOC.",
    category: "Reference Chart",
    href: "/learn/lifepo4-soc-chart",
    tags: ["soc", "state of charge", "estimation"],
  },
  {
    title: "Battery Sizing Reference",
    description:
      "Practical battery sizing tables for RV, solar, marine, home backup, and commercial BESS applications.",
    category: "Reference",
    href: "/learn/battery-sizing-reference",
    tags: ["sizing", "planning", "reference"],
  },
  {
    title: "C-Rate Reference",
    description:
      "C-rate reference for converting discharge/charge current to battery capacity (and vice versa).",
    category: "Reference Table",
    href: "/learn/battery-c-rate-reference",
    tags: ["c-rate", "crate", "charging", "discharging"],
  },
  {
    title: "Temperature Correction Chart",
    description:
      "How temperature impacts usable capacity, charging behavior, and degradation risk with correction factors.",
    category: "Reference Chart",
    href: "/learn/battery-temperature-correction-chart",
    tags: ["temperature", "correction", "capacity"],
  },
];

const faqItems = [
  {
    question: "What are these resources?",
    answer:
      "These are reference pages for key battery engineering topics—charts, tables, and sizing guidance—written to be easy to consult while designing or troubleshooting battery systems.",
  },
  {
    question: "Are the references practical for real projects?",
    answer:
      "Yes. The charts and tables are based on standard engineering relationships and our verified assumptions. Actual results still depend on battery chemistry, temperature, age, and operating conditions.",
  },
  {
    question: "How often are the references updated?",
    answer:
      "They’re updated as the underlying engineering guidance is revised. When major changes occur (new chemistries, corrections, or improved tables), the reference content is refreshed.",
  },
];
---

<Layout
  title="Free Battery Engineering Resources — Cheat Sheets & Worksheets | Battery Calculators"
  description="Free battery engineering resources: reference charts, voltage tables, sizing guides, and planning references for solar, RV, and marine applications."
  faqItems={faqItems}
>
  <div class="max-w-3xl mx-auto">
    <div class="mb-12 border-b border-hairline pb-8">
      <a
        href="/"
        class="text-label-uppercase text-xs text-muted hover:text-primary transition-colors mb-4 inline-block"
        >&larr; Home</a
      >
      <Breadcrumb items={[{ label: "Resources" }]} />
      <span class="text-label-uppercase text-m-blue-light text-xs block mb-4"
        >Reference Resources</span
      >
      <h1 class="text-display-md text-primary mb-6">
        Battery Engineering Reference Resources
      </h1>
      <p class="text-body-md text-body font-light">
        Charts, tables, and sizing references for battery system design. Use
        these pages as quick references while planning and engineering your
        setup.
      </p>
    </div>

    <div class="flex flex-col gap-12">
      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-6">
          Available Resources
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {
            resources.map((resource) => (
              <CalculatorCard class="flex flex-col justify-between">
                <div>
                  <span class="text-label-uppercase text-m-blue-light text-[10px] block mb-2">
                    {resource.category}
                  </span>
                  <h3 class="text-title-lg text-primary mb-3">
                    {resource.title}
                  </h3>
                  <p class="text-body-sm text-muted mb-4">
                    {resource.description}
                  </p>
                  <div class="flex flex-wrap gap-2 mb-4">
                    {resource.tags.map((tag) => (
                      <span class="text-[10px] text-primary border border-hairline px-2 py-0.5 uppercase tracking-wider">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
                <div class="flex gap-3">
                  <a
                    href={resource.href}
                    class="btn-primary text-xs py-3 px-6 inline-block"
                  >
                    Open Reference
                  </a>
                </div>
              </CalculatorCard>
            ))
          }
        </div>
      </section>

      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-4">
          How to Use These Resources
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <CalculatorCard>
            <h4 class="text-primary font-bold mb-2">1. Open the Reference</h4>
            <p class="text-body-sm text-muted">
              Select the reference you need and review the chart or table
              directly in the browser.
            </p>
          </CalculatorCard>
          <CalculatorCard>
            <h4 class="text-primary font-bold mb-2">
              2. Use as a Quick Reference
            </h4>
            <p class="text-body-sm text-muted">
              Keep the reference handy while designing, verifying, or tuning
              battery systems.
            </p>
          </CalculatorCard>
          <CalculatorCard>
            <h4 class="text-primary font-bold mb-2">
              3. Validate with Calculators
            </h4>
            <p class="text-body-sm text-muted">
              Pair these references with our online calculators to tailor
              results to your battery and load conditions.
            </p>
          </CalculatorCard>
        </div>
      </section>

      <section>
        <h2 class="text-title-lg text-primary uppercase tracking-wider mb-4">
          Related Calculators
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <CalculatorCard class="border-m-blue-light">
            <h4 class="text-primary font-bold mb-2">Runtime Calculator</h4>
            <p class="text-body-sm text-muted mb-3">
              Calculate exact runtime for your specific battery and load
              configuration.
            </p>
            <a
              href="/tools/runtime-calculator"
              class="text-label-uppercase text-m-blue-light text-xs hover:text-primary transition-colors"
              >Open Calculator →</a
            >
          </CalculatorCard>
          <CalculatorCard class="border-m-blue-light">
            <h4 class="text-primary font-bold mb-2">
              Battery Sizing Calculator
            </h4>
            <p class="text-body-sm text-muted mb-3">
              Size your battery bank from loads, autonomy, and chemistry
              requirements.
            </p>
            <a
              href="/tools/battery-sizing-calculator"
              class="text-label-uppercase text-m-blue-light text-xs hover:text-primary transition-colors"
              >Open Calculator →</a
            >
          </CalculatorCard>
          <CalculatorCard class="border-m-blue-light">
            <h4 class="text-primary font-bold mb-2">SOC Estimator</h4>
            <p class="text-body-sm text-muted mb-3">
              Estimate state of charge from voltage or coulomb counting.
            </p>
            <a
              href="/tools/soc-estimator"
              class="text-label-uppercase text-m-blue-light text-xs hover:text-primary transition-colors"
              >Open Calculator →</a
            >
          </CalculatorCard>
          <CalculatorCard class="border-m-blue-light">
            <h4 class="text-primary font-bold mb-2">Solar Battery Sizing</h4>
            <p class="text-body-sm text-muted mb-3">
              Size solar battery banks from daily consumption and autonomy.
            </p>
            <a
              href="/tools/solar-battery-sizing-calculator"
              class="text-label-uppercase text-m-blue-light text-xs hover:text-primary transition-colors"
              >Open Calculator →</a
            >
          </CalculatorCard>
          <CalculatorCard class="border-m-blue-light">
            <h4 class="text-primary font-bold mb-2">Battery Passport Generator</h4>
            <p class="text-body-sm text-muted mb-3">
              Create a structured battery lifecycle and compliance-readiness report.
            </p>
            <a
              href="/battery-passport-generator/"
              class="text-label-uppercase text-m-blue-light text-xs hover:text-primary transition-colors"
              >Open Generator →</a
            >
          </CalculatorCard>
        </div>
      </section>

      <FAQSection items={faqItems} />
    </div>
  </div>
</Layout>
