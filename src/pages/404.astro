---
import Layout from "../layouts/Layout.astro";

const popularCalculators = [
  {
    title: "Runtime Calculator",
    url: "/tools/runtime-calculator",
    description:
      "Estimate battery runtime from capacity, load, and efficiency.",
  },
  {
    title: "Solar Battery Sizing Calculator",
    url: "/tools/solar-battery-sizing-calculator",
    description:
      "Size your solar bank from daily consumption and autonomy days.",
  },
  {
    title: "Battery Pack Calculator",
    url: "/tools/battery-pack-calculator",
    description:
      "Design packs from individual cells with series-parallel configs.",
  },
];
---

<Layout
  title="Page Not Found | Battery Calculators"
  description="The page you are looking for does not exist. Browse our battery calculators or visit the learning center."
  canonical="https://batterycalculators.com/404"
>
  <div class="max-w-[700px] mx-auto text-center py-12 md:py-20">
    <!-- Error Code -->
    <span class="text-label-uppercase text-m-blue-light text-xs block mb-4"
      >ERROR</span
    >
    <h1 class="text-display-lg text-primary mb-6">404</h1>
    <p
      class="text-body-md text-body font-light mb-10 mx-auto whitespace-normal"
    >
      The page you are looking for does not exist or has been moved. Check the
      URL or navigate using the options below.
    </p>

    <!-- Action Buttons -->
    <div
      class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16"
    >
      <a href="/" class="btn-primary text-xs">Home</a>
      <a href="/tools" class="btn-primary-outline text-xs">Browse Calculators</a
      >
      <a href="/learn" class="btn-primary-outline text-xs">Learning Center</a>
    </div>

    <!-- Popular Calculators -->
    <div class="border-t border-hairline pt-12">
      <span class="text-label-uppercase text-primary text-xs block mb-6"
        >Popular Calculators</span
      >
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {
          popularCalculators.map((calc) => (
            <a
              href={calc.url}
              class="bg-surface-card border border-hairline p-6 flex flex-col gap-3 hover:border-primary transition-colors text-left group"
            >
              <span class="text-title-md text-primary group-hover:text-m-blue-light transition-colors">
                {calc.title}
              </span>
              <span class="text-body-sm text-muted">{calc.description}</span>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</Layout>
