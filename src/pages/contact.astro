---
import Layout from '../layouts/Layout.astro';
import CalculatorCard from '../components/CalculatorCard.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<Layout
  title="Contact Us | Battery Calculators"
  description="Get in touch with the Battery Calculators team for calculator feedback, bug reports, content corrections, or partnership enquiries."
  canonical="https://batterycalculators.com/contact"
>
  <div class="max-w-3xl mx-auto">
    <Breadcrumb items={[{ label: 'Contact' }]} />

    <div class="mb-12 border-b border-hairline pb-8">
      <span class="text-label-uppercase text-m-blue-light text-xs block mb-4">CONTACT</span>
      <h1 class="text-display-md text-primary mb-6">Contact Us</h1>
      <p class="text-body-md text-body font-light">
        For calculator feedback, bug reports, content corrections, or partnership enquiries, please get in touch using the form or email below.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
      <!-- Contact Info -->
      <div class="md:col-span-1 flex flex-col gap-6 text-body-sm">
        <div>
          <h4 class="text-label-uppercase text-primary text-xs mb-1">Email</h4>
          <p class="text-muted">
            <a href="mailto:dsarangi7@gmail.com" class="hover:text-primary transition-colors underline underline-offset-4">dsarangi7@gmail.com</a>
          </p>
          <p class="text-caption text-muted mt-1 italic">
            For calculator feedback, bug reports, or partnership enquiries.
          </p>
        </div>
        <div>
          <h4 class="text-label-uppercase text-primary text-xs mb-1">Response Time</h4>
          <p class="text-muted">1–3 business days</p>
        </div>
        <div>
          <h4 class="text-label-uppercase text-primary text-xs mb-1">Topics</h4>
          <ul class="flex flex-col gap-1 text-muted">
            <li>Calculator Feedback</li>
            <li>Bug Reports</li>
            <li>Content Corrections</li>
            <li>Partnership Enquiries</li>
          </ul>
        </div>
        <div>
          <h4 class="text-label-uppercase text-primary text-xs mb-1">Educational Scope</h4>
          <p class="text-muted">
            All algorithms are public and intended for educational battery system design sizing check-ups.
          </p>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="md:col-span-2">
        <CalculatorCard>
          <form id="contact-form" class="flex flex-col gap-4">
            <div class="flex flex-col gap-2">
              <label for="name" class="text-label-uppercase text-xs text-primary">Your Name</label>
              <input type="text" id="name" required class="text-input" placeholder="JOHN DOE" />
            </div>

            <div class="flex flex-col gap-2">
              <label for="email" class="text-label-uppercase text-xs text-primary">Email Address</label>
              <input type="email" id="email" required class="text-input" placeholder="JOHN@EXAMPLE.COM" />
            </div>

            <div class="flex flex-col gap-2">
              <label for="topic" class="text-label-uppercase text-xs text-primary">Topic</label>
              <select id="topic" required class="select-input">
                <option value="" disabled selected>Select a topic</option>
                <option value="calculator-feedback">Calculator Feedback</option>
                <option value="bug-report">Bug Report</option>
                <option value="content-correction">Content Correction</option>
                <option value="partnership">Partnership Enquiry</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="flex flex-col gap-2">
              <label for="message" class="text-label-uppercase text-xs text-primary">Message</label>
              <textarea id="message" required class="text-input h-32 resize-none" placeholder="YOUR MESSAGE HERE..."></textarea>
            </div>

            <button type="submit" class="btn-primary w-full text-xs h-12">Send Message</button>
          </form>
          
          <div id="form-success" class="hidden mt-4 p-4 border border-green-600 bg-surface-soft text-body-sm text-green-500">
            Thank you for your message. This is a static site — your message was recorded locally but not sent to a backend server. For actual enquiries, please email us directly.
          </div>
        </CalculatorCard>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const successDiv = document.getElementById('form-success');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      form.reset();
      if (successDiv) {
        successDiv.classList.remove('hidden');
        setTimeout(() => {
          successDiv.classList.add('hidden');
        }, 8000);
      }
    });
  </script>
</Layout>
