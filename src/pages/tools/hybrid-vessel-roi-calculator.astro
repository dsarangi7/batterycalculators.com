---
import CalculatorLayout from '../../layouts/CalculatorLayout.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import InputField from '../../components/InputField.astro';
import ResultBox from '../../components/ResultBox.astro';
import FormulaBox from '../../components/FormulaBox.astro';
import FAQSection from '../../components/FAQSection.astro';
import RelatedTools from '../../components/RelatedTools.astro';

const whatIs = `The Hybrid Vessel ROI Calculator evaluates the financial return on investment for marine hybridization and electrification projects. It models fuel cost savings, additional electricity costs, simple payback period, lifetime savings, net present value (NPV), and return on investment (ROI) for battery-electric and hybrid propulsion retrofits. This tool helps vessel owners, operators, and investors make informed decisions about decarbonization capital investments by quantifying the economic case alongside the environmental benefits.`;

const whyItMatters = [
  "Hybrid propulsion systems cost $500K–$5M+ depending on vessel size — quantifying the payback period before investment is essential for financial planning.",
  "Fuel cost savings from hybridization typically deliver 15–30% reduction in annual fuel expenditure, but the economic case depends on fuel prices, electricity costs, and duty cycle.",
  "NPV analysis accounts for the time value of money, providing a more accurate investment assessment than simple payback alone.",
  "The economic case for hybridization strengthens as fuel prices rise and carbon pricing mechanisms expand — early movers capture both fuel savings and regulatory advantage.",
  "Investors and financiers require documented ROI projections to approve marine decarbonization capital expenditures."
];

const practicalApplications = [
  { title: "Retrofit Financial Planning", description: "Evaluate the economic case for converting an existing diesel vessel to diesel-electric hybrid propulsion." },
  { title: "Newbuild Cost-Benefit Analysis", description: "Compare hybrid versus conventional propulsion lifecycle costs for new vessel construction projects." },
  { title: "Carbon Credit Valuation", description: "Estimate the value of emissions reductions in emerging maritime carbon markets and ETS schemes." },
  { title: "Fleet Decarbonization Strategy", description: "Prioritize vessel hybridization investments across a fleet by comparing ROI metrics for each candidate vessel." }
];

const expertNotes: { title: string; variant: 'warning' | 'engineering' | 'info'; content: string }[] = [
  {
    title: "Fuel Cost Sensitivity",
    variant: "warning",
    content: "This calculator assumes constant fuel and electricity prices over the project lifetime. In reality, marine fuel prices are volatile and subject to geopolitical, regulatory, and market factors. Consider running sensitivity analyses at ±20% fuel price scenarios. The IMO 2020 sulfur cap, EU ETS inclusion of maritime, and potential global carbon levy will likely increase fuel costs over the coming decade."
  },
  {
    title: "Electricity Cost Considerations",
    variant: "engineering",
    content: "The electricity cost increase accounts for energy consumed to charge the battery system. This calculator assumes round-trip efficiency of 90% and uses MGO energy density of 10 kWh/liter as conversion basis. Actual electricity costs depend on charging location (shore power rates vary 3× between ports), time-of-use pricing, and whether charging uses dedicated infrastructure or standard port connections."
  },
  {
    title: "Economic Limitations",
    variant: "warning",
    content: "This calculator does not account for: battery replacement costs during vessel lifetime, maintenance cost changes from hybrid systems, insurance premium impacts, vessel residual value changes, carbon credit revenues, or regulatory incentive payments (e.g., green port fee discounts). A full financial model should include these factors. Battery replacement at year 8–12 is a significant cost that should be factored into lifecycle analysis."
  }
];

const trustSection = {
  text: "This calculator uses standard discounted cash flow (DCF) methodology with transparent assumptions. All formulas, conversion factors, and economic parameters are documented below for independent verification.",
  link: { label: "View our methodology and formula derivations", href: "/methodology" }
};

const references = [
  { title: "DNV Maritime Forecast to 2050", url: "https://www.dnv.com/maritime/forecast/", source: "DNV" },
  { title: "IEA — Maritime Transport 2023", url: "https://www.iea.org/reports/maritime-transport-2023", source: "International Energy Agency" },
  { title: "IMO Fourth GHG Study 2020 — Fuel Prices and Emissions Costs", url: "https://www.imo.org/en/OurWork/Environment/Pages/Fourth-IMO-Greenhouse-Gas-Study-2020.aspx", source: "International Maritime Organization" },
  { title: "Clarksons Research — Green Shipping Tracker", url: "https://www.clarksons.net/", source: "Clarksons Research Services" }
];

const faqItems = [
  {
    question: "What fuel cost should I use?",
    answer: "Use your vessel's actual contracted or spot-market fuel price. Current MGO prices range $600–$900/tonne ($0.60–$0.90/liter) depending on region and market conditions. HFO is typically 20–30% cheaper but requires scrubber compliance. Use a conservative estimate (historical average or forward curve) rather than peak prices for financial projections."
  },
  {
    question: "How does electricity cost affect the ROI?",
    answer: "Electricity cost partially offsets fuel savings — you're replacing burned fuel with grid electricity to charge batteries. At $0.15/kWh, electricity costs roughly $1.50 per kWh of fuel energy equivalent (accounting for 90% round-trip efficiency). At $0.10/kWh, the offset is lower, improving ROI. Shore power rates vary significantly between ports — from $0.08/kWh in Norway to $0.25/kWh in some Asian ports."
  },
  {
    question: "What is a realistic fuel reduction percentage?",
    answer: "Depends heavily on duty cycle. Ferries with frequent port calls: 20–40%. Offshore support vessels with DP operations: 15–25%. Harbor tugs: 25–40%. Long-voyage cargo ships: 5–15%. The hybrid system's benefit comes from handling low-load periods (where diesel engines are inefficient) with battery power, enabling engines to run at optimal loading."
  },
  {
    question: "Should I use simple payback or NPV for investment decisions?",
    answer: "Use both. Simple payback gives a quick feasibility check — most marine investors target 5–8 year payback. NPV provides a more accurate investment assessment by accounting for the time value of money. A positive NPV means the project earns more than the discount rate. A project with 7-year payback and 8% discount rate may still have positive NPV if savings are strong in early years."
  },
  {
    question: "How does the discount rate affect the analysis?",
    answer: "The discount rate reflects the cost of capital or required return. Higher discount rates penalize future cash flows more heavily, reducing NPV. Marine industry typical discount rates: 8–12% for established operators, 12–15% for project finance, 15–20% for high-risk ventures. A 0% discount rate gives undiscounted lifetime savings (which equals total cash flow minus initial investment)."
  },
  {
    question: "What about battery replacement costs?",
    answer: "This calculator does not include battery replacement costs. LFP batteries typically last 8–15 years in marine applications (5,000+ cycles). NMC batteries may require replacement at 5–10 years. If your project lifetime exceeds battery life, budget for replacement at approximately 60–80% of original battery cost (prices continue to decline). This significantly impacts long-term ROI."
  },
  {
    question: "Can carbon credits improve the ROI?",
    answer: "Potentially. The EU ETS now covers maritime emissions at approximately €80–100/tonne CO₂. If your vessel trades in EU waters, avoided emissions could generate carbon credit revenue. At 100 tonnes CO₂ reduction and €90/tonne, this adds €9,000/year in value. The IMO is developing a global maritime carbon levy that could further improve hybrid ROI. This calculator does not include carbon credit revenue."
  },
  {
    question: "What about regulatory incentives?",
    answer: "Many port authorities offer green port fee discounts for hybrid/electric vessels — typically 10–30% reduction in port dues. Norway, Germany, and several Asian ports offer shore power subsidies or preferential berthing. The EU Innovation Fund and national green shipping programs provide grants for hybridization projects. These incentives are not included in this calculator but should be factored into your financial model."
  }
];

const relatedArticles = [
  { title: "Hybrid Propulsion Systems Explained", href: "/learn/hybrid-propulsion-systems-explained" },
  { title: "How Hybrid Vessels Reduce Fuel Consumption and Emissions", href: "/learn/how-hybrid-vessels-reduce-emissions" },
];

const relatedCalculators = [
  { href: "/tools/marine-co2-reduction-calculator", title: "Marine CO₂ Reduction Calculator", description: "Quantify emissions reductions from hybridization and shore power." },
  { href: "/tools/vessel-energy-storage-calculator", title: "Vessel Energy Storage Calculator", description: "Determine battery capacity for hybrid or electric vessel systems." },
  { href: "/marine", title: "Marine Electrification Hub", description: "Explore all marine decarbonization tools and resources." },
];
---

<CalculatorLayout
  title="Hybrid Vessel ROI Calculator | Battery Calculators"
  description="Evaluate return on investment for marine hybridization projects with fuel savings, payback period, NPV, and lifetime economic analysis."
  faqItems={faqItems}
  whatIs={whatIs}
  whyItMatters={whyItMatters}
  practicalApplications={practicalApplications}
  trustSection={trustSection}
  references={references}
  expertNotes={expertNotes}
  relatedCalculators={relatedCalculators}
  relatedArticles={relatedArticles}
>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 mb-16">

    <!-- Input Form -->
    <CalculatorCard>
      <h3 class="text-title-lg text-primary mb-6 uppercase tracking-wider">Financial Parameters</h3>
      <div class="flex flex-col gap-6">

        <InputField
          id="fuel-cost"
          label="Fuel Cost"
          value={0.75}
          min={0.01}
          step={0.05}
          unit="$/L"
          helperText="Current MGO/MDO price per liter (typical $0.60–$0.90)."
        />

        <InputField
          id="annual-fuel"
          label="Annual Fuel Consumption"
          value={200000}
          min={1000}
          step={5000}
          unit="L/yr"
          helperText="Total vessel fuel consumption per year."
        />

        <InputField
          id="battery-cost"
          label="Battery System Cost"
          value={1200000}
          min={10000}
          step={50000}
          unit="$"
          helperText="Total installed cost of battery, BMS, and integration."
        />

        <InputField
          id="electricity-cost"
          label="Electricity Cost"
          value={0.15}
          min={0.01}
          step={0.01}
          unit="$/kWh"
          helperText="Shore power or grid electricity rate."
        />

        <InputField
          id="fuel-reduction"
          label="Expected Fuel Reduction"
          value={20}
          min={1}
          max={80}
          step={1}
          unit="%"
          helperText="Estimated reduction from hybrid/electric operation."
        />

        <InputField
          id="project-lifetime"
          label="Project Lifetime"
          value={15}
          min={1}
          max={30}
          step={1}
          unit="years"
          helperText="Vessel operational lifetime for analysis."
        />

        <InputField
          id="discount-rate"
          label="Discount Rate"
          value={8}
          min={0}
          max={30}
          step={0.5}
          unit="%"
          helperText="Cost of capital or required return (0% = undiscounted)."
        />

      </div>
    </CalculatorCard>

    <!-- Results -->
    <CalculatorCard class="border-m-blue-light flex flex-col justify-between">
      <div>
        <h3 class="text-title-lg text-primary mb-6 uppercase tracking-wider">Investment Analysis</h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
          <ResultBox
            label="Annual Fuel Cost (Baseline)"
            value="$150,000"
            suffix="Current annual fuel expenditure"
            variant="primary"
            id="result-baseline-cost"
          />
          <ResultBox
            label="Annual Fuel Savings"
            value="$30,000"
            suffix="From 20% fuel reduction"
            id="result-fuel-savings"
          />
          <ResultBox
            label="Annual Electricity Cost Increase"
            value="$0"
            suffix="Charging battery system"
            id="result-elec-cost"
          />
          <ResultBox
            label="Annual Net Operating Savings"
            value="$0"
            suffix="Fuel savings minus electricity cost"
            id="result-net-savings"
          />
          <ResultBox
            label="Simple Payback Period"
            value="N/A"
            suffix="Battery cost / annual net savings"
            id="result-payback"
          />
          <ResultBox
            label="Lifetime Savings"
            value="$0"
            suffix="Undiscounted over project lifetime"
            id="result-lifetime"
          />
          <ResultBox
            label="Net Present Value (NPV)"
            value="$0"
            suffix="Discounted at specified rate"
            id="result-npv"
          />
          <ResultBox
            label="Return on Investment"
            value="0%"
            suffix="Lifetime return on battery investment"
            id="result-roi"
          />
        </div>
      </div>

      <div class="border-t border-hairline pt-6">
        <h4 class="text-label-uppercase text-primary text-xs mb-2">Investment Assessment</h4>
        <p class="text-body-sm text-muted" id="investment-note">
          At $15,000 net annual savings, the battery system pays for itself in 8.0 years.
        </p>
      </div>
    </CalculatorCard>

  </div>

  <!-- Cumulative Cash Flow Chart -->
  <section class="mb-16">
    <CalculatorCard>
      <h3 class="text-title-lg text-primary mb-4 uppercase tracking-wider">Cumulative Cash Flow Over Project Lifetime</h3>
      <p class="text-body-sm text-muted mb-6">Initial investment (negative) offset by annual net savings until payback, then accumulating positive returns.</p>
      <div id="cashflow-chart" class="overflow-x-auto">
        <svg id="cashflow-svg" viewBox="0 0 600 200" class="w-full block" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Cumulative cash flow chart"></svg>
      </div>
      <div class="flex items-center gap-4 mt-4 text-caption text-muted">
        <span class="flex items-center gap-1.5"><span class="w-3 h-3 bg-m-red inline-block"></span> Negative (investment period)</span>
        <span class="flex items-center gap-1.5"><span class="w-3 h-3 bg-green-600 inline-block"></span> Positive (returns)</span>
        <span class="flex items-center gap-1.5"><span class="w-3 h-3 bg-m-blue-light inline-block"></span> Break-even line</span>
      </div>
    </CalculatorCard>
  </section>

  <!-- Formulas -->
  <section class="mb-16 border-t border-hairline pt-12">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">

      <FormulaBox title="Mathematical Formulas">
        <p>
          Financial analysis uses standard discounted cash flow methodology:
        </p>
        <div class="bg-surface-soft p-4 font-mono text-primary border border-hairline my-2">
          Fuel Savings = Annual Fuel × Reduction% × Fuel Cost
        </div>
        <div class="bg-surface-soft p-4 font-mono text-primary border border-hairline my-2">
          Electricity Cost = (Fuel Saved × 10 kWh/L) / 0.9 × Elec Rate
        </div>
        <div class="bg-surface-soft p-4 font-mono text-primary border border-hairline my-2">
          Net Savings = Fuel Savings - Electricity Cost Increase
        </div>
        <div class="bg-surface-soft p-4 font-mono text-primary border border-hairline my-2">
          Payback = Battery Cost / Net Savings
        </div>
        <div class="bg-surface-soft p-4 font-mono text-primary border border-hairline my-2">
          NPV = -Cost + Σ(Net Savings / (1 + r)^t) for t = 1 to N
        </div>
        <div class="bg-surface-soft p-4 font-mono text-primary border border-hairline my-2">
          ROI = (Lifetime Savings / Battery Cost) × 100%
        </div>
        <p class="mt-4">
          MGO energy density: 10.0 kWh/liter. Battery round-trip efficiency: 90%.<br/>
          NPV uses end-of-year cash flow convention.
        </p>
      </FormulaBox>

      <div>
        <h2 class="text-title-lg text-primary uppercase mb-6 tracking-wider">Worked Engineering Example</h2>
        <div class="text-body-sm text-muted flex flex-col gap-4">
          <p>Given investment parameters:</p>
          <ul class="list-disc pl-6 flex flex-col gap-1">
            <li><strong>Fuel cost:</strong> $0.75/L | <strong>Annual consumption:</strong> 200,000 L</li>
            <li><strong>Battery cost:</strong> $1,200,000 | <strong>Electricity:</strong> $0.15/kWh</li>
            <li><strong>Fuel reduction:</strong> 20% | <strong>Lifetime:</strong> 15 years | <strong>Discount:</strong> 8%</li>
          </ul>

          <p><strong>Step 1:</strong> Calculate baseline annual fuel cost:</p>
          <div class="font-mono text-primary">Baseline = 200,000 × $0.75 = $150,000/year</div>

          <p><strong>Step 2:</strong> Calculate annual fuel savings:</p>
          <div class="font-mono text-primary">Savings = 200,000 × 0.20 × $0.75 = $30,000/year</div>

          <p><strong>Step 3:</strong> Calculate electricity cost increase:</p>
          <div class="font-mono text-primary">Fuel energy = 40,000 L × 10 kWh/L = 400,000 kWh</div>
          <div class="font-mono text-primary">Elec cost = 400,000 / 0.9 × $0.15 = $66,667/year</div>

          <p><strong>Step 4:</strong> Calculate net operating savings:</p>
          <div class="font-mono text-primary">Net = $30,000 - $66,667 = -$36,667/year</div>

          <p><strong>Step 5:</strong> Result — negative net savings at these parameters:</p>
          <div class="font-mono text-primary">At 20% fuel reduction with $0.15/kWh electricity, the fuel savings do not cover electricity costs. Increase fuel reduction to 50%+ or reduce electricity cost.</div>

          <p><strong>At 50% fuel reduction:</strong></p>
          <div class="font-mono text-primary">Savings = $75,000 | Net = $75,000 - $66,667 = $8,333/yr</div>
          <div class="font-mono text-primary">Payback = $1,200,000 / $8,333 = 14.4 years</div>
          <div class="font-mono text-primary">NPV (8%, 15yr) = -$1,200,000 + $71,114 = -$1,128,886</div>
        </div>
      </div>

    </div>
  </section>

  <!-- Sensitivity Note Section -->
  <section class="mb-16 border-t border-hairline pt-12">
    <h2 class="text-title-lg text-primary uppercase tracking-wider mb-6">Sensitivity Analysis Guidance</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <CalculatorCard>
        <h4 class="text-primary font-bold text-sm mb-3">Fuel Price Impact</h4>
        <p class="text-body-sm text-muted">Each $0.10/L increase in fuel price improves annual savings by approximately $2,000/year (at 20% reduction, 200,000 L/year). At current volatility, ±30% fuel price scenarios are recommended for robust financial projections.</p>
      </CalculatorCard>
      <CalculatorCard>
        <h4 class="text-primary font-bold text-sm mb-3">Electricity Rate Impact</h4>
        <p class="text-body-sm text-muted">Shore power rates vary 3× between ports ($0.08–$0.25/kWh). Reducing electricity cost from $0.15 to $0.10/kWh saves $22,222/year, dramatically improving payback. Charging at off-peak rates or using dedicated infrastructure reduces costs.</p>
      </CalculatorCard>
      <CalculatorCard>
        <h4 class="text-primary font-bold text-sm mb-3">Carbon Price Upside</h4>
        <p class="text-body-sm text-muted">EU ETS carbon prices at €80–100/tonne CO₂ add potential revenue. At 64 tonnes CO₂ reduction (from 200,000 L MGO), carbon credits add €5,120–€6,400/year. This calculator does not include carbon revenue but it should be modeled separately.</p>
      </CalculatorCard>
    </div>
  </section>

  <FAQSection items={faqItems} />
  <RelatedTools tools={relatedCalculators} />

  <!-- Calculation Script -->
  <script>
    import { calculateHybridVesselRoi } from '../../utils/calculators';

    const fuelCostInput = document.getElementById('fuel-cost') as HTMLInputElement;
    const annualFuelInput = document.getElementById('annual-fuel') as HTMLInputElement;
    const batteryCostInput = document.getElementById('battery-cost') as HTMLInputElement;
    const electricityCostInput = document.getElementById('electricity-cost') as HTMLInputElement;
    const fuelReductionInput = document.getElementById('fuel-reduction') as HTMLInputElement;
    const projectLifetimeInput = document.getElementById('project-lifetime') as HTMLInputElement;
    const discountRateInput = document.getElementById('discount-rate') as HTMLInputElement;

    function getResultElements(id: string) {
      const box = document.getElementById(id);
      return {
        value: box?.querySelector('.text-display-md, .text-title-lg') as HTMLElement,
        suffix: box?.querySelector('.text-caption') as HTMLElement,
      };
    }

    const baselineCost = getResultElements('result-baseline-cost');
    const fuelSavings = getResultElements('result-fuel-savings');
    const elecCost = getResultElements('result-elec-cost');
    const netSavings = getResultElements('result-net-savings');
    const payback = getResultElements('result-payback');
    const lifetime = getResultElements('result-lifetime');
    const npv = getResultElements('result-npv');
    const roi = getResultElements('result-roi');
    const investmentNoteEl = document.getElementById('investment-note');

    function fmt(n: number, decimals = 1): string {
      if (Math.abs(n) >= 1000000) return `$${(n / 1000000).toFixed(decimals)}M`;
      if (Math.abs(n) >= 1000) return `$${(n / 1000).toFixed(decimals)}K`;
      return `$${n.toFixed(decimals)}`;
    }

    function drawCashflowChart(cashFlows: number[], paybackYear: number | null) {
      const svg = document.getElementById('cashflow-svg');
      if (!svg) return;

      const n = cashFlows.length;
      if (n === 0) return;

      const minVal = Math.min(...cashFlows, 0);
      const maxVal = Math.max(...cashFlows, 0);
      const range = maxVal - minVal || 1;

      const padding = { top: 20, right: 20, bottom: 30, left: 60 };
      const w = 600 - padding.left - padding.right;
      const h = 200 - padding.top - padding.bottom;

      const barWidth = Math.max(1, (w / n) - 2);
      const gap = w / n;

      // Scale: 0 line position
      const zeroY = padding.top + (maxVal / range) * h;

      let svgContent = `
        <line x1="${padding.left}" y1="${zeroY}" x2="${600 - padding.right}" y2="${zeroY}" stroke="#3c3c3c" stroke-width="1" stroke-dasharray="4,4"/>
        <text x="${padding.left - 5}" y="${zeroY + 4}" fill="#7e7e7e" font-size="8" text-anchor="end">$0</text>
      `;

      cashFlows.forEach((cf, i) => {
        const x = padding.left + i * gap + gap / 2 - barWidth / 2;
        const barHeight = Math.abs(cf / range) * h;
        const y = cf >= 0 ? zeroY - barHeight : zeroY;
        const color = cf >= 0 ? '#16a34a' : '#e22718';

        svgContent += `<rect x="${x}" y="${y}" width="${barWidth}" height="${barHeight}" fill="${color}" rx="1"/>`;

        // Year labels every few years
        if (n <= 15 || i % 2 === 0) {
          svgContent += `<text x="${x + barWidth / 2}" y="${200 - 8}" fill="#7e7e7e" font-size="7" text-anchor="middle">${i}</text>`;
        }
      });

      // Payback line
      if (paybackYear !== null && paybackYear > 0 && paybackYear < n) {
        const pbX = padding.left + paybackYear * gap;
        svgContent += `<line x1="${pbX}" y1="${padding.top}" x2="${pbX}" y2="${200 - padding.bottom}" stroke="#0066b1" stroke-width="1.5" stroke-dasharray="3,3"/>`;
        svgContent += `<text x="${pbX + 4}" y="${padding.top + 10}" fill="#0066b1" font-size="7">Payback</text>`;
      }

      // Y-axis labels
      const steps = 4;
      for (let i = 0; i <= steps; i++) {
        const val = minVal + (range * i) / steps;
        const y = padding.top + h - (i / steps) * h;
        svgContent += `<text x="${padding.left - 5}" y="${y + 3}" fill="#7e7e7e" font-size="7" text-anchor="end">${fmt(val, 0)}</text>`;
      }

      svg.innerHTML = svgContent;
    }

    function updateCalculations() {
      const fuelCost = parseFloat(fuelCostInput.value) || 0.75;
      const annualFuel = parseFloat(annualFuelInput.value) || 200000;
      const batteryCost = parseFloat(batteryCostInput.value) || 1200000;
      const electricityCost = parseFloat(electricityCostInput.value) || 0.15;
      const fuelReduction = parseFloat(fuelReductionInput.value) || 20;
      const projectLifetime = parseFloat(projectLifetimeInput.value) || 15;
      const discountRate = parseFloat(discountRateInput.value) || 8;

      const result = calculateHybridVesselRoi({
        fuelCostPerLiter: fuelCost,
        annualFuelConsumptionLiters: annualFuel,
        batterySystemCost: batteryCost,
        electricityCostPerKwh: electricityCost,
        expectedFuelReductionPercent: fuelReduction,
        projectLifetimeYears: projectLifetime,
        discountRatePercent: discountRate,
      });

      if (baselineCost.value) baselineCost.value.textContent = `$${Math.round(result.annualFuelCostBaseline).toLocaleString()}`;
      if (baselineCost.suffix) baselineCost.suffix.textContent = 'Current annual fuel expenditure';

      if (fuelSavings.value) fuelSavings.value.textContent = `$${Math.round(result.annualFuelCostSavings).toLocaleString()}`;
      if (fuelSavings.suffix) fuelSavings.suffix.textContent = `From ${fuelReduction}% fuel reduction`;

      if (elecCost.value) elecCost.value.textContent = `$${Math.round(result.annualElectricityCostIncrease).toLocaleString()}`;
      if (elecCost.suffix) elecCost.suffix.textContent = 'Charging battery system';

      if (netSavings.value) netSavings.value.textContent = `$${Math.round(result.annualNetOperatingSavings).toLocaleString()}`;
      if (netSavings.suffix) netSavings.suffix.textContent = 'Fuel savings minus electricity cost';

      if (payback.value) {
        payback.value.textContent = result.simplePaybackYears !== null
          ? `${result.simplePaybackYears.toFixed(1)} years`
          : 'N/A';
      }
      if (payback.suffix) payback.suffix.textContent = 'Battery cost / annual net savings';

      if (lifetime.value) lifetime.value = { textContent: fmt(result.lifetimeSavings) } as any;
      if (lifetime.value) (lifetime.value as HTMLElement).textContent = fmt(result.lifetimeSavings);
      if (lifetime.suffix) lifetime.suffix.textContent = 'Undiscounted over project lifetime';

      if (npv.value) npv.value.textContent = fmt(result.npv);
      if (npv.suffix) npv.suffix.textContent = `Discounted at ${discountRate}%`;

      if (roi.value) roi.value.textContent = `${result.roiPercent.toFixed(1)}%`;
      if (roi.suffix) roi.suffix.textContent = 'Lifetime return on battery investment';

      if (investmentNoteEl) investmentNoteEl.textContent = result.paybackNote;

      // Build cashflow array
      const cashFlows: number[] = [-batteryCost];
      let cumulative = -batteryCost;
      for (let y = 1; y <= projectLifetime; y++) {
        cumulative += result.annualNetOperatingSavings;
        cashFlows.push(cumulative);
      }

      drawCashflowChart(cashFlows, result.simplePaybackYears);
    }

    [fuelCostInput, annualFuelInput, batteryCostInput, electricityCostInput, fuelReductionInput, projectLifetimeInput, discountRateInput].forEach(el => {
      el.addEventListener('input', updateCalculations);
    });

    updateCalculations();
  </script>

</CalculatorLayout>
