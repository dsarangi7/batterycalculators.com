---
import CalculatorLayout from '../../layouts/CalculatorLayout.astro';
import CalculatorCard from '../../components/CalculatorCard.astro';
import InputField from '../../components/InputField.astro';
import ResultBox from '../../components/ResultBox.astro';
import FormulaBox from '../../components/FormulaBox.astro';
import FAQSection from '../../components/FAQSection.astro';
import RelatedTools from '../../components/RelatedTools.astro';

const wireSizes = [
  { label: "16 AWG (1.31 mm²)", value: 1.31 },
  { label: "14 AWG (2.08 mm²)", value: 2.08 },
  { label: "12 AWG (3.31 mm²)", value: 3.31 },
  { label: "10 AWG (5.26 mm²)", value: 5.26 },
  { label: "8 AWG (8.37 mm²)", value: 8.37 },
  { label: "6 AWG (13.3 mm²)", value: 13.3 },
  { label: "4 AWG (21.15 mm²)", value: 21.15 },
  { label: "2 AWG (33.6 mm²)", value: 33.6 },
  { label: "1/0 AWG (53.5 mm²)", value: 53.5 },
  { label: "2/0 AWG (67.4 mm²)", value: 67.4 },
  { label: "4/0 AWG (107 mm²)", value: 107 },
  { label: "Custom Metric Size (mm²)", value: "-1" },
];

const materialOptions = [
  { label: "Copper", value: "copper" },
  { label: "Aluminum", value: "aluminum" },
];

const whatIs = `DC cable power loss is the electrical energy dissipated as heat when current flows through a conductor's inherent resistance. It is calculated using the <strong>I²R formula</strong> — power loss equals current squared times resistance. Unlike voltage drop (which affects device operation), cable power loss represents <strong>direct energy waste</strong> — energy that is paid for but never reaches the load. In battery systems, cable losses reduce effective runtime, decrease round-trip efficiency, and generate heat that can degrade wire insulation over time. For a 50A system with 0.008Ω loop resistance, cable losses waste 20W continuously — enough to drain 480 Wh per day.`;

const whyItMatters = [
  "Cable losses directly reduce battery runtime — a 5% cable loss means 5% less energy reaches your loads.",
  "I²R losses scale with the square of current — doubling current quadruples the power loss for the same cable.",
  "Heat generated by cable losses can exceed wire insulation ratings in confined spaces, creating fire hazards.",
  "In solar systems, cable losses reduce the effective energy delivered from panels to batteries.",
  "Long cable runs between battery and inverter are the most common source of unexpected efficiency losses.",
];

const practicalApplications = [
  { title: "Solar PV Systems", description: "Calculate power losses in DC wiring from solar panels to charge controllers and batteries." },
  { title: "Battery-to-Inverter Cabling", description: "Size cables between battery banks and inverters to minimize I²R losses." },
  { title: "Marine Power Distribution", description: "Evaluate cable losses in marine DC power systems with long run distances." },
  { title: "EV Charging Infrastructure", description: "Calculate cable losses in high-current DC charging connections." },
  { title: "Telecom DC Power", description: "Evaluate losses in 48V DC power distribution cables to telecom equipment." },
];

const expertNotes = [
  { title: 'Thermal Feedback Loop', variant: 'warning', content: 'High current heats the wire, which raises its temperature. Higher temperature raises resistance, which increases power loss (I²R) and causes further heating. This positive feedback loop can lead to thermal runaway if cables are undersized. Ensure correct sizing keeps thermal dissipation low.' },
  { title: 'Daily Energy Impact', variant: 'engineering', content: 'A 20W cable loss running 8 hours/day wastes 160 Wh daily — equivalent to a small appliance running all day. Over a year, this adds up to 58.4 kWh of wasted energy, worth $5–$15 at typical electricity rates.' },
];

const trustSection = {
  text: "This calculator uses the standard I²R power loss model with temperature-corrected resistivity for copper and aluminum conductors. All formulas follow IEEE conductor sizing standards and are displayed step-by-step for verification.",
  link: { label: "View our full methodology", href: "/methodology" },
};

const references = [
  { title: "NEC Chapter 9 — Tables for Conductor Resistance", url: "https://www.nfpa.org/codes-and-standards/nfpa-70-standard-for-electrical-safety-in-the-workplace", source: "NFPA / National Electrical Code" },
  { title: "Copper Development Association — Resistance Tables", url: "https://www.copper.org/", source: "Copper Development Association" },
  { title: "IEEE 141 — DC Power Systems Design", url: "https://standards.ieee.org/", source: "IEEE Standards Association" },
];

const faqItems = [
  {
    question: "How do resistive losses differ from voltage drop?",
    answer: "Voltage drop represents the drop in potential energy (volts) at the load terminal, which can cause electronics to malfunction. Resistive cable loss represents actual power (watts) converted into heat, which represents direct efficiency loss and thermal stress in the installation.",
  },
  {
    question: "What is the safe upper limit for continuous cable power loss?",
    answer: "There is no single limit, but a rule of thumb is to keep power losses below 2% to 3% of the total system power. If cable loss exceeds 5%, the cabling is undersized for energy efficiency, and wire heating should be analyzed for safety.",
  },
  {
    question: "How does wire material impact heating?",
    answer: "Aluminum has about 60% higher resistance than copper for the same cross-sectional area. This means an aluminum wire will dissipate 60% more heat than a copper wire of the same thickness carrying identical current. Aluminum requires thicker wire sizes to control heat.",
  },
  {
    question: "Does continuous heating increase resistance?",
    answer: "Yes, this is a dangerous positive feedback loop. High current heats the wire, which raises its temperature. Higher temperature raises resistance, which increases power loss (I²R) and causes further heating. Ensuring correct sizing keeps thermal dissipation low.",
  },
  {
    question: "How do I calculate cable losses in my system?",
    answer: "Measure or calculate the loop resistance (R = ρ × 2L / A), then use P_loss = I² × R. For example, 50A through 0.008Ω loop resistance = 50² × 0.008 = 20W continuous loss.",
  },
  {
    question: "What percentage of cable loss is acceptable?",
    answer: "For battery systems: <2% is excellent, 2–3% is acceptable, 3–5% is marginal, and >5% indicates undersized cabling. For critical or high-power systems, target <1.5% cable loss.",
  },
  {
    question: "How does cable loss affect battery runtime?",
    answer: "Cable losses reduce the effective energy reaching the load. A 5% cable loss means only 95% of battery energy reaches the load, directly reducing runtime by 5%. For a battery providing 4 hours of runtime, 5% cable loss reduces it to 3.84 hours.",
  },
  {
    question: "Can I reduce cable losses by paralleling wires?",
    answer: "Yes. Paralleling two identical cables halves the effective resistance and quarters the I²R loss (since resistance drops by 2× while current per cable also drops by 2×). This is an effective way to reduce losses without replacing with thicker single cables.",
  },
  {
    question: "How do cable losses compare between 12V and 48V systems?",
    answer: "A 480W load draws 40A at 12V but only 10A at 48V. Since I²R losses scale with current squared, the 12V system has 16× more cable loss than the 48V system for the same cable. Higher voltage dramatically reduces cable losses.",
  },
  {
    question: "What is the annual cost of cable losses?",
    answer: "For a 20W cable loss running 8 hours/day at $0.12/kWh: 20W × 8h × 365 days = 58.4 kWh/year = $7.01/year. For larger systems with 100W+ losses, annual costs can reach $50–$200.",
  },
  {
    question: "Do cable losses affect round-trip efficiency?",
    answer: "Yes. Cable losses during both charge and discharge reduce round-trip efficiency. If cables lose 3% during charge and 3% during discharge, total round-trip cable loss is approximately 6%, which must be included in system efficiency calculations.",
  },
];
---

<CalculatorLayout
  title="DC Cable Power Loss Calculator | Battery Calculators"
  description="Estimate electrical power wattage loss (I²R) and daily thermal energy loss in DC battery transmission cables. Exposes standard formula."
  faqItems={faqItems}
  relatedCalculators={[
    { href: "/tools/voltage-drop-calculator", title: "DC Voltage Drop", description: "Calculate terminal voltage drops along lines." },
    { href: "/tools/battery-sizing-calculator", title: "Battery Sizing Tool", description: "Estimate daily consumption sizing requirements." },
    { href: "/tools/energy-conversion-calculator", title: "Energy Conversion", description: "Convert battery capacity values Ah/Wh." },
    { href: "/tools/runtime-calculator", title: "Runtime Calculator", description: "Compute runtime from load wattage profiles." },
    { href: "/tools/battery-pack-calculator", title: "Battery Pack Calculator", description: "Design series/parallel cell configurations." },
  ]}
  whatIs={whatIs}
  whyItMatters={whyItMatters}
  practicalApplications={practicalApplications}
  trustSection={trustSection}
  references={references}
  expertNotes={expertNotes}
>

  <!-- Main Calculator Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 mb-16">

    <!-- Input Form -->
    <CalculatorCard>
      <h3 class="text-title-lg text-primary mb-6 uppercase tracking-wider">Cable Parameters</h3>
      <div class="flex flex-col gap-6">
        <InputField id="current" label="Continuous Current (Amperes)" value={50} min={0.1} step="any" />
        <InputField id="length" label="One-Way Run Distance (Meters)" value={3} min={0.1} step="any" helperText="The loop is doubled to cover source and return paths." />
        <InputField id="wire-dropdown" label="Conductor Size" type="select" options={wireSizes} value="13.3" />
        <InputField id="custom-area" label="Custom Area (mm²)" value={13.3} min={0.01} step="any" wrapperId="custom-area-wrapper" />
        <InputField id="material" label="Conductor Material" type="select" options={materialOptions} value="copper" />
        <InputField id="temperature" label="Operating Temp (°C)" value={25} min={-40} max={200} />
        <InputField id="runtime" label="Daily Load Duration (Hours/Day)" value={4} min={0.1} max={24} step="any" />
        <InputField id="total-power" label="Total Load Power (Watts)" value={600} min={1} step="any" helperText="Used to calculate percentage efficiency loss." />
      </div>
    </CalculatorCard>

    <!-- Calculation Results -->
    <CalculatorCard class="border-m-blue-light flex flex-col justify-between">
      <div>
        <h3 class="text-title-lg text-primary mb-6 uppercase tracking-wider">Estimated Outputs</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8" id="results-grid">
          <ResultBox
            label="Continuous Cable Power Loss"
            value="19.78 W"
            suffix="3.30% of total load power lost as heat"
            variant="primary"
            id="result-status-card"
          />
          <ResultBox
            label="Daily Energy Loss"
            value="79.1 Wh"
            suffix="Dissipated per 24h"
            id="result-energy-loss-box"
          />
          <ResultBox
            label="Loop Resistance"
            value="0.0079 Ω"
            suffix="Two ways resistance"
            id="result-resistance-box"
          />
        </div>
      </div>

      <!-- Action Area -->
      <div class="border-t border-hairline pt-6">
        <h4 class="text-label-uppercase text-primary text-xs mb-2">Conductor Heating Hazard Note</h4>
        <p class="text-body-sm text-muted">
          All electrical energy lost inside transmission cables is converted into heat. High losses in confined spaces (like battery boxes or conduit runs) will elevate wire temperatures, degrade wire insulation, and create severe fire hazards.
        </p>
      </div>
    </CalculatorCard>

  </div>

  <!-- Technical Explanation and Equations -->
  <section class="mb-16 border-t border-hairline pt-12">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <FormulaBox title="Mathematical Formulas">
        <p>Power loss P_loss is determined by the square of the current moving through the wire loop (I²R):</p>
        <div class="bg-surface-soft p-4 font-mono text-primary border border-hairline my-2">
          Cable Resistance (R) = ρ(T) × (2 × Distance) / Area
        </div>
        <div class="bg-surface-soft p-4 font-mono text-primary border border-hairline my-2">
          Power Loss (W) = Current² (A) × Cable Resistance (Ω)
        </div>
        <p>Energy loss E_loss and percentage efficiency loss are computed as:</p>
        <div class="bg-surface-soft p-4 font-mono text-primary border border-hairline my-2">
          Energy Loss (Wh) = Power Loss (W) × Run Time (Hours)
        </div>
        <div class="bg-surface-soft p-4 font-mono text-primary border border-hairline my-2">
          Efficiency Loss (%) = (Power Loss (W) / Load Power (W)) × 100
        </div>
      </FormulaBox>

      <!-- Worked Example -->
      <div>
        <h2 class="text-title-lg text-primary uppercase mb-6 tracking-wider">Worked Engineering Example</h2>
        <div class="text-body-sm text-muted flex flex-col gap-4">
          <p>Consider a high-current battery linkage loop:</p>
          <ul class="list-disc pl-6 flex flex-col gap-1">
            <li><strong>Current:</strong> 50 A</li>
            <li><strong>Distance:</strong> 3 meters (6m loop)</li>
            <li><strong>Size:</strong> 6 AWG (13.3 mm² area)</li>
            <li><strong>Material:</strong> Copper, 25°C</li>
            <li><strong>Run Duration:</strong> 4 hours/day</li>
            <li><strong>Load:</strong> 600 W</li>
          </ul>
          <p><strong>Step 1:</strong> Solve temperature-corrected resistivity (copper):</p>
          <div class="font-mono text-primary">ρ = 1.72 × 10⁻⁸ × (1 + 0.00393 × (25 − 20)) = 1.7538 × 10⁻⁸ Ω·m</div>
          <p><strong>Step 2:</strong> Solve Loop resistance:</p>
          <div class="font-mono text-primary">R_loop = 1.7538 × 10⁻⁸ × (2 × 3) / (1.33 × 10⁻⁵) = 0.00791 Ω</div>
          <p><strong>Step 3:</strong> Calculate continuous power loss:</p>
          <div class="font-mono text-primary">P_loss = 50² × 0.00791 = 2500 × 0.00791 = 19.78 Watts</div>
          <p><strong>Step 4:</strong> Find percentage efficiency loss and daily energy loss:</p>
          <div class="font-mono text-primary">% Loss = (19.78 W / 600 W) × 100% = 3.30%</div>
          <div class="font-mono text-primary">E_loss = 19.78 W × 4 hours = 79.12 Wh</div>
        </div>
      </div>
    </div>
  </section>

  <FAQSection items={faqItems} />

  <!-- Calculation Script -->
  <script>
    import { calculateDcCableLoss } from '../../utils/calculators';

    const currentInput = document.getElementById('current') as HTMLInputElement;
    const lengthInput = document.getElementById('length') as HTMLInputElement;
    const wireDropdown = document.getElementById('wire-dropdown') as HTMLSelectElement;
    const customAreaWrapper = document.getElementById('custom-area-wrapper');
    const customAreaInput = document.getElementById('custom-area') as HTMLInputElement;
    const materialSelect = document.getElementById('material') as HTMLSelectElement;
    const temperatureInput = document.getElementById('temperature') as HTMLInputElement;
    const runtimeInput = document.getElementById('runtime') as HTMLInputElement;
    const totalPowerInput = document.getElementById('total-power') as HTMLInputElement;

    // Outputs
    const resultStatusCard = document.getElementById('result-status-card');
    const resultPowerLoss = resultStatusCard?.querySelector('.text-display-md') as HTMLElement;
    const resultLossPercent = resultStatusCard?.querySelector('.text-caption') as HTMLElement;
    const resultEnergyLoss = document.getElementById('result-energy-loss-box')?.querySelector('.text-title-lg') as HTMLElement;
    const resultResistance = document.getElementById('result-resistance-box')?.querySelector('.text-title-lg') as HTMLElement;

    function toggleCustomArea() {
      const isCustom = wireDropdown.value === "-1";
      if (isCustom) {
        customAreaWrapper?.classList.remove('hidden');
      } else {
        customAreaWrapper?.classList.add('hidden');
      }
      updateCalculations();
    }

    function updateCalculations() {
      const current = parseFloat(currentInput.value) || 0;
      const length = parseFloat(lengthInput.value) || 0;
      const material = materialSelect.value as "copper" | "aluminum";
      const temperature = parseFloat(temperatureInput.value) || 25;
      const runtime = parseFloat(runtimeInput.value) || 0;
      const totalPower = parseFloat(totalPowerInput.value) || 1;

      const dropdownArea = parseFloat(wireDropdown.value);
      const wireSize = dropdownArea === -1 ? (parseFloat(customAreaInput.value) || 0.1) : dropdownArea;

      const results = calculateDcCableLoss(current, length, wireSize, material, temperature, runtime, totalPower);

      // Render Outputs
      if (resultPowerLoss) resultPowerLoss.textContent = `${results.powerLossW.toFixed(2)} W`;
      if (resultLossPercent) resultLossPercent.textContent = `${results.lossPercent.toFixed(2)}% of total load power lost as heat`;

      // Energy loss format
      if (resultEnergyLoss) {
        if (results.energyLossWh >= 1000) {
          resultEnergyLoss.textContent = `${(results.energyLossWh / 1000).toFixed(2)} kWh`;
        } else {
          resultEnergyLoss.textContent = `${results.energyLossWh.toFixed(1)} Wh`;
        }
      }

      if (resultResistance) resultResistance.textContent = `${results.resistanceOhm.toFixed(4)} Ω`;

      // Status Card color code border
      if (resultStatusCard) {
        resultStatusCard.className = "bg-surface-soft p-6 border col-span-1 md:col-span-2 " +
          (results.lossPercent > 5 ? "border-red-600" :
           results.lossPercent > 3 ? "border-yellow-500" : "border-hairline");
      }
    }

    wireDropdown.addEventListener('change', toggleCustomArea);
    [currentInput, lengthInput, customAreaInput, materialSelect, temperatureInput, runtimeInput, totalPowerInput].forEach(el => {
      el.addEventListener('input', updateCalculations);
    });

    // Run on boot
    toggleCustomArea();
  </script>
</CalculatorLayout>
