# Environment Variables for Battery Calculators
# Copy this file to .env and fill in your values

# Google Analytics 4 (optional - falls back to default G-D40HJV44WS)
PUBLIC_GA4_ID=G-D40HJV44WS

# Microsoft Clarity (optional - disabled when not set)
# PUBLIC_CLARITY_ID=

# Web3Forms Access Key (required for Marine Support Form)
# Sign up free at https://web3forms.com to get your access key
# The access key determines where form submissions are sent
PUBLIC_WEB3FORMS_ACCESS_KEY=your_access_key_here
